<!DOCTYPE html>
<html lang="<%= typeof locale !== 'undefined' ? locale : 'en' %>" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title><%= tText("TrasX - Forgot Password") %></title>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body class="auth-page auth-page-forgot-password">
  <main class="auth-shell auth-shell-centered">
    <section class="auth-card auth-card-login">
      <div class="auth-card-panel auth-card-panel-form">
        <div class="auth-card-inner">
          <div class="auth-brand-lockup">
            <div class="auth-brand-icon" aria-label="TrasX">W</div>
            <div>
              <div class="auth-brand-name">TrasX</div>
              <div class="auth-brand-tag"><%= tText("Account recovery") %></div>
            </div>
          </div>

          <div class="auth-heading-block">
            <h1 class="auth-heading">
              <%= mode === 'reset' ? tText("Create a new password") : tText("Forgot your password?") %>
            </h1>
            <p class="auth-subheading">
              <%= mode === 'reset'
                ? tText("Enter the code you received and choose your new password.")
                : tText("Enter your email address and we will send you a reset code.") %>
            </p>
          </div>

          <% if (error) { %>
            <div class="auth-alert error"><%= error %></div>
          <% } %>

          <% if (success) { %>
            <div class="auth-alert success"><%= success %></div>
          <% } %>

          <% if (deliveryFallback) { %>
            <div class="auth-alert warning">
              <strong><%= tText("Email service unavailable.") %></strong>
              <%= tText("Use this reset code for") %> <%= deliveryFallback.email %>:
              <strong style="display:block; margin-top: 8px; font-size: 22px; letter-spacing: 0.22em;"><%= deliveryFallback.code %></strong>
            </div>
          <% } %>

          <% if (mode === 'reset') { %>
            <form class="auth-form" action="/auth/forgot-password/reset" method="POST">
              <div class="auth-field">
                <label for="reset_email"><%= tText("Email") %></label>
                <label class="auth-input-wrap" for="reset_email">
                  <span class="auth-input-icon">✉</span>
                  <input class="auth-input auth-input-inline" id="reset_email" type="email" name="email" required value="<%= email || '' %>" placeholder="<%= tText('Email') %>" autocomplete="email">
                </label>
              </div>

              <div class="auth-field">
                <label for="reset_code"><%= tText("Reset code") %></label>
                <label class="auth-input-wrap" for="reset_code">
                  <span class="auth-input-icon">#</span>
                  <input class="auth-input auth-input-inline" id="reset_code" type="text" name="code" required placeholder="<%= tText('6-digit code') %>" inputmode="numeric" maxlength="6">
                </label>
              </div>

              <div class="auth-field">
                <label for="reset_password"><%= tText("New password") %></label>
                <label class="auth-input-wrap" for="reset_password">
                  <span class="auth-input-icon">•</span>
                  <input class="auth-input auth-input-inline" id="reset_password" type="password" name="password" required placeholder="<%= tText('New password') %>" autocomplete="new-password">
                </label>
              </div>

              <div class="auth-field">
                <label for="reset_confirm_password"><%= tText("Confirm password") %></label>
                <label class="auth-input-wrap" for="reset_confirm_password">
                  <span class="auth-input-icon">•</span>
                  <input class="auth-input auth-input-inline" id="reset_confirm_password" type="password" name="confirm_password" required placeholder="<%= tText('Confirm password') %>" autocomplete="new-password">
                </label>
              </div>

              <button type="submit" class="auth-submit auth-submit-solid"><%= tText("Update password") %></button>
            </form>
          <% } else { %>
            <form class="auth-form" action="/auth/forgot-password" method="POST">
              <div class="auth-field">
                <label for="forgot_email"><%= tText("Email") %></label>
                <label class="auth-input-wrap" for="forgot_email">
                  <span class="auth-input-icon">✉</span>
                  <input class="auth-input auth-input-inline" id="forgot_email" type="email" name="email" required placeholder="<%= tText('Email') %>" autocomplete="email">
                </label>
              </div>

              <button type="submit" class="auth-submit auth-submit-solid"><%= tText("Send reset code") %></button>
            </form>
          <% } %>

          <p class="auth-switch-copy">
            <a href="/auth/login"><%= tText("Back to login") %></a>
          </p>
        </div>
      </div>

      <div class="auth-card-panel auth-card-panel-visual">
        <div class="auth-visual-surface">
          <div class="auth-visual-orbit auth-visual-orbit-one"></div>
          <div class="auth-visual-orbit auth-visual-orbit-two"></div>
          <div class="auth-visual-badge auth-visual-badge-slack">✉</div>
          <div class="auth-visual-badge auth-visual-badge-camera">⌁</div>
          <div class="auth-visual-badge auth-visual-badge-google">🔒</div>
          <div class="auth-visual-plus"></div>

          <div class="auth-visual-card auth-visual-card-main">
            <div class="auth-visual-card-top">
              <span></span>
              <span></span>
              <span></span>
            </div>
            <div class="auth-visual-list">
              <div class="auth-visual-user-row">
                <div class="auth-visual-avatar"></div>
                <div class="auth-visual-lines">
                  <span></span>
                  <span></span>
                </div>
              </div>
              <div class="auth-visual-user-row">
                <div class="auth-visual-avatar"></div>
                <div class="auth-visual-lines">
                  <span></span>
                  <span></span>
                </div>
              </div>
              <div class="auth-visual-user-row">
                <div class="auth-visual-avatar"></div>
                <div class="auth-visual-lines">
                  <span></span>
                  <span></span>
                </div>
              </div>
            </div>
          </div>

          <div class="auth-visual-copy">
            <h2><%= tText("Recover access safely.") %></h2>
            <p><%= tText("We send you a code so you can reset your password securely.") %></p>
            <div class="auth-visual-dots">
              <span></span>
              <span class="is-active"></span>
              <span></span>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</body>
</html>
