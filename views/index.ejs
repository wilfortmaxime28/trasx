                      <span><%= tText("Affichage du media") %></span>
                      <small><%= tText("Le choix sera garde pour ce short.") %></small>
                    </div>
                    <div class="short-fit-options" role="radiogroup" aria-label="<%= tText("Affichage du media") %>">
                      <label class="short-fit-option active" data-fit-option="cover">
                        <input type="radio" name="short_media_fit_choice" value="cover" checked>
                        <span class="short-fit-icon"><i data-lucide="maximize-2"></i></span>
                        <span>
                          <strong>Zoome</strong>
                          <small><%= tText("Remplit tout l'ecran") %></small>
                        </span>
                      </label>
                      <label class="short-fit-option" data-fit-option="contain">
                        <input type="radio" name="short_media_fit_choice" value="contain">
                        <span class="short-fit-icon"><i data-lucide="minimize-2"></i></span>
                        <span>
                          <strong><%= tText("Format initial") %></strong>
                          <small><%= tText("Pas de recadrage") %></small>
                        </span>
                      </label>
                    </div>
                  </div>

                  <div class="short-trade-section">
                    <div>
                      <div class="short-trade-title"><%= tText("Activer l'option Trade Short") %></div>
                      <div class="short-trade-subtitle">Permet aux autres de racheter ce short. Meme principe que les posts trade.</div>
                    </div>
                    <label class="short-trade-switch" aria-label="<%= tText("Activer l'option Trade Short") %>">
                      <input type="checkbox" id="shortTradeToggle">
                      <span></span>
                    </label>
                  </div>

                  <div id="shortTradeInfo" class="short-trade-info" style="display: none; margin-top: 0;">
                    <strong><%= tText("Option Trade Short active") %></strong>
                    Vous allez payer <span><%= tText("5 tokens") %></span> pour activer le trade. Si le prix baisse apres un trade, la
                    difference divisee par le prix du token ($<%= Number(typeof tokenPriceUsd !== 'undefined' ? tokenPriceUsd : 0.1).toFixed(4).replace(/\.?0+$/, '') %>) est creditee en tokens.
                    <div class="short-trade-balance <%= Number(currentUser.token_balance || 0) < 5 ? 'is-insufficient' : '' %>" style="margin-top: 6px;">
                      <span><%= tText("Solde disponible :") %> <strong id="shortTradeTokenBalance"><%= Number(currentUser.token_balance || 0) %></strong> tokens</span>
                      <span><%= tText("Cout requis :") %> <strong>5</strong> tokens</span>
                    </div>
                    <% if (Number(currentUser.token_balance || 0) < 5) { %>
                      <div class="short-trade-warning" style="margin-top: 6px;"><%= tText("Solde insuffisant pour activer Trade Short.") %></div>
                    <% } %>
                  </div>
                </div>
              </details>

              <!-- 1. Video Tab Panel -->
              <div id="shortPanelVideo" class="short-tab-panel">
                <div class="settings-field short-upload-card" style="margin-bottom: 10px;">
                  <label
                    style="font-size: 12px; font-weight: 600; color: var(--text-secondary); display: block; margin-bottom: 4px;">Choose
                    Video File</label>
                  <div class="status-upload-row">
                    <label for="shortVideoInput" class="status-upload-btn settings-secondary-btn"><i
                        data-lucide="upload-cloud"></i><span><%= tText("Choose file") %></span></label>
                    <span id="shortVideoFilename" class="status-upload-name"><%= tText("No file chosen") %></span>
                  </div>
                  <input type="file" id="shortVideoInput" class="status-file-input-hidden" name="reel_video"
                    accept="video/*" style="display: none;">
                </div>
                <div id="shortVideoPreviewBox" class="short-media-preview-box"
                  style="display: none; margin-top: 10px; border-radius: 12px; overflow: hidden; background: #000; display: flex; align-items: center; justify-content: center; position: relative; max-height: 190px; aspect-ratio: 9/16; margin: 10px auto;">
                  <video id="shortVideoPreview" style="width:100%; height:100%; object-fit:cover;" muted playsinline preload="auto"></video>
                </div>
                
                <!-- Premium dual video trimmer for Shorts -->
                <div id="shortVideoTrimSection" style="display: none; flex-direction: column; gap: 8px; margin-top: 12px; background: rgba(255, 255, 255, 0.05); padding: 12px; border-radius: 12px; border: 1px solid var(--border-color);">
                  <div style="display: flex; justify-content: space-between; font-size: 11px; color: var(--text-secondary); font-weight: 600;">
                    <span>Trimmer la vidéo</span>
                    <span id="shortTrimRangeLabel">0:00 - 0:00</span>
                  </div>
                  <div class="trimmer-track-container" style="position: relative; width: 100%; height: 28px; background: rgba(0,0,0,0.3); border-radius: 6px; overflow: visible;">
                    <div id="shortTrimmerHighlightTrack" style="position: absolute; height: 100%; top: 0; left: 0%; right: 0%; background: rgba(139, 92, 246, 0.4); border-left: 3px solid var(--primary); border-right: 3px solid var(--primary); pointer-events: none; border-radius: 4px; box-sizing: border-box;"></div>
                    <input type="range" id="shortTrimStartInput" min="0" max="100" value="0" step="0.1" style="position: absolute; width: 100%; top: 0; left: 0; height: 100%; -webkit-appearance: none; appearance: none; background: transparent; pointer-events: auto; margin: 0; outline: none; cursor: pointer; z-index: 3;">
                    <input type="range" id="shortTrimEndInput" min="0" max="100" value="100" step="0.1" style="position: absolute; width: 100%; top: 0; left: 0; height: 100%; -webkit-appearance: none; appearance: none; background: transparent; pointer-events: auto; margin: 0; outline: none; cursor: pointer; z-index: 3;">
                  </div>
                  <div style="font-size: 10px; color: var(--text-muted); text-align: center;">Glissez les poignées pour définir le début et la fin de votre Short.</div>
                </div>
              </div>

              <!-- 2. Image + Audio Tab Panel -->
              <div id="shortPanelImageAudio" class="short-tab-panel" style="display: none;">
                <div class="settings-field short-upload-card" style="margin-bottom: 10px;">
                  <label
                    style="font-size: 12px; font-weight: 600; color: var(--text-secondary); display: block; margin-bottom: 4px;">Choose
                    Image File</label>
                  <div class="status-upload-row">
                    <label for="shortImageInput" class="status-upload-btn settings-secondary-btn"><i
                        data-lucide="upload-cloud"></i><span><%= tText("Choose image") %></span></label>
                    <span id="shortImageFilename" class="status-upload-name"><%= tText("No image chosen") %></span>
                  </div>
                  <input type="file" id="shortImageInput" class="status-file-input-hidden" name="reel_image"
                    accept="image/*" style="display: none;">
                </div>
                <div id="shortImagePreviewBox" class="short-media-preview-box"
                  style="display: none; margin-bottom: 10px; border-radius: 12px; overflow: hidden; max-height: 190px; aspect-ratio: 9/16; margin: 10px auto;">
                  <img id="shortImagePreview" src="" style="width:100%; height:100%; object-fit:cover;">
                </div>

                <!-- Audio Source Choice -->
                <div class="settings-field" style="margin-bottom: 10px;">
                  <label style="font-size: 12px; font-weight: 600; color: var(--text-secondary); display: block; margin-bottom: 4px;">Source de l'audio</label>
                  <select id="shortAudioSourceSelect" class="settings-input">
                    <option value="upload">Importer un fichier audio depuis l'appareil</option>
                    <option value="shared">Choisir un son déjà disponible</option>
                  </select>
                </div>

                <!-- Custom Sound Title Input (only for new uploads) -->
                <div class="settings-field" id="shortAudioTitleField" style="margin-bottom: 10px;">
                  <label style="font-size: 12px; font-weight: 600; color: var(--text-secondary); display: block; margin-bottom: 4px;">Titre du son</label>
                  <input type="text" id="shortAudioTitleInput" name="sound_name" readonly placeholder="Le titre sera détecté automatiquement..." class="settings-input">
                </div>

                <!-- File upload card (shown if source = upload) -->
                <div class="settings-field short-upload-card" id="shortAudioUploadField" style="margin-bottom: 10px;">
                  <label
                    style="font-size: 12px; font-weight: 600; color: var(--text-secondary); display: block; margin-bottom: 4px;">Choose
                    Background Audio File</label>
                  <div class="status-upload-row">
                    <label for="shortAudioInput" class="status-upload-btn settings-secondary-btn"><i
                        data-lucide="music"></i><span><%= tText("Choose audio") %></span></label>
                    <span id="shortAudioFilename" class="status-upload-name"><%= tText("No audio chosen") %></span>
                  </div>
                  <input type="file" id="shortAudioInput" class="status-file-input-hidden" name="reel_audio"
                    accept="audio/*" style="display: none;">
                </div>

                <!-- Shared audio dropdown (shown if source = shared) -->
                <div class="settings-field" id="shortAudioSharedField" style="display: none; margin-bottom: 10px;">
                  <label style="font-size: 12px; font-weight: 600; color: var(--text-secondary); display: block; margin-bottom: 4px;">Sélectionner un son disponible</label>
                  <select id="shortAudioSharedSelect" name="existing_audio_url" class="settings-input">
                    <option value="">-- Charger les sons disponibles --</option>
                  </select>
                </div>
              </div>

              <!-- 3. Voice Note Tab Panel -->
              <div id="shortPanelVoice" class="short-tab-panel" style="display: none;">
                <div
                  style="width: 100%; aspect-ratio: 16/9; border-radius: 14px; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 20px; background: linear-gradient(135deg, #4f46e5 0%, #06b6d4 100%); position: relative; gap: 10px;">
                  <div id="shortVoiceTimer"
                    style="font-family: monospace; font-size: 24px; font-weight: 800; color: white; text-shadow: 0 1px 3px rgba(0,0,0,0.3);">
                    00:00</div>
                  <button type="button" id="shortVoiceRecordBtn"
                    style="width: 54px; height: 54px; border-radius: 50%; border: none; background: white; color: #f5576c; display: grid; place-items: center; cursor: pointer; box-shadow: 0 4px 15px rgba(0,0,0,0.2); transition: transform 0.2s, background 0.2s;">
                    <i data-lucide="mic" style="width: 24px; height: 24px;"></i>
                  </button>
                  <div id="shortVoiceStatus"
                    style="font-size: 11px; font-weight: 700; color: rgba(255,255,255,0.9); text-transform: uppercase; letter-spacing: 0.5px;">
                    Click mic to record</div>

                  <div id="shortVoicePlayerWrapper"
                    style="display: none; width: 85%; align-items: center; gap: 8px; background: rgba(0,0,0,0.2); padding: 6px 12px; border-radius: 30px; margin-top: 5px;">
                    <button type="button" id="shortVoicePlayBtn"
                      style="background: none; border: none; color: white; cursor: pointer; display: flex; align-items: center; justify-content: center;"><i
                        data-lucide="play" style="width: 16px; height: 16px; fill: white;"></i></button>
                    <div
                      style="flex: 1; height: 3px; background: rgba(255,255,255,0.3); border-radius: 1.5px; position: relative; cursor: pointer;"
                      id="shortVoicePlayTimeline">
                      <div
                        style="position: absolute; left: 0; top: 0; width: 0%; height: 100%; background: white; border-radius: 1.5px;"
                        id="shortVoicePlayProgress"></div>
                    </div>
                    <span style="font-size: 9.5px; color: white; font-family: monospace;"
                      id="shortVoicePlayTime">0:00</span>
                  </div>
                </div>
              </div>

              <!-- 4. Audio Only Tab Panel -->
              <div id="shortPanelAudio" class="short-tab-panel" style="display: none;">
                <div class="settings-field" style="margin-bottom: 10px;">
                  <label
                    style="font-size: 12px; font-weight: 600; color: var(--text-secondary); display: block; margin-bottom: 4px;">Choose
                    Audio File</label>
                  <div class="status-upload-row">
                    <label for="shortAudioOnlyInput" class="status-upload-btn settings-secondary-btn"><i
                        data-lucide="music"></i><span><%= tText("Choose audio") %></span></label>
                    <span id="shortAudioOnlyFilename" class="status-upload-name"><%= tText("No audio chosen") %></span>
                  </div>
                  <input type="file" id="shortAudioOnlyInput" class="status-file-input-hidden" name="reel_audio"
                    accept="audio/*" style="display: none;">
                </div>
              </div>

              <!-- Trimmer and Settings (Visible if audio is selected or uploaded) -->
              <div id="shortAudioSettingsSection"
                style="display: none; background: var(--bg-hover); padding: 12px; border-radius: 10px; border: 1px solid var(--border-color); flex-direction: column; gap: 10px;">
                <div>
                  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px;">
                    <label style="font-size: 12px; font-weight: 600; color: var(--text-secondary);">Music Section (Start
                      Time)</label>
                    <span id="shortAudioOffsetLabel"
                      style="font-size: 11.5px; font-weight: 700; color: var(--primary);">0:00</span>
                  </div>
                  <div style="display: flex; gap: 10px; align-items: center;">
                    <input type="range" id="shortAudioOffsetSlider" min="0" max="120" value="0"
                      style="flex: 1; accent-color: var(--primary);">
                    <button type="button" id="shortAudioPreviewBtn" class="icon-btn"
                      style="background: var(--bg-card); border: 1px solid var(--border-color); border-radius: 50%; width: 32px; height: 32px; display: grid; place-items: center; cursor: pointer; color: var(--text-primary);"
                      title="<%= tText("Preview Trimmed Audio") %>">
                      <i data-lucide="play" style="width: 14px; height: 14px;"></i>
                    </button>
                  </div>
                  <div style="position: relative; height: 16px; display: flex; align-items: center; margin-top: 2px;">
                    <div
                      style="width: 100%; height: 6px; background: rgba(0,0,0,0.1); border-radius: 3px; position: absolute;">
                    </div>
                    <div id="shortAudioTrimHighlight"
                      style="position: absolute; height: 6px; background: var(--primary); border-radius: 3px; left: 0%; width: 100%; transition: left 0.1s ease-out, width 0.2s ease-out;">
                    </div>
                  </div>
                </div>
              </div>

              <!-- Side-by-side Duration Limit and Sound Name for compact layout -->
              <div style="display: grid; grid-template-columns: 1fr 1.2fr; gap: 10px; margin-bottom: 4px;">
                <div class="settings-field" style="margin-bottom: 0;">
                  <label style="font-size: 11px; font-weight: 600; color: var(--text-secondary); display: block; margin-bottom: 4px;">Duration</label>
                  <div style="display: flex; gap: 4px;">
                    <label style="flex: 1; text-align: center; background: var(--bg-hover); border: 1px solid var(--border-color); border-radius: 8px; padding: 6px 4px; cursor: pointer; font-size: 10.5px; font-weight: 600; display: block;" id="durationOpt30">
                      <input type="radio" name="audio_duration" value="30" checked style="display: none;"> 30s
                    </label>
                    <label style="flex: 1; text-align: center; background: var(--bg-hover); border: 1px solid var(--border-color); border-radius: 8px; padding: 6px 4px; cursor: pointer; font-size: 10.5px; font-weight: 600; display: block;" id="durationOpt60">
                      <input type="radio" name="audio_duration" value="60" style="display: none;"> 1m
                    </label>
                    <label style="flex: 1; text-align: center; background: var(--bg-hover); border: 1px solid var(--border-color); border-radius: 8px; padding: 6px 4px; cursor: pointer; font-size: 10.5px; font-weight: 600; display: block;" id="durationOpt300">
                      <input type="radio" name="audio_duration" value="300" style="display: none;"> 5m
                    </label>
                  </div>
                </div>

                <div class="settings-field" style="margin-bottom: 0;">
                  <label for="shortSoundName" style="font-size: 11px; font-weight: 600; color: var(--text-secondary); display: block; margin-bottom: 4px;"><%= tText("Sound Name") %></label>
                  <input type="text" id="shortSoundName" name="sound_name" placeholder="<%= tText("Original Sound") %>" class="settings-input" style="height: 32px; font-size: 12.5px; padding: 0 8px; border-radius: 8px;">
                </div>
              </div>

              <div class="settings-field" style="margin-bottom: 10px;">
