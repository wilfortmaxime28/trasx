                        <div class="player-avatar-wrap" style="position: relative; cursor: pointer;">
                          <img id="gamePlayer1Avatar" src="/assets/avatar_placeholder.jpg" alt="<%= tText("Player 1") %>">
                          <video id="gamePlayer1Video" autoplay playsinline muted style="display: none; width: 100%; height: 100%; object-fit: cover; border-radius: 50%; position: absolute; top: 0; left: 0; border: 2px solid var(--primary);"></video>
                          <span class="active-turn-ring"></span>
                        </div>
                        <div class="player-meta">
                          <div class="player-name-wrapper" style="display: flex; align-items: center; gap: 6px;">
                            <div id="gamePlayer1Name" class="player-name"><%= tText("Joueur 1") %></div>
                            <button id="sendGiftP1Btn" class="game-send-gift-btn" data-player-slot="p1" style="display: none;" title="<%= tText("Envoyer un cadeau") %>">
                              <i data-lucide="gift" style="width: 12px; height: 12px; color: #fbbf24;"></i>
                            </button>
                          </div>
                          <span class="player-symbol-badge badge-p1"><%= tText("Pions Noirs (X)") %></span>
                        </div>
                        <span id="gamePlayer1Score" class="player-score-badge">0</span>
                      </div>

                      <div class="scoreboard-vs">VS</div>

                      <!-- Player 2 -->
                      <div class="scoreboard-player p2">
                        <div class="player-avatar-wrap" style="position: relative; cursor: pointer;">
                          <img id="gamePlayer2Avatar" src="/assets/avatar_placeholder.jpg" alt="<%= tText("Player 2") %>">
                          <video id="gamePlayer2Video" autoplay playsinline style="display: none; width: 100%; height: 100%; object-fit: cover; border-radius: 50%; position: absolute; top: 0; left: 0; border: 2px solid #ec4899;"></video>
                          <span class="active-turn-ring"></span>
                        </div>
                        <div class="player-meta">
                          <div class="player-name-wrapper" style="display: flex; align-items: center; gap: 6px;">
                            <div id="gamePlayer2Name" class="player-name"><%= tText("Robot AI") %></div>
                            <button id="sendGiftP2Btn" class="game-send-gift-btn" data-player-slot="p2" style="display: none;" title="<%= tText("Envoyer un cadeau") %>">
                              <i data-lucide="gift" style="width: 12px; height: 12px; color: #fbbf24;"></i>
                            </button>
                          </div>
                          <span id="gamePlayer2SymbolLabel" class="player-symbol-badge badge-p2"><%= tText("Pions Blancs (O)") %></span>
                        </div>
                        <span id="gamePlayer2Score" class="player-score-badge">0</span>
                      </div>

                    </div>

                    <!-- Row: Game Status Bar -->
                    <div id="gameTurnStatus" class="game-turn-status-bar">
                      C'est à votre tour
                    </div>

                    <!-- Boards wrapper -->
                    <div class="game-board-wrapper">
                      
                      <!-- Domino Board Container -->
                      <div id="dominoBoardContainer" class="domino-board-container" style="display: none;">
                        <!-- Action bar (Boneyard status, Draw and Pass buttons) -->
                        <div class="domino-action-bar">
                          <div class="boneyard-badge">
                            <i data-lucide="layers"></i>
                            <span id="boneyardCount"><%= tText("Pioche : 14") %></span>
                          </div>
                          <button id="dominoDrawBtn" class="domino-btn-primary"><%= tText("Piger une tuile") %></button>
                          <button id="dominoPassBtn" class="domino-btn-secondary" style="display: none;">Passer</button>
                        </div>
                        
                        <!-- Scrollable layout of played dominoes -->
                        <div class="domino-table-wrapper">
                          <div id="dominoTable" class="domino-table">
                            <!-- Placed dominoes generated dynamically -->
                          </div>
                        </div>
                        
                        <!-- Player's active hand of dominoes -->
                        <div class="domino-player-hand-section">
                          <h4><%= tText("Votre main") %></h4>
                          <div id="dominoPlayerHand" class="domino-player-hand">
                            <!-- Player tiles generated dynamically -->
                          </div>
                        </div>
                      </div>

                      <!-- Puissance 4 (Connect Four) Grid -->
                      <div id="connectFourBoardContainer" class="connectfour-grid-container">
                        <!-- Columns header drop buttons -->
                        <div class="c4-drop-header">
                          <% for (let col=0; col<7; col++) { %>
                            <button class="c4-drop-btn" data-col="<%= col %>" aria-label="<%= tText("Placer colonne") %> <%= col + 1 %>">
                              <i data-lucide="arrow-down"></i>
                            </button>
                          <% } %>
                        </div>
                        <!-- 6 Rows x 7 Columns grid -->
                        <div id="connectFourGrid" class="connectfour-grid">
                          <!-- Cells populated programmatically -->
                        </div>
                      </div>

                      <!-- Gomoku Board (Uses original styles) -->
                      <div id="gomokuBoardContainer" class="gomoku-board-container">
                        <div id="gomokuBoard" class="gomoku-board"></div>
                      </div>

                      <div id="tableFootballBoardContainer" class="table-football-board-container" style="display: none;">
                        <div class="table-football-card">
                          <div class="table-football-header">
                            <div class="table-football-phase" id="tableFootballPhaseLabel"><%= tText("Phase d'attaque") %></div>
                            <div class="table-football-sub" id="tableFootballSubLabel"><%= tText("Choisissez un couloir pour tirer.") %></div>
                          </div>
                          <div class="table-football-field" id="tableFootballField"></div>
                          <div class="table-football-actions" id="tableFootballActions"></div>
                          <div class="table-football-result" id="tableFootballResult"></div>
                        </div>
                      </div>

                  </div>

                </div>

                <div class="modal-overlay" id="gameConfirmModal" style="display: none;" aria-hidden="true">
                  <div class="modal-content game-confirm-modal-content" role="dialog" aria-modal="true" aria-labelledby="gameConfirmModalTitle">
                    <button class="modal-close" type="button" id="closeGameConfirmModal" aria-label="Fermer">
                      <i data-lucide="x"></i>
                    </button>
                    <div class="game-confirm-modal-icon">
                      <i data-lucide="shield-alert"></i>
                    </div>
                    <h3 id="gameConfirmModalTitle" class="game-confirm-modal-title"><%= tText("Confirmer l'action") %></h3>
                    <p id="gameConfirmModalMessage" class="game-confirm-modal-message">
                      Voulez-vous continuer ?
                    </p>
                    <div class="game-confirm-modal-actions">
                      <button type="button" id="gameConfirmCancelBtn" class="game-confirm-cancel-btn">Annuler</button>
                      <button type="button" id="gameConfirmAcceptBtn" class="game-confirm-accept-btn">Confirmer</button>
                    </div>
                  </div>
                </div>

                <!-- Right Side: Live Spectators List Popover & Live Chat Panel (only in PVP or when spectating) -->
                <div id="gameSidePanel" class="game-side-panel">
                    
                    <!-- Game Live Chat Box (Visible for everyone in game room) -->
                    <div class="game-chat-box">
                      <div class="game-chat-header">
                        <i data-lucide="message-square"></i>
                        <span><%= tText("Chat de la partie") %></span>
                      </div>
                      <!-- Messages Feed -->
                      <div id="gameChatFeed" class="game-chat-feed">
                        <div class="game-chat-empty"><%= tText("Le chat est ouvert ! Envoyez des encouragements en direct.") %></div>
                      </div>
                       <form id="gameChatForm" class="game-chat-form" style="position: relative;">
                         <!-- Quoted Reply Banner -->
                         <div id="gameChatReplyBanner" class="chat-reply-banner" style="display: none; padding: 6px 10px; background: rgba(24, 119, 242, 0.08); border-left: 3px solid var(--primary); border-radius: 4px; margin-bottom: 8px; justify-content: space-between; align-items: center; gap: 8px; width: 100%; box-sizing: border-box;">
                           <div class="chat-reply-content" style="min-width: 0; flex: 1;">
                             <span class="reply-username" id="gameChatReplyUsername" style="font-size: 11px; font-weight: 700; color: var(--primary); display: block;"></span>
                             <p class="reply-text" id="gameChatReplyText" style="margin: 2px 0 0 0; font-size: 11px; color: var(--text-secondary); text-overflow: ellipsis; overflow: hidden; white-space: nowrap;"></p>
                           </div>
                           <button type="button" class="cancel-reply-btn" id="gameChatCancelReply" style="background: none; border: none; color: var(--text-muted); cursor: pointer; padding: 4px; display: flex; align-items: center; justify-content: center;"><i data-lucide="x" style="width: 12px; height: 12px;"></i></button>
                           <input type="hidden" id="gameChatParentId" value="">
                           <input type="hidden" id="gameChatParentUsername" value="">
                           <input type="hidden" id="gameChatParentContent" value="">
                         </div>
                         <div class="game-chat-input-wrapper" style="display: flex; width: 100%; align-items: center; background: var(--bg-hover); border-radius: 8px; border: 1px solid var(--border-color); padding-right: 8px; box-sizing: border-box;">
                           <button type="button" class="emoji-trigger-btn" id="gameChatEmojiBtn" style="background: none; border: none; padding: 8px; color: var(--text-secondary); cursor: pointer; display: flex; align-items: center; justify-content: center;"><i data-lucide="smile" style="width: 16px; height: 16px;"></i></button>
                           <input type="text" id="gameChatInput" placeholder="<%= tText("Tapez un message...") %>" autocomplete="off" style="flex: 1; border: none; background: none; outline: none; padding: 10px; color: var(--text-primary); font-size: 12px; font-family: inherit;">
                           <button type="submit" style="background: none; border: none; padding: 8px; color: var(--primary); cursor: pointer; display: flex; align-items: center; justify-content: center;"><i data-lucide="send" style="width: 16px; height: 16px;"></i></button>
                         </div>
                       </form>
                    </div>

                  </div>

                </div>

              </div>



              <!-- Spectators List Popover / Modal (Modern design) -->
              <div class="hashtag-popover spectators-list-modal" id="spectatorsListModal" style="display: none;">
                <div class="modal-header-gradient bg-spectators">
                  <button id="closeSpectatorsListModal" class="modal-close-btn" aria-label="Fermer"><i data-lucide="x"></i></button>
                  <i data-lucide="users" class="modal-header-icon"></i>
                  <h3>Spectateurs</h3>
                  <p><%= tText("Liste des personnes regardant le live") %></p>
                </div>
                <div id="spectatorsListContainer" class="spectators-list-container">
                  <div class="spectators-empty"><%= tText("Aucun spectateur pour le moment.") %></div>
                </div>
              </div>
              <div id="spectatorsListModalOverlay" class="modal-overlay-blur" style="display: none;"></div>

              <!-- Messages Column View (Hidden by default, for mobile/tablet page view) -->
              <div class="mobile-messages-section" id="mobileMessagesSection"
                style="display: <%= currentView === 'messages' ? 'flex' : 'none' %>; flex-direction: column; gap: 20px; width: 100%;">
                <!-- Messages Header -->
                <div style="display: flex; justify-content: space-between; align-items: center; padding: 12px 0;">
                  <h2
                    style="font-family: 'Outfit', sans-serif; font-size: 20px; font-weight: 700; display: flex; align-items: center; gap: 8px; color: var(--text-primary);">
                    <i data-lucide="message-square" style="color: var(--primary);"></i> Messages
                  </h2>
                  <button class="icon-btn" id="mobileMessagesBackBtn" title="<%= tText("Back to Feed") %>"
                    style="font-size: 13px; font-weight: 600; padding: 0 16px; border-radius: 20px; background: var(--bg-card); border: 1px solid var(--border-color); width: auto; height: 36px; display: flex; align-items: center; gap: 6px; color: var(--text-primary); cursor: pointer;">
                    <i data-lucide="arrow-left" style="width: 14px; height: 14px;"></i> Feed
                  </button>
                </div>

                <!-- Messages List Body -->
                <div class="sidebar-card messages-card"
                  style="box-shadow: none; border: none; background: transparent; padding: 0; width: 100%;">
