                                      <button class="post-opt-btn text-style">
                                        <i data-lucide="type"></i>
                                        <span><%= tText("Text Style") %></span>
                                      </button>
                                    </div>

                                    <div class="post-privacy-dropdown">
                                      <button class="privacy-select-btn" id="privacyBtn">
                                        <i data-lucide="globe" id="privacyBtnIcon"></i>
                                        <span id="privacyBtnText">Public</span>
                                        <i data-lucide="chevron-down" style="width:12px; height:12px;"></i>
                                      </button>
                                      <div class="dropdown-menu privacy-dropdown-menu" id="privacyMenu"
                                        style="display: none; position: absolute; right: 0; top: 40px; background: var(--bg-card); border: 1px solid var(--border-color); border-radius: var(--border-radius-item); box-shadow: var(--shadow-lg); z-index: 100; flex-direction: column; width: 130px;">
                                        <a href="#" class="privacy-option" data-value="Public" data-icon="globe"><i
                                            data-lucide="globe" style="width:12px; height:12px; margin-right:6px;"></i>
                                          Public</a>
                                        <a href="#" class="privacy-option" data-value="Friends" data-icon="users"><i
                                            data-lucide="users" style="width:12px; height:12px; margin-right:6px;"></i>
                                          Friends</a>
                                        <a href="#" class="privacy-option" data-value="<%= tText("Only Me") %>" data-icon="lock"><i
                                            data-lucide="lock" style="width:12px; height:12px; margin-right:6px;"></i>
                                          Only Me</a>
                                      </div>
                                    </div>

                                  </div>

                                  <!-- Hashtag List Popover (Premium Design) -->
                                  <div class="hashtag-popover" id="hashtagListModal">
                                    <div class="hashtag-popover-arrow"></div>
                                    <!-- Premium Gradient Header -->
                                    <div
                                      style="background: linear-gradient(135deg, #3b82f6 0%, #8b5cf6 100%); padding: 18px 16px 14px 16px; position: relative; border-radius: 16px 16px 0 0; text-align: center; z-index: 2;">
                                      <button id="closeHashtagListModal"
                                        style="position: absolute; right: 12px; top: 12px; color: rgba(255,255,255,0.8); background: rgba(0,0,0,0.15); border: none; cursor: pointer; border-radius: 50%; width: 22px; height: 22px; display: flex; align-items: center; justify-content: center; transition: all 0.2s;"><i
                                          data-lucide="x" style="width: 12px; height: 12px;"></i></button>
                                      <div
                                        style="display: flex; flex-direction: column; align-items: center; gap: 4px;">
                                        <div
                                          style="background: rgba(255,255,255,0.2); width: 32px; height: 32px; border-radius: 8px; display: flex; align-items: center; justify-content: center; backdrop-filter: blur(4px);">
                                          <i data-lucide="trending-up"
                                            style="color: white; width: 16px; height: 16px;"></i>
                                        </div>
                                        <h3
                                          style="margin: 0; color: white; font-size: 15px; font-weight: 700; letter-spacing: -0.3px;">
                                          Trending Hashtags</h3>
                                        <p style="margin: 0; color: rgba(255,255,255,0.8); font-size: 11px;">Select a
                                          hashtag to insert into your post</p>
                                      </div>
                                    </div>
                                    <div class="hashtag-popover-body">
                                      <div id="hashtagListContainer" class="hashtag-list-container"></div>
                                      <button id="openCreateHashtagModalBtn" class="hashtag-create-btn">
                                        <i data-lucide="plus-circle" style="width: 15px; height: 15px;"></i>
                                        Create Hashtag
                                      </button>
                                    </div>
                                  </div>

                                  <!-- Photo/Video Popover -->
                                  <div class="hashtag-popover" id="photoVideoModal">
                                    <div class="hashtag-popover-arrow"></div>
                                    <div
                                      style="background: linear-gradient(135deg, #1877f2 0%, #00c6ff 100%); padding: 18px 16px 14px 16px; position: relative; border-radius: 16px 16px 0 0; text-align: center; z-index: 2;">
                                      <button id="closePhotoVideoModal"
                                        style="position: absolute; right: 12px; top: 12px; color: rgba(255,255,255,0.8); background: rgba(0,0,0,0.15); border: none; cursor: pointer; border-radius: 50%; width: 22px; height: 22px; display: flex; align-items: center; justify-content: center; transition: all 0.2s;"><i
                                          data-lucide="x" style="width: 12px; height: 12px;"></i></button>
                                      <div
                                        style="display: flex; flex-direction: column; align-items: center; gap: 4px;">
                                        <div
                                          style="background: rgba(255,255,255,0.2); width: 32px; height: 32px; border-radius: 8px; display: flex; align-items: center; justify-content: center; backdrop-filter: blur(4px);">
                                          <i data-lucide="image" style="color: white; width: 16px; height: 16px;"></i>
                                        </div>
                                        <h3
                                          style="margin: 0; color: white; font-size: 15px; font-weight: 700; letter-spacing: -0.3px;">
                                          Add Photos/Videos</h3>
                                        <p style="margin: 0; color: rgba(255,255,255,0.8); font-size: 11px;">Select
                                          images or videos for your post</p>
                                      </div>
                                    </div>
                                    <div class="hashtag-popover-body" style="padding: 16px;">
                                      <div class="media-upload-zone" id="mediaUploadZone"
                                        style="border: 2px dashed var(--border-color); border-radius: 12px; padding: 24px 16px; text-align: center; cursor: pointer; background: var(--bg-hover); transition: all 0.2s;">
                                        <i data-lucide="upload-cloud"
                                          style="color: var(--text-secondary); width: 32px; height: 32px; margin: 0 auto 8px auto;"></i>
                                        <div style="font-size: 13px; font-weight: 600; color: var(--text-primary);">
                                          Click to Upload</div>
                                        <div style="font-size: 11px; color: var(--text-secondary); margin-top: 4px;">1,
                                          2, 3 ou 4 images (max 10 Mo/image) ou 1 vidéo (max 150 Mo)</div>
                                        <input type="file" id="photoVideoInput" accept="image/*,video/*" multiple
                                          style="display: none;">
                                      </div>
                                      <div id="mediaPreviewContainer"
                                        style="margin-top: 12px; max-height: 80px; overflow-y: auto; display: flex; flex-direction: column; gap: 6px;">
                                      </div>
                                      <label class="video-download-setting" id="videoDownloadSetting">
                                        <input type="checkbox" id="allowVideoDownloadToggle" checked>
                                        <span class="video-download-toggle-ui">
                                          <span></span>
                                        </span>
                                        <span><%= tText("Autoriser le téléchargement de la vidéo") %></span>
                                      </label>

                                      <!-- Media Setup (Caption & Destination) Section (WhatsApp / Facebook style) -->
                                      <div id="photoVideoMediaSetupSection" style="display: none; flex-direction: column; gap: 12px; margin-top: 12px;">
                                        <div id="photoVideoMediaPreviewBox" style="width: 100%; border-radius: 8px; overflow: hidden; background: #000; display: flex; align-items: center; justify-content: center; position: relative; max-height: 180px;">
                                          <!-- Selected media (img or video) will be placed here dynamically -->
                                        </div>

                                        <!-- Video Trimmer Container -->
                                        <div id="videoTrimmerContainer" style="display: none; flex-direction: column; gap: 8px; margin-top: 6px;">
                                          <div style="display: flex; justify-content: space-between; font-size: 11px; color: var(--text-secondary); font-weight: 600;">
                                            <span>Trimmer la vidéo</span>
                                            <span id="trimRangeLabel">0:00 - 0:00</span>
                                          </div>
                                          <div class="trimmer-track-container" style="position: relative; width: 100%; height: 28px; background: rgba(0,0,0,0.3); border-radius: 6px; overflow: visible;">
                                            <div id="trimmerHighlightTrack" style="position: absolute; height: 100%; top: 0; left: 0%; right: 0%; background: rgba(24, 119, 242, 0.4); border-left: 3px solid var(--primary); border-right: 3px solid var(--primary); pointer-events: none; border-radius: 4px; box-sizing: border-box;"></div>
                                            <input type="range" id="trimStartInput" min="0" max="100" value="0" step="0.1" style="position: absolute; width: 100%; top: 0; left: 0; height: 100%; -webkit-appearance: none; appearance: none; background: transparent; pointer-events: auto; margin: 0;">
                                            <input type="range" id="trimEndInput" min="0" max="100" value="100" step="0.1" style="position: absolute; width: 100%; top: 0; left: 0; height: 100%; -webkit-appearance: none; appearance: none; background: transparent; pointer-events: auto; margin: 0;">
                                          </div>
                                          <div style="font-size: 10px; color: var(--text-muted); text-align: center;">Faites glisser les poignées pour définir le début et la fin de la vidéo.</div>
                                        </div>
                                        
                                        <textarea id="photoVideoCaption" placeholder="<%= tText("Écrire une légende...") %>" style="width: 100%; min-height: 60px; border-radius: 8px; border: 1px solid var(--border-color); background: var(--bg-input); color: var(--text-primary); padding: 8px 12px; font-family: inherit; font-size: 13px; resize: none; box-sizing: border-box; outline: none; transition: border-color 0.2s;"></textarea>
                                        
                                        <!-- Destination Section Selector (visible only if video is selected) -->
                                        <div id="photoVideoDestinationContainer" style="display: none; flex-direction: column; gap: 6px;">
                                          <label style="font-size: 12px; font-weight: 700; color: var(--text-secondary); margin-bottom: 2px;">Publier dans :</label>
                                          <div style="display: flex; gap: 10px;">
                                            <label class="media-dest-option active" style="flex: 1; display: flex; align-items: center; gap: 8px; padding: 10px; border: 1.5px solid var(--primary); border-radius: 8px; cursor: pointer; background: var(--bg-hover); transition: all 0.2s;">
                                              <input type="radio" name="photoVideoDestRadio" value="feed" checked style="accent-color: var(--primary); pointer-events: none; display: none;">
                                              <div style="display: flex; flex-direction: column;">
                                                <span style="font-size: 13px; font-weight: 700; color: var(--text-primary);">Fil d'actualité</span>
                                                <span style="font-size: 10px; color: var(--text-secondary);">Ajouter comme post</span>
                                              </div>
                                            </label>
                                            <label class="media-dest-option" style="flex: 1; display: flex; align-items: center; gap: 8px; padding: 10px; border: 1.5px solid var(--border-color); border-radius: 8px; cursor: pointer; background: var(--bg-card); transition: all 0.2s;">
                                              <input type="radio" name="photoVideoDestRadio" value="shorts" style="accent-color: var(--primary); pointer-events: none; display: none;">
                                              <div style="display: flex; flex-direction: column;">
                                                <span style="font-size: 13px; font-weight: 700; color: var(--text-primary);">Shorts (Reel)</span>
                                                <span style="font-size: 10px; color: var(--text-secondary);">Ajouter aux Shorts</span>
                                              </div>
                                            </label>
                                          </div>
                                        </div>

                                        <div style="display: flex; gap: 10px; margin-top: 6px;">
                                          <button type="button" id="photoVideoCancelBtn" style="flex: 1; background: transparent; border: 1px solid var(--border-color); color: var(--text-primary); border-radius: 8px; padding: 10px; font-size: 13px; font-weight: 600; cursor: pointer; transition: all 0.2s; text-align: center;"><%= tText("Annuler") %></button>
