                          <i data-lucide="video-off" style="width: 16px; height: 16px;"></i>
                        </button>
                        <button id="gameMicBtn" class="game-webrtc-btn" type="button" title="<%= tText("Activer/Désactiver le micro") %>" style="display: inline-flex; align-items: center; justify-content: center; width: 36px; height: 36px; border-radius: 50%; border: 1px solid var(--border-color); background: var(--bg-input); color: var(--text-main); cursor: pointer; transition: all 0.2s; padding: 0; outline: none;">
                          <i data-lucide="mic-off" style="width: 16px; height: 16px;"></i>
                        </button>
                      </div>

                      <!-- Real-Time Viewer Indicator -->
