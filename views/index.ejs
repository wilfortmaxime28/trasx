                    <i data-lucide="search" class="search-icon"></i>
                    <input type="text" placeholder="Search" aria-label="<%= tText("Search messages") %>" style="width: 100%;">
                    <i data-lucide="sliders-horizontal" class="filter-icon" title="<%= tText("Filter messages") %>"></i>
                  </div>

                  <% const inbox=(typeof messageInbox !=='undefined' && messageInbox) ? messageInbox : { sections: {
                    general: [], requests: [] }, counts: { general: 0, requests: 0 } }; %>
                    <div class="messages-tabs" style="margin-bottom: 16px;">
                      <button class="tab-btn active" data-tab="general">General<span class="tab-count">(<%=
                            inbox.counts.general %>)</span></button>
                      <button class="tab-btn" data-tab="requests">
                        Requests<span class="tab-count">(<%= inbox.counts.requests %>)</span>
                      </button>
                    </div>

                    <div class="messages-list active" data-message-tab-list="general"
                      style="display: flex; flex-direction: column; gap: 8px;">
                      <% inbox.sections.general.forEach(contact=> { %>
                        <div class="message-item <%= contact.is_online ? 'online' : '' %>"
                          data-contact-id="<%= contact.id %>"
                          data-contact-username="<%= contact.username || '' %>"
                          data-message-category="<%= contact.category %>"
                          data-message-request-status="<%= contact.request_status || '' %>"
                          data-can-manage-request="<%= contact.can_manage_request ? '1' : '0' %>"
                          data-follow-target-id="<%= contact.id %>"
                          data-following="<%= contact.is_following ? '1' : '0' %>"
                          data-followed-by="<%= contact.is_followed_by ? '1' : '0' %>"
                          data-mutual="<%= contact.is_mutual ? '1' : '0' %>"
                          data-is-online="<%= contact.is_online ? '1' : '0' %>"
                          data-last-seen-text="<%= contact.presence_text || '' %>"
                          style="cursor: pointer; display: flex; align-items: center; justify-content: space-between; gap: 12px; width: 100%; padding: 10px 14px; border-radius: var(--border-radius-item); background-color: var(--bg-card); border: 1px solid var(--border-color); box-shadow: var(--shadow-sm);">
                          <div style="display: flex; align-items: center; gap: 12px; flex: 1; min-width: 0;">
                            <div class="msg-avatar-wrapper <%= contact.is_online ? 'online' : '' %>">
                              <div class="avatar" style="width: 36px; height: 36px;">
                                <img src="<%= contact.avatar %>" alt="<%= contact.name %>">
                              </div>
                              <span class="status-dot"></span>
                            </div>
                            <div class="message-details" style="flex: 1; min-width: 0;">
                              <h4 class="contact-name"
                                style="margin: 0; font-size: 13.5px; font-weight: 600; color: var(--text-primary);">
                                <%= contact.name %>
                              </h4>
                              <p class="message-preview" id="mobile-chat-preview-<%= contact.id %>"
                                style="margin: 2px 0 0 0; font-size: 11px; color: var(--text-secondary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                <%= contact.preview %>
                              </p>
                              <p class="message-presence" id="mobile-chat-presence-<%= contact.id %>"
                                style="margin: 2px 0 0 0; font-size: 10px; color: var(--text-muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                <%= contact.presence_text %>
                              </p>
                            </div>
                          </div>
                          <div style="display: flex; align-items: center; gap: 8px; flex-shrink: 0;">
                            <% if (contact.time_text) { %>
                              <span class="chat-time" id="mobile-chat-time-<%= contact.id %>"
                                style="font-size: 10px; color: var(--text-muted); white-space: nowrap;">
                                <%= contact.time_text %>
                              </span>
                              <% } else { %>
                                <span class="chat-time" id="mobile-chat-time-<%= contact.id %>"
                                  style="font-size: 10px; color: var(--text-muted); white-space: nowrap;"></span>
                                <% } %>
                                  <button type="button" class="follow-toggle-btn"
                                    data-follow-target-id="<%= contact.id %>"
                                    data-following="<%= contact.is_following ? '1' : '0' %>"
                                    title="<%= contact.is_following ? 'Unfollow' : 'Follow' %>"
                                    aria-label="<%= contact.is_following ? 'Unfollow' : 'Follow' %>">
                                    <i data-lucide="<%= contact.is_following ? 'user-check' : 'user-plus' %>"
                                      style="width: 14px; height: 14px;"></i>
                                  </button>
                          </div>
                        </div>
                        <% }) %>
                    </div>

                    <div class="messages-list" data-message-tab-list="requests"
                      style="display: none; flex-direction: column; gap: 8px;">
                      <% inbox.sections.requests.forEach(contact=> { %>
                        <div class="message-item <%= contact.is_online ? 'online' : '' %>"
                          data-contact-id="<%= contact.id %>"
                          data-contact-username="<%= contact.username || '' %>"
                          data-message-category="<%= contact.category %>"
                          data-message-request-status="<%= contact.request_status || '' %>"
                          data-can-manage-request="<%= contact.can_manage_request ? '1' : '0' %>"
                          data-follow-target-id="<%= contact.id %>"
                          data-following="<%= contact.is_following ? '1' : '0' %>"
                          data-followed-by="<%= contact.is_followed_by ? '1' : '0' %>"
                          data-mutual="<%= contact.is_mutual ? '1' : '0' %>"
                          data-is-online="<%= contact.is_online ? '1' : '0' %>"
                          data-last-seen-text="<%= contact.presence_text || '' %>"
                          style="cursor: pointer; display: flex; align-items: center; justify-content: space-between; gap: 12px; width: 100%; padding: 10px 14px; border-radius: var(--border-radius-item); background-color: var(--bg-card); border: 1px solid var(--border-color); box-shadow: var(--shadow-sm);">
                          <div style="display: flex; align-items: center; gap: 12px; flex: 1; min-width: 0;">
                            <div class="msg-avatar-wrapper <%= contact.is_online ? 'online' : '' %>">
                              <div class="avatar" style="width: 36px; height: 36px;">
                                <img src="<%= contact.avatar %>" alt="<%= contact.name %>">
                              </div>
                              <span class="status-dot"></span>
                            </div>
                            <div class="message-details" style="flex: 1; min-width: 0;">
                              <h4 class="contact-name"
                                style="margin: 0; font-size: 13.5px; font-weight: 600; color: var(--text-primary);">
                                <%= contact.name %>
                              </h4>
                              <p class="message-preview" id="mobile-chat-preview-<%= contact.id %>"
                                style="margin: 2px 0 0 0; font-size: 11px; color: var(--text-secondary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                <%= contact.preview %>
                              </p>
                              <p class="message-presence" id="mobile-chat-presence-<%= contact.id %>"
                                style="margin: 2px 0 0 0; font-size: 10px; color: var(--text-muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                <%= contact.presence_text %>
                              </p>
                            </div>
                          </div>
                          <div style="display: flex; align-items: center; gap: 8px; flex-shrink: 0;">
                            <% if (contact.time_text) { %>
                              <span class="chat-time" id="mobile-chat-time-<%= contact.id %>"
                                style="font-size: 10px; color: var(--text-muted); white-space: nowrap;">
                                <%= contact.time_text %>
                              </span>
                              <% } else { %>
                                <span class="chat-time" id="mobile-chat-time-<%= contact.id %>"
                                  style="font-size: 10px; color: var(--text-muted); white-space: nowrap;"></span>
                                <% } %>
                                  <button type="button" class="follow-toggle-btn"
                                    data-follow-target-id="<%= contact.id %>"
                                    data-following="<%= contact.is_following ? '1' : '0' %>"
                                    title="<%= contact.is_following ? 'Unfollow' : 'Follow' %>"
                                    aria-label="<%= contact.is_following ? 'Unfollow' : 'Follow' %>">
                                    <i data-lucide="<%= contact.is_following ? 'user-check' : 'user-plus' %>"
                                      style="width: 14px; height: 14px;"></i>
                                  </button>
                          </div>
                          <% if (contact.can_manage_request) { %>
                            <div class="message-request-actions">
                              <button type="button" class="message-request-action accept"
                                data-message-request-action="accept"
                                data-requester-id="<%= contact.id %>">Accepter</button>
                              <button type="button" class="message-request-action decline"
                                data-message-request-action="decline"
                                data-requester-id="<%= contact.id %>">Refuser</button>
                            </div>
                            <% } %>
                        </div>
                        <% }) %>
                    </div>
                </div>
              </div>
            </main>

            <%- include('partials/rightSidebar') %>

        </div>
      </div>

      <%- include('partials/mobileNav') %>

        <!-- Mobile Messages Drawer -->
        <div class="mobile-drawer" id="messagesDrawer">
          <div class="drawer-header">
            <h3>Messages</h3>
            <button class="drawer-close-btn" id="closeMessagesDrawer"><i data-lucide="x"></i></button>
          </div>
          <div class="drawer-content" id="messagesDrawerContent">
            <!-- Chat items cloned or populated here -->
          </div>
        </div>

        <!-- Floating Toast Container -->
        <div id="appToast"
          style="position: fixed; bottom: 84px; left: 50%; transform: translateX(-50%) translateY(100px); background: var(--text-primary); color: var(--bg-card); padding: 12px 24px; border-radius: var(--border-radius-pill); font-size: 13px; font-weight: 600; box-shadow: var(--shadow-lg); z-index: 99999; transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275), opacity 0.3s ease; opacity: 0; pointer-events: none; border: 1px solid var(--border-color);">
          Action successful
        </div>

        <!-- Container des boîtes de discussion (Facebook-style) -->
        <div class="chat-boxes-container" id="chatBoxesContainer"></div>

        <!-- Create Hashtag Modal (Premium Design) -->
        <div class="modal-overlay" id="createHashtagModal" style="display: none; backdrop-filter: blur(8px);">
          <div class="modal-content"
