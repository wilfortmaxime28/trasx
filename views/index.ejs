                      data-gradient="linear-gradient(135deg, #a18cd1 0%, #fbc2eb 100%)"
                      style="width: 28px; height: 28px; border-radius: 50%; border: 2px solid white; box-shadow: 0 0 0 1px #ccc; cursor: pointer; background: linear-gradient(135deg, #a18cd1 0%, #fbc2eb 100%);"></button>
                    <button type="button" class="color-dot"
                      data-gradient="linear-gradient(135deg, #84fab0 0%, #8fd3f4 100%)"
