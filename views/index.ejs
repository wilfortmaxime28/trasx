<%- include('partials/head') %>
<%
const currentView = (typeof activeView !== 'undefined' ? activeView : 'feed');
const safePosts = Array.isArray(posts) ? posts : [];
const bookmarkedPostsCount = safePosts.filter(p => p.is_bookmarked).length;

function getYouTubeId(url) {
  if (!url) return null;
  const cleaned = url.trim();
  if (cleaned.length === 11 && !cleaned.includes('/') && !cleaned.includes('.')) {
    return cleaned;
  }
  const regExp = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|\&v=|live\/)([^#\&\?]*).*/;
  const match = cleaned.match(regExp);
  return (match && match[2].length === 11) ? match[2] : null;
}
%>
  <div id="globalDownloadProgressBar"
    style="position: fixed; top: 0; left: 0; width: 0%; height: 4px; background: linear-gradient(90deg, var(--primary) 0%, #06b6d4 100%); z-index: 99999; transition: width 0.2s ease, opacity 0.3s ease; opacity: 0; pointer-events: none; box-shadow: 0 1px 10px rgba(139, 92, 246, 0.5);">
  </div>
  <%- include('partials/header') %>
    <% const activeStatuses=Array.isArray(statuses) ? statuses : []; const safeMarketData=(typeof marketData !=='undefined' && marketData) ? marketData : { publicOffers: [], myOffers: [], myOrders: [], stats: {} }; const safeStatusMessage=typeof statusStatus
      !=='undefined' ? statusStatus : null; const safeStatusError=typeof statusError !=='undefined' ? statusError :
      null; const localeCode=typeof locale !=='undefined' ? locale : 'en' ; %>

      <!-- App Wrapper -->
      <div class="app-wrapper">
        <!-- Main Layout Container -->
        <div class="main-layout">

          <%- include('partials/leftSidebar') %>

            <!-- Middle Feed Column -->
            <main class="feed-column">
              <div id="feedMainContent" style="display: <%= (currentView === 'feed' || currentView === 'bookmarks') ? 'flex' : 'none' %>; flex-direction: column; gap: 24px; width: 100%;">
                <!-- Stories Horizontal Container -->
                <div class="stories-wrapper stories-loading" id="storiesWrapper" style="<%= currentView !== 'feed' ? 'display: none;' : '' %>">
                  <!-- Stories skeleton -->
                  <div id="skeletonStories" class="sk-section skeleton-stories-row" aria-hidden="true" style="<%= currentView !== 'feed' ? 'display: none;' : '' %>">
                    <% for(let _ss = 0; _ss < 7; _ss++) { %>
                    <div class="skeleton-story-card">
                      <div class="skeleton-story-avatar skeleton-base"></div>
                      <div class="skeleton-story-label skeleton-base"></div>
                    </div>
                    <% } %>
                  </div>
                  <div class="stories-container is-loading" id="storiesContainer">
                    <button type="button" class="story-card add-story" id="openStatusModalBtn">
                      <div class="story-avatar-container main-user">
                        <img class="story-avatar" src="<%= currentUser.avatar %>" alt="<%= currentUser.name %>">
                        <div class="add-story-btn">
                          <i data-lucide="plus"></i>
                        </div>
                      </div>
                      <span class="story-username">
                        <%= t('status.addStatus', 'Add status' ) %>
                      </span>
                    </button>

                    <% if (activeStatuses.length> 0) { %>
                      <% activeStatuses.forEach((item)=> { %>
                        <%
                          /* Defensively handle both grouped and ungrouped formats to prevent crashes */
                          let group;
                          if (item && Array.isArray(item.statuses)) {
                            group = item;
                          } else if (item) {
                            group = {
                              user_id: item.user_id,
                              user_name: item.user_name || item.username,
                              username: item.username,
                              avatar: item.avatar,
                              statuses: [item]
                            };
                          } else {
                            return;
                          }
                          const latestStatus = group.statuses[group.statuses.length - 1];
                          const serializedStatuses = JSON.stringify(group.statuses.map(s => ({
                            id: s.id,
                            media_url: s.media_url,
                            media_type: s.media_type,
                            caption: s.caption || '',
                            expires_at: s.expires_at ? (s.expires_at instanceof Date ? s.expires_at.toISOString() : String(s.expires_at)) : '',
                            remaining_text: s.remaining_text,
                            trim_start: s.trim_start,
                            trim_end: s.trim_end,
                            bg_color: s.bg_color
                          })));
                        %>
                          <button type="button" class="story-card status-card" data-user-id="<%= group.user_id %>"
                            data-user-name="<%= group.user_name %>" data-username="<%= group.username %>"
                            data-avatar="<%= group.avatar %>" data-statuses='<%= serializedStatuses.replace(/'/g, "&#39;") %>'>
                            <div class="story-avatar-container active-story status-avatar-container"
                              style="position: relative;">
                              <!-- Segmented Ring representing number of status updates (WhatsApp Style) -->
                              <svg class="status-ring-svg" viewBox="0 0 100 100"
                                style="position: absolute; inset: -4px; width: calc(100% + 8px); height: calc(100% + 8px); transform: rotate(-90deg); pointer-events: none; z-index: 1;">
                                <defs>
                                  <linearGradient id="statusRingGradient-<%= group.user_id %>" x1="0%" y1="0%" x2="100%"
                                    y2="100%">
                                    <stop offset="0%" stop-color="#f09433" />
                                    <stop offset="25%" stop-color="#e6683c" />
                                    <stop offset="50%" stop-color="#dc2743" />
                                    <stop offset="75%" stop-color="#cc2366" />
                                    <stop offset="100%" stop-color="#bc1888" />
                                  </linearGradient>
                                </defs>
                                <% const count=group.statuses.length; const r=46; const circumference=2 * Math.PI * r;
                                  const gap=count> 1 ? 6 : 0;
                                  const segmentLength = (circumference - (count * gap)) / count;
                                  %>
                                  <% for (let i=0; i < count; i++) { %>
                                    <circle cx="50" cy="50" r="<%= r %>" fill="none"
                                      stroke="url(#statusRingGradient-<%= group.user_id %>)" stroke-width="3"
                                      stroke-dasharray="<%= segmentLength %> <%= segmentLength + gap %>"
                                      stroke-dashoffset="<%= -i * (segmentLength + gap) %>" stroke-linecap="round" />
                                    <% } %>
                              </svg>

                              <% if (String(latestStatus.media_type || '' ).startsWith('video/')) { %>
                                <video class="story-avatar status-media-preview" muted autoplay loop playsinline
                                  style="z-index: 2;">
                                  <source src="<%= latestStatus.media_url %>" type="<%= latestStatus.media_type %>">
                                </video>
                                <% } else if (latestStatus.media_type==='text' ) { %>
                                  <div class="story-avatar status-media-preview text-status-thumbnail"
                                    style="z-index: 2; background: <%= latestStatus.bg_color || 'linear-gradient(135deg, #a18cd1 0%, #fbc2eb 100%)' %>; display: flex; align-items: center; justify-content: center; color: #fff; font-size: 8px; font-weight: bold; overflow: hidden; padding: 4px; text-align: center; font-family: 'Outfit', sans-serif; word-break: break-word; line-height: 1.1; border-radius: 50%; border: 2px solid var(--bg-card); width: 52px; height: 52px; box-sizing: border-box;">
                                    <%= (latestStatus.caption || '' ).length> 20 ? (latestStatus.caption || '').slice(0,
                                      18) + '..' : latestStatus.caption %>
                                  </div>
                                  <% } else if (latestStatus.media_type && latestStatus.media_type.startsWith('audio/'))
                                    { %>
                                    <div class="story-avatar status-media-preview voice-status-thumbnail"
                                      style="z-index: 2; background: <%= latestStatus.bg_color || 'linear-gradient(135deg, #a18cd1 0%, #fbc2eb 100%)' %>; display: flex; align-items: center; justify-content: center; color: #fff; border-radius: 50%; border: 2px solid var(--bg-card); width: 52px; height: 52px; box-sizing: border-box;">
                                      <i data-lucide="mic" style="width: 18px; height: 18px;"></i>
                                    </div>
                                    <% } else { %>
                                      <img class="story-avatar status-media-preview" src="<%= latestStatus.media_url %>"
                                        alt="<%= group.user_name %>" style="z-index: 2;">
                                      <% } %>
                                        <div class="status-duration-badge" style="z-index: 3;">
                                          <%= group.statuses.length %>
                                        </div>
                            </div>
                            <span class="story-username">
                              <%= (group.user_name || '').trim().length > 10 ? (group.user_name || '').trim().slice(0, 10) + '...' : (group.user_name || '').trim() %>
                            </span>
                          </button>
                          <% }) %>
                            <% } %>
                  </div>
                </div>

                <% if (safeStatusMessage) { %>
                  <div class="alert success">
                    <%= safeStatusMessage %>
                  </div>
                  <% } %>
                    <% if (safeStatusError) { %>
                      <div class="alert error">
                        <%= safeStatusError %>
                      </div>
                      <% } %>

                        <% if (isPartiallyBlocked) { %>
                          <div class="restriction-note"
                            style="background: rgba(255, 59, 48, 0.1); color: #ff3b30; padding: 12px; border-radius: 8px; font-weight: 500; font-size: 14px; margin-bottom: 20px; border: 1px solid rgba(255, 59, 48, 0.2);">
                            <i data-lucide="alert-triangle"
                              style="width: 16px; height: 16px; vertical-align: text-bottom;"></i>
                            Your account is partially blocked. You are in read-only mode and cannot perform any actions.
                          </div>
                          <% } else if (isPaused) { %>
                            <div class="restriction-note"
                              style="background: rgba(255, 149, 0, 0.1); color: #ff9500; padding: 12px; border-radius: 8px; font-weight: 500; font-size: 14px; margin-bottom: 20px; border: 1px solid rgba(255, 149, 0, 0.2);">
                              <i data-lucide="pause-circle"
                                style="width: 16px; height: 16px; vertical-align: text-bottom;"></i>
                              Your account is paused. Please contact administration.
                            </div>
                            <% } %>

                              <% if (!isPartiallyBlocked && !isPaused) { %>
                                <!-- Create Post Card -->
                                <div class="create-post-card" style="<%= currentView !== 'feed' ? 'display: none;' : '' %>">
                                  <div class="create-post-upper">
                                    <div class="create-post-upper-row">
