                <span style="font-size: 12px; font-weight: 600; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.5px; display: block; margin-bottom: 8px;"><%= tText("Statistiques d'utilisation") %></span>
                <div style="display: flex; align-items: center; gap: 16px; background: var(--bg-hover); padding: 16px; border-radius: 10px; border: 1px solid var(--border-color);">
                  <div style="background: rgba(16, 185, 129, 0.1); width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #10b981;">
                    <i data-lucide="trending-up" style="width: 20px;"></i>
                  </div>
                  <div>
                    <div id="detailsHashtagUsageCount" style="font-size: 20px; font-weight: 800; color: var(--text-primary);">0</div>
                    <div style="font-size: 12px; color: var(--text-secondary);"><%= tText("utilisations au total") %></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

