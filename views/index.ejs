                  style="flex: 1; padding: 8px; border-radius: 8px; border: none; background: transparent; color: var(--text-secondary); font-weight: 600; cursor: pointer; font-size: 12.5px; display: flex; align-items: center; justify-content: center; gap: 4px;">
