                                      </div>
                                      
                                      <div style="display: flex; flex-direction: column; gap: 6px;">
                                        <label style="font-size: 11px; font-weight: 800; color: var(--text-secondary); text-transform: uppercase;"><%= tText("Mode d'accès") %></label>
                                        <div style="display:grid; grid-template-columns:1fr 1fr; gap:8px;">
                                          <button type="button" id="liveModeFreeBtn" class="challenge-vote-btn active" style="padding:10px 8px; border-radius:10px; border:1px solid var(--primary); background:var(--bg-hover); color:var(--text-primary); font-size:11px; font-weight:700; cursor:pointer;"><%= tText("Gratuit") %></button>
                                          <button type="button" id="liveModePaidBtn" class="challenge-vote-btn" style="padding:10px 8px; border-radius:10px; border:1px solid var(--border-color); background:var(--bg-hover); color:var(--text-primary); font-size:11px; font-weight:700; cursor:pointer;"><%= tText("Payant") %></button>
                                        </div>
                                      </div>

                                      <div id="livePriceContainer" style="display:none; flex-direction:column; gap:6px;">
                                        <label for="livePriceInput" style="font-size: 11px; font-weight: 800; color: var(--text-secondary); text-transform: uppercase;"><%= tText("Prix d'accès (USD)") %></label>
                                        <input type="number" id="livePriceInput" min="0.01" step="0.01" placeholder="<%= tText("Ex: 2.50") %>" style="width:100%; height:38px; padding:8px 12px; border-radius:10px; border:1px solid var(--border-color); background:var(--bg-hover); color:var(--text-primary); font-size:12px;">
                                      </div>
                                      
                                      <button type="button" id="applyLiveConfigBtn" class="hashtag-create-btn" style="margin-top:4px; width:100%; background:linear-gradient(135deg, #e53935 0%, #e35d5b 100%); border:none; color:white;">
                                        <i data-lucide="check"></i> <%= tText("Confirmer la configuration") %>
                                      </button>
                                      
                                      <button type="button" id="clearLiveConfigBtn" style="display:none; width:100%; height:38px; border-radius:10px; border:1px solid var(--danger); background:transparent; color:var(--danger); font-weight:700; font-size:13px; cursor:pointer; align-items:center; justify-content:center; gap:6px;">
                                        <i data-lucide="trash-2"></i> <%= tText("Annuler la diffusion") %>
                                      </button>
                                    </div>
                                  </div>

                                  <!-- Challenge Popover -->
                                  <div class="hashtag-popover" id="challengeModal">
                                    <div class="hashtag-popover-arrow"></div>
                                    <div
                                      style="background: linear-gradient(135deg, #f44336 0%, #ff9800 100%); padding: 18px 16px 14px 16px; position: relative; border-radius: 16px 16px 0 0; text-align: center; z-index: 2;">
                                      <button id="closeChallengeModal"
                                        style="position: absolute; right: 12px; top: 12px; color: rgba(255,255,255,0.8); background: rgba(0,0,0,0.15); border: none; cursor: pointer; border-radius: 50%; width: 22px; height: 22px; display: flex; align-items: center; justify-content: center; transition: all 0.2s;"><i
                                          data-lucide="x" style="width: 12px; height: 12px;"></i></button>
                                      <div
                                        style="display: flex; flex-direction: column; align-items: center; gap: 4px;">
                                        <div
                                          style="background: rgba(255,255,255,0.2); width: 32px; height: 32px; border-radius: 8px; display: flex; align-items: center; justify-content: center; backdrop-filter: blur(4px);">
                                          <i data-lucide="trophy" style="color: white; width: 16px; height: 16px;"></i>
                                        </div>
                                        <h3
                                          style="margin: 0; color: white; font-size: 15px; font-weight: 700; letter-spacing: -0.3px;">
                                          <h3
                                          style="margin: 0; color: white; font-size: 15px; font-weight: 700; letter-spacing: -0.3px;">
                                          <%= tText("Challenge Builder") %></h3>
                                        <p style="margin: 0; color: rgba(255,255,255,0.8); font-size: 11px;"><%= tText("Beaute, vote, miss et concours avec invitation ou participation libre") %></p>
                                      </div>
                                    </div>
                                    <div class="hashtag-popover-body" style="padding: 12px;">
                                      <div style="display:flex; flex-direction:column; gap:10px;">
                                        <label for="challengeTitleInput"
                                          style="font-size:11px; font-weight:800; color:var(--text-secondary); text-transform:uppercase; letter-spacing:0.08em;">
                                          <%= tText("Nom du challenge") %>
                                        </label>
                                        <input type="text" id="challengeTitleInput" class="challenge-title-input"
                                          placeholder="<%= tText("Ex: Miss Summer 2026") %>">
                                        <div style="display:grid; grid-template-columns:repeat(3, minmax(0, 1fr)); gap:8px;">
                                          <button type="button" class="challenge-type-btn" data-challenge-type="beauty"
                                            style="padding:10px 8px; border-radius:10px; border:1px solid var(--border-color); background:var(--bg-hover); color:var(--text-primary); font-size:11px; font-weight:700; cursor:pointer;"><%= tText("Beauty") %></button>
                                          <button type="button" class="challenge-type-btn" data-challenge-type="vote"
                                            style="padding:10px 8px; border-radius:10px; border:1px solid var(--border-color); background:var(--bg-hover); color:var(--text-primary); font-size:11px; font-weight:700; cursor:pointer;"><%= tText("Vote") %></button>
                                          <button type="button" class="challenge-type-btn" data-challenge-type="miss"
                                            data-certification-required="1"
                                            style="padding:10px 8px; border-radius:10px; border:1px solid var(--border-color); background:var(--bg-hover); color:var(--text-primary); font-size:11px; font-weight:700; cursor:pointer;"><%= tText("Miss") %></button>
                                        </div>
                                        <div id="challengeEntryModeContainer" style="display:grid; grid-template-columns:repeat(2, minmax(0, 1fr)); gap:8px;">
                                          <button type="button" class="challenge-entry-btn" data-challenge-entry="open"
                                            style="padding:10px 8px; border-radius:10px; border:1px solid var(--border-color); background:var(--bg-hover); color:var(--text-primary); font-size:11px; font-weight:700; cursor:pointer;"><%= tText("Participation libre") %></button>
                                          <button type="button" class="challenge-entry-btn" data-challenge-entry="invite_only"
                                            style="padding:10px 8px; border-radius:10px; border:1px solid var(--border-color); background:var(--bg-hover); color:var(--text-primary); font-size:11px; font-weight:700; cursor:pointer;"><%= tText("Inviter une personne") %></button>
                                        </div>
                                        <div style="display:grid; grid-template-columns:repeat(2, minmax(0, 1fr)); gap:8px;">
                                          <button type="button" class="challenge-vote-btn" data-challenge-vote="free"
                                            style="padding:10px 8px; border-radius:10px; border:1px solid var(--border-color); background:var(--bg-hover); color:var(--text-primary); font-size:11px; font-weight:700; cursor:pointer;"><%= tText("Vote gratuit") %></button>
                                          <button type="button" class="challenge-vote-btn" data-challenge-vote="paid"
                                            style="padding:10px 8px; border-radius:10px; border:1px solid var(--border-color); background:var(--bg-hover); color:var(--text-primary); font-size:11px; font-weight:700; cursor:pointer;"><%= tText("Vote payant") %></button>
                                        </div>
                                        <input type="number" min="0" step="0.01" id="challengeVotePriceInput"
                                          class="settings-input" placeholder="<%= tText("Montant du vote payant (USD)") %>"
                                          style="height: 38px; font-size: 12px; display:none;">
                                        <div id="challengeEndDateContainer" style="display:flex; flex-direction:column; gap:6px;">
                                          <label for="challengeEndDateInput" style="font-size:11px; font-weight:800; color:var(--text-secondary); text-transform:uppercase; letter-spacing:0.08em;"><%= tText("Date et heure de fin (optionnel)") %></label>
                                          <input type="datetime-local" id="challengeEndDateInput" class="settings-input" style="height: 38px; font-size: 12px;">
                                        </div>
                                        <div id="challengeCreatorParticipationContainer" style="display:none; align-items:center; justify-content:space-between; padding:10px 12px; border-radius:12px; background:var(--bg-hover); border:1px solid var(--border-color); margin-bottom:8px;">
                                          <span style="font-size:12px; font-weight:700; color:var(--text-primary);"><%= tText("Participer au challenge") %></span>
                                          <label style="position:relative; display:inline-block; width:44px; height:24px; cursor:pointer;">
                                            <input type="checkbox" id="challengeCreatorParticipateToggle" style="opacity: 0; width: 0; height: 0; position: absolute;">
                                            <span id="challengeCreatorParticipateToggleBg" style="display:block; background: var(--border-color); width: 44px; height: 24px; border-radius: 12px; position: relative; transition: background 0.2s;">
                                              <span id="challengeCreatorParticipateToggleKnob" style="display:block; background: white; width: 20px; height: 20px; border-radius: 50%; position: absolute; left: 2px; top: 2px; transition: transform 0.2s;"></span>
                                            </span>
                                          </label>
                                        </div>
                                        <div id="challengeCreatorPhotoContainer" style="display:none; flex-direction:column; gap:6px; padding:10px 12px; border-radius:12px; background:var(--bg-hover); border:1px solid var(--border-color); margin-bottom:8px;">
                                          <span style="font-size:11px; font-weight:800; color:var(--text-secondary); text-transform:uppercase;"><%= tText("Votre photo pour le challenge") %></span>
                                          <div style="display:flex; align-items:center; gap:10px;">
                                            <button type="button" id="challengeCreatorPhotoBtn" style="padding:6px 12px; border-radius:8px; border:1px solid var(--border-color); background:var(--bg-card); color:var(--text-primary); font-size:11px; font-weight:700; cursor:pointer;"><%= tText("Choisir une photo") %></button>
                                            <span id="challengeCreatorPhotoStatus" style="font-size:11px; color:var(--text-secondary);"><%= tText("Aucune photo choisie") %></span>
                                          </div>
                                          <input type="file" id="challengeCreatorPhotoInput" accept="image/*" style="display:none;">
                                        </div>
                                        <input type="text" id="challengeInviteSearchInput" class="settings-input"
                                          placeholder="<%= tText("Rechercher un utilisateur a inviter") %>"
                                          style="height: 38px; font-size: 12px; display:none;">
                                        <div id="challengeParticipantsList" style="display:none; flex-wrap:wrap; gap:6px; margin: 4px 0 8px 0;"></div>
                                        <div id="challengeInviteResults"
                                          style="display:none; max-height:120px; overflow:auto; border:1px solid var(--border-color); border-radius:10px; background:var(--bg-card);"></div>
                                        <button type="button" id="applyChallengeConfigBtn" class="hashtag-create-btn"
                                          style="margin-top:0;">
                                          <i data-lucide="trophy"></i>
                                          <%= tText("Créer et publier le challenge") %>
                                        </button>
                                      </div>
                                    </div>
                                  </div>

                                  <!-- Mention Popover -->
                                  <div class="hashtag-popover" id="mentionModal">
                                    <div class="hashtag-popover-arrow"></div>
                                    <div
                                      style="background: linear-gradient(135deg, #9c27b0 0%, #e040fb 100%); padding: 18px 16px 14px 16px; position: relative; border-radius: 16px 16px 0 0; text-align: center; z-index: 2;">
                                      <button id="closeMentionModal"
                                        style="position: absolute; right: 12px; top: 12px; color: rgba(255,255,255,0.8); background: rgba(0,0,0,0.15); border: none; cursor: pointer; border-radius: 50%; width: 22px; height: 22px; display: flex; align-items: center; justify-content: center; transition: all 0.2s;"><i
                                          data-lucide="x" style="width: 12px; height: 12px;"></i></button>
                                      <div
                                        style="display: flex; flex-direction: column; align-items: center; gap: 4px;">
                                        <div
                                          style="background: rgba(255,255,255,0.2); width: 32px; height: 32px; border-radius: 8px; display: flex; align-items: center; justify-content: center; backdrop-filter: blur(4px);">
                                          <i data-lucide="at-sign" style="color: white; width: 16px; height: 16px;"></i>
                                        </div>
                                        <h3
                                          style="margin: 0; color: white; font-size: 15px; font-weight: 700; letter-spacing: -0.3px;">
                                          Mention Friends</h3>
                                        <p style="margin: 0; color: rgba(255,255,255,0.8); font-size: 11px;">Tag friends
                                          to notify them</p>
                                      </div>
                                    </div>
                                    <div class="hashtag-popover-body" style="padding: 12px;">
                                      <div style="position: relative; margin-bottom: 8px;">
                                        <input type="text" id="mentionSearchInput"
                                          placeholder="<%= tText("Search user to mention...") %>"
                                          style="width: 100%; padding: 8px 10px 8px 30px; border-radius: 8px; border: 1px solid var(--border-color); background: var(--bg-hover); color: var(--text-primary); font-size: 13px; outline: none;">
                                        <i data-lucide="search"
                                          style="position: absolute; left: 10px; top: 50%; transform: translateY(-50%); color: var(--text-secondary); width: 14px; height: 14px;"></i>
                                      </div>
                                      <div class="mention-list-container" id="mentionListContainer"
                                        style="max-height: 180px; overflow-y: auto; display: flex; flex-direction: column; gap: 4px;">
                                        <div
                                          style="text-align: center; padding: 12px; color: var(--text-secondary); font-size: 12px;">
                                          Start typing a username...</div>
                                      </div>
                                    </div>
                                  </div>

                                  <!-- Text Style Popover (Premium Design) -->
                                  <div class="hashtag-popover" id="textStyleModal">
                                    <div class="hashtag-popover-arrow"></div>
                                    <!-- Premium Gradient Header (Pink to Purple) -->
                                    <div
                                      style="background: linear-gradient(135deg, #ec4899 0%, #8b5cf6 100%); padding: 18px 16px 14px 16px; position: relative; border-radius: 16px 16px 0 0; text-align: center; z-index: 2;">
                                      <button id="closeTextStyleModal"
                                        style="position: absolute; right: 12px; top: 12px; color: rgba(255,255,255,0.8); background: rgba(0,0,0,0.15); border: none; cursor: pointer; border-radius: 50%; width: 22px; height: 22px; display: flex; align-items: center; justify-content: center; transition: all 0.2s;"><i
                                          data-lucide="x" style="width: 12px; height: 12px;"></i></button>
                                      <div
                                        style="display: flex; flex-direction: column; align-items: center; gap: 4px;">
                                        <div
                                          style="background: rgba(255,255,255,0.2); width: 32px; height: 32px; border-radius: 8px; display: flex; align-items: center; justify-content: center; backdrop-filter: blur(4px);">
                                          <i data-lucide="type" style="color: white; width: 16px; height: 16px;"></i>
                                        </div>
                                        <h3
                                          style="margin: 0; color: white; font-size: 15px; font-weight: 700; letter-spacing: -0.3px;">
                                          Custom Text Post</h3>
                                        <p style="margin: 0; color: rgba(255,255,255,0.8); font-size: 11px;">Select a
                                          background and customize text. Premium backgrounds can also make your post much more viral.</p>
                                      </div>
                                    </div>
                                    <div class="hashtag-popover-body"
                                      style="padding: 16px; display: flex; flex-direction: column; gap: 14px;">

                                      <!-- Background Grid Selector -->
                                      <div>
                                        <div
                                          style="font-size: 11px; font-weight: 600; text-transform: uppercase; color: var(--text-secondary); margin-bottom: 8px; letter-spacing: 0.5px;">
                                          1. Select Background</div>
                                        <div id="bgGridContainer"
                                          style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; max-height: 120px; overflow-y: auto;">
                                          <!-- Default None (Plain) option -->
                                          <div class="bg-select-option active" data-bg-none="true"
                                            style="aspect-ratio: 1; border-radius: 8px; border: 2px solid var(--primary); display: flex; align-items: center; justify-content: center; cursor: pointer; background: var(--bg-hover);">
                                            <i data-lucide="slash"
                                              style="width: 16px; height: 16px; color: var(--text-secondary);"></i>
                                          </div>
                                        </div>
                                      </div>

                                      <!-- Customizations (Color, Alignment, Vertical Position, Font) -->
                                      <div>
                                        <div
                                          style="font-size: 11px; font-weight: 600; text-transform: uppercase; color: var(--text-secondary); margin-bottom: 8px; letter-spacing: 0.5px;">
                                          2. Text Styling</div>
                                        <div
                                          style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; margin-bottom: 8px;">
                                          <!-- Text Color picker -->
                                          <div style="display: flex; flex-direction: column; gap: 4px;">
                                            <label style="font-size: 10px; color: var(--text-secondary);">Color</label>
                                            <input type="color" id="textColorPicker" value="#ffffff"
                                              style="width: 100%; height: 32px; border-radius: 6px; border: 1px solid var(--border-color); background: transparent; cursor: pointer; padding: 0;">
                                          </div>
                                          <!-- Text Alignment -->
                                          <div style="display: flex; flex-direction: column; gap: 4px;">
                                            <label style="font-size: 10px; color: var(--text-secondary);">Align</label>
                                            <div
                                              style="display: flex; border: 1px solid var(--border-color); border-radius: 6px; overflow: hidden; height: 32px;">
                                              <button type="button" id="alignLeftBtn" class="text-format-btn"
                                                style="flex: 1; background: transparent; border: none; cursor: pointer; display: flex; align-items: center; justify-content: center; color: var(--text-secondary);"><i
                                                  data-lucide="align-left" style="width:14px;"></i></button>
                                              <button type="button" id="alignCenterBtn" class="text-format-btn active"
                                                style="flex: 1; background: var(--bg-hover); border: none; cursor: pointer; display: flex; align-items: center; justify-content: center; color: var(--primary);"><i
                                                  data-lucide="align-center" style="width:14px;"></i></button>
                                              <button type="button" id="alignRightBtn" class="text-format-btn"
                                                style="flex: 1; background: transparent; border: none; cursor: pointer; display: flex; align-items: center; justify-content: center; color: var(--text-secondary);"><i
                                                  data-lucide="align-right" style="width:14px;"></i></button>
                                              <button type="button" id="alignJustifyBtn" class="text-format-btn"
                                                style="flex: 1; background: transparent; border: none; cursor: pointer; display: flex; align-items: center; justify-content: center; color: var(--text-secondary);"><i
                                                  data-lucide="align-justify" style="width:14px;"></i></button>
                                            </div>
                                          </div>
                                          <!-- Vertical position -->
                                          <div style="display: flex; flex-direction: column; gap: 4px;">
                                            <label
                                              style="font-size: 10px; color: var(--text-secondary);">Position</label>
                                            <div
                                              style="display: flex; border: 1px solid var(--border-color); border-radius: 6px; overflow: hidden; height: 32px;">
                                              <button type="button" id="posTopBtn" class="text-format-btn"
                                                style="flex: 1; background: transparent; border: none; cursor: pointer; display: flex; align-items: center; justify-content: center; color: var(--text-secondary);"><i
                                                  data-lucide="align-vertical-justify-start"
                                                  style="width:14px;"></i></button>
                                              <button type="button" id="posCenterBtn" class="text-format-btn active"
                                                style="flex: 1; background: var(--bg-hover); border: none; cursor: pointer; display: flex; align-items: center; justify-content: center; color: var(--primary);"><i
                                                  data-lucide="align-vertical-justify-center"
                                                  style="width:14px;"></i></button>
                                              <button type="button" id="posBottomBtn" class="text-format-btn"
                                                style="flex: 1; background: transparent; border: none; cursor: pointer; display: flex; align-items: center; justify-content: center; color: var(--text-secondary);"><i
                                                  data-lucide="align-vertical-justify-end"
                                                  style="width:14px;"></i></button>
                                            </div>
                                          </div>
                                        </div>

                                        <!-- Font & Size selection -->
                                        <div
                                          style="display: grid; grid-template-columns: 2fr 1fr; gap: 8px; margin-top: 8px;">
                                          <div style="display: flex; flex-direction: column; gap: 4px;">
                                            <label style="font-size: 10px; color: var(--text-secondary);">Font
                                              Family</label>
                                            <select id="textFontSelect"
                                              style="width: 100%; height: 34px; border-radius: 6px; border: 1px solid var(--border-color); background: var(--bg-hover); color: var(--text-primary); font-size: 12px; outline: none; padding: 0 8px; cursor: pointer;">
                                              <option value="<%= tText("'Outfit', sans-serif") %>"><%= tText("Outfit (Modern)") %></option>
                                              <option value="<%= tText("'Inter', sans-serif") %>"><%= tText("Inter (Clean)") %></option>
                                              <option value="<%= tText("'Georgia', serif") %>"><%= tText("Georgia (Classic Serif)") %></option>
                                              <option value="<%= tText("'Courier New', monospace") %>"><%= tText("Courier New (Monospace)") %></option>
                                              <option value="<%= tText("'Playfair Display', serif") %>"><%= tText("Playfair Display (Elegant)") %>
                                              </option>
                                            </select>
                                          </div>
                                          <div style="display: flex; flex-direction: column; gap: 4px;">
                                            <label style="font-size: 10px; color: var(--text-secondary);">Size</label>
                                            <select id="textSizeSelect"
                                              style="width: 100%; height: 34px; border-radius: 6px; border: 1px solid var(--border-color); background: var(--bg-hover); color: var(--text-primary); font-size: 12px; outline: none; padding: 0 8px; cursor: pointer;">
                                              <option value="16px">S</option>
                                              <option value="20px" selected>M</option>
                                              <option value="24px">L</option>
                                              <option value="28px">XL</option>
                                              <option value="36px">XXL</option>
                                            </select>
                                          </div>
                                        </div>
                                      </div>

                                      <!-- Cancel/Reset -->
                                      <button type="button" id="resetTextStyleBtn" class="btn"
                                        style="background: transparent; border: 1px solid var(--border-color); color: var(--text-secondary); font-size: 12px; padding: 6px 12px; display: none; align-items: center; justify-content: center; gap: 6px; cursor: pointer;">
                                        <i data-lucide="rotate-ccw" style="width:12px;"></i> Reset Style
                                      </button>
                                    </div>
                                  </div>
                                </div>
                                <% } %>

                                  <!-- Bookmarks Header -->
                                  <div id="bookmarksHeader" class="bookmarks-header" style="display: <%= currentView === 'bookmarks' ? 'flex' : 'none' %>;">
                                    <div class="bookmarks-header-content">
                                      <h2>
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="header-bookmark-icon"><path d="m19 21-7-4-7 4V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16z"/></svg>
                                        <%= tText("Favoris") %>
                                      </h2>
                                      <p class="bookmarks-header-subtitle"><%= tText("Vos publications enregistrées") %></p>
                                    </div>
                                    <div class="bookmarks-count-badge" id="bookmarksCountBadge">
                                      <%= bookmarkedPostsCount %> <%= bookmarkedPostsCount > 1 ? tText("favoris") : tText("favori") %>
                                    </div>
                                  </div>

                                  <!-- Bookmarks Empty State -->
                                  <div id="bookmarksEmptyState" class="bookmarks-empty-state" style="display: <%= (currentView === 'bookmarks' && bookmarkedPostsCount === 0) ? 'flex' : 'none' %>; flex-direction: column !important; align-items: center !important;">
                                    <div class="empty-illustration-container">
                                      <svg class="floating-bookmark-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 120 120" width="100" height="100">
                                        <!-- Outer glow circle -->
                                        <circle cx="60" cy="60" r="50" fill="url(#glowGradient)" opacity="0.15" />
                                        <!-- Soft dashed inner path -->
                                        <circle cx="60" cy="60" r="42" fill="none" stroke="var(--primary)" stroke-width="1.5" stroke-dasharray="4 4" opacity="0.3" />
                                        <!-- Main bookmark ribbon shadow -->
                                        <path d="M45,25 L75,25 C79,25 82,28 82,32 L82,95 L60,80 L38,95 L38,32 C38,28 41,25 45,25 Z" fill="rgba(124, 58, 237, 0.1)" transform="translate(2, 4)" />
                                        <!-- Main bookmark ribbon -->
                                        <path d="M45,25 L75,25 C79,25 82,28 82,32 L82,95 L60,80 L38,95 L38,32 C38,28 41,25 45,25 Z" fill="url(#bookmarkGradient)" stroke="url(#borderGradient)" stroke-width="1" />
                                        <!-- Decorative inner lines -->
                                        <path d="M48,40 L72,40 M48,50 L72,50 M48,60 L62,60" stroke="rgba(255, 255, 255, 0.25)" stroke-width="2" stroke-linecap="round" />
                                        <!-- Glowing sparkles/stars -->
                                        <path d="M25,35 L27,38 L30,35 L27,32 Z M92,45 L94,48 L97,45 L94,42 Z M58,105 L60,108 L63,105 L60,102 Z" fill="var(--primary)" />
                                        
                                        <!-- Gradients definitions -->
                                        <defs>
                                          <radialGradient id="glowGradient" cx="50%" cy="50%" r="50%">
                                            <stop offset="0%" stop-color="var(--primary)" />
                                            <stop offset="100%" stop-color="var(--primary)" stop-opacity="0" />
                                          </radialGradient>
                                          <linearGradient id="bookmarkGradient" x1="0%" y1="0%" x2="100%" y2="100%">
                                            <stop offset="0%" stop-color="#8b5cf6" />
                                            <stop offset="100%" stop-color="#3b82f6" />
                                          </linearGradient>
                                          <linearGradient id="borderGradient" x1="0%" y1="0%" x2="0%" y2="100%">
                                            <stop offset="0%" stop-color="rgba(255, 255, 255, 0.4)" />
                                            <stop offset="100%" stop-color="rgba(0, 0, 0, 0.2)" />
                                          </linearGradient>
                                        </defs>
                                      </svg>
                                    </div>
                                    <h3><%= tText("Aucun favori pour le moment") %></h3>
                                    <p><%= tText("Enregistrez des publications en cliquant sur l'icône de signet pour les retrouver ici.") %></p>
                                    <button class="btn-explore-posts" onclick="showFeedView()">
                                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-compass"><circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/></svg>
                                      <%= tText("Découvrir des publications") %>
                                    </button>
                                  </div>

                                  <!-- Skeleton Feed (shown while content loads) -->
                                  <div id="skeletonFeed" aria-hidden="true" style="<%= currentView !== 'feed' ? 'display: none;' : '' %>">
                                    <% for(let _sk = 0; _sk < 4; _sk++) { %>
                                    <div class="skeleton-post-card">
                                      <div class="skeleton-header">
                                        <div class="skeleton-avatar skeleton-base"></div>
                                        <div class="skeleton-meta">
                                          <div class="skeleton-name skeleton-base"></div>
                                          <div class="skeleton-date skeleton-base"></div>
                                        </div>
                                      </div>
                                      <% if(_sk % 2 === 0) { %>
                                      <div class="skeleton-media skeleton-base"></div>
                                      <% } %>
                                      <div style="display:flex;flex-direction:column;gap:9px;">
                                        <div class="skeleton-text-line w-full skeleton-base"></div>
                                        <div class="skeleton-text-line w-90 skeleton-base"></div>
                                        <div class="skeleton-text-line w-75 skeleton-base"></div>
                                        <% if(_sk % 3 !== 1) { %>
                                        <div class="skeleton-text-line w-55 skeleton-base"></div>
                                        <% } %>
                                      </div>
                                      <div class="skeleton-actions">
                                        <div class="skeleton-action-btn skeleton-base"></div>
                                        <div class="skeleton-action-btn skeleton-base"></div>
                                        <div class="skeleton-action-btn skeleton-base"></div>
                                      </div>
                                    </div>
                                    <% } %>
                                  </div>

                                  <!-- Feed Posts Container -->
                                  <div id="postsContainer" style="display: flex; flex-direction: column; gap: 24px;">
                                    <%
                                      const feedDateValue = (value) => {
                                        const time = new Date(value || 0).getTime();
                                        return Number.isFinite(time) ? time : 0;
                                      };
                                      const escapeFeedHtml = (value) => String(value ?? '').replace(/[&<>"']/g, (char) => ({
                                        '&': '&amp;',
                                        '<': '&lt;',
                                        '>': '&gt;',
                                        '"': '&quot;',
                                        "'": '&#39;'
                                      }[char]));
                                      const feedDisplayUrl = (url) => String(url || '').replace(/^(https?:\/\/)?(www\.)?/, '').split('/')[0];
                                          const renderSponsoredFeedAd = (ad) => {
                                          const adDisplayUrl = feedDisplayUrl(ad.ad_url);
                                          const adCreatedAt = ad.created_at ? (ad.created_at instanceof Date ?
                                          ad.created_at.toISOString() : String(ad.created_at)) : '';
                                          return `
                                          <article class="post-card sponsored-ad-card" data-feed-item-type="ad"
                                            data-ad-id="${escapeFeedHtml(ad.id)}"
                                            data-created-at="${escapeFeedHtml(adCreatedAt)}">
                                            <a class="sponsored-ad-link" href="${escapeFeedHtml(ad.ad_url)}"
                                              target="_blank" rel="noopener noreferrer">
                                              <header class="sponsored-ad-header">
                                                <div class="sponsored-ad-brand">
                                                  <div class="sponsored-ad-meta">
                                                    <span class="sponsored-ad-subtitle">Sponsorisé ·
                                                      ${escapeFeedHtml(adDisplayUrl)}</span>
                                                  </div>
                                                </div>
                                                <span class="sponsored-ad-label"><i data-lucide="badge-ad"></i>
                                                  Annonce</span>
                                              </header>
                                              <div class="sponsored-ad-copy">
                                                <h4>${escapeFeedHtml(ad.title)}</h4>
                                                <p>${escapeFeedHtml(ad.description)}</p>
                                              </div>
                                              <div class="sponsored-ad-media">
                                                <img src="${escapeFeedHtml(ad.image_url)}"
                                                  alt="${escapeFeedHtml(ad.title)}">
                                              </div>
                                              <footer class="sponsored-ad-footer">
                                                <span class="sponsored-ad-domain">${escapeFeedHtml(adDisplayUrl)}</span>
                                                <span class="sponsored-ad-cta">Ouvrir <i
                                                    data-lucide="arrow-up-right"></i></span>
                                              </footer>
                                            </a>
                                          </article>
                                          `;
                                          };
                                          const feedAds = (typeof activeAds !== 'undefined')
                                          ? activeAds
                                          .filter(ad => ad.show_in_feed === 1 || ad.show_in_feed === true)
                                          .sort((a, b) => feedDateValue(b.created_at) - feedDateValue(a.created_at))
                                          : [];
                                          const birthdayCards = Array.isArray(typeof birthdayCelebrants !== 'undefined' ? birthdayCelebrants : [])
                                            ? (typeof birthdayCelebrants !== 'undefined' ? birthdayCelebrants : [])
                                            : [];
                                          const progressiveFeedInitialBatchSize = Number(typeof initialFeedBatchSize !== 'undefined' ? initialFeedBatchSize : 10);
                                          const progressiveShortInitialBatchSize = Number(typeof initialShortBatchSize !== 'undefined' ? initialShortBatchSize : 4);
                                          const sortedPosts = Array.isArray(posts) ? posts : [];
                                          let feedAdCursor = 0;
                                          %>

                                          <% birthdayCards.forEach((celebrant) => { %>
                                            <article class="post-card birthday-feed-card" data-feed-item-type="birthday" data-birthday-user-id="<%= celebrant.id %>" data-birthday-preview="<%= celebrant.is_preview ? '1' : '0' %>">
                                              <div class="birthday-feed-card-shell">
                                                <div class="birthday-feed-confetti birthday-feed-confetti-left" aria-hidden="true"></div>
                                                <div class="birthday-feed-confetti birthday-feed-confetti-right" aria-hidden="true"></div>
                                                <div class="birthday-feed-card-hero">
                                                  <a href="/profile/u/<%= encodeURIComponent(celebrant.username || '') %>" class="birthday-feed-card-photo">
                                                    <img src="<%= celebrant.avatar || '/assets/avatar_placeholder.jpg' %>" alt="<%= celebrant.name %>">
                                                  </a>
                                                </div>
                                                <div class="birthday-feed-card-copy">
                                                  <span class="birthday-feed-card-kicker"><i data-lucide="cake"></i> <%= celebrant.birthday_label || 'Anniversaire du jour' %></span>
                                                  <div class="birthday-feed-title-block">
                                                    <h3 class="birthday-feed-title">Happy</h3>
                                                    <div class="birthday-feed-script">Birthday</div>
                                                  </div>
                                                  <a href="/profile/u/<%= encodeURIComponent(celebrant.username || '') %>" class="birthday-feed-card-name">
                                                    <%= celebrant.name %>
                                                    <% if ((celebrant.certification_type || 'None') !== 'None') { %>
                                                      <span class="verified-badge-small" title="<%= celebrant.certification_type %>" data-type="<%= celebrant.certification_type %>" style="display: inline-flex; margin-left: 6px;">
                                                        <i data-lucide="badge-check"></i>
                                                      </span>
                                                    <% } %>
                                                  </a>
                                                  <div class="birthday-feed-card-meta">
                                                    <span>@<%= celebrant.username %></span>
                                                    <% if (celebrant.country) { %><span><%= celebrant.country %></span><% } %>
                                                  </div>
                                                  <p class="birthday-feed-card-text">
                                                    <%= celebrant.is_preview
                                                      ? (celebrant.preview_message || `${celebrant.first_name || celebrant.name} fêtera bientôt son anniversaire.`)
                                                      : (celebrant.is_self ? 'Aujourd’hui, c’est votre anniversaire.' : `Aujourd’hui, ${celebrant.first_name || celebrant.name} fête son anniversaire.`) %>
                                                  </p>
                                                  <p class="birthday-feed-blessing"><%= tText("QUE DIEU VOUS BENISSE !") %></p>
                                                  <div class="birthday-feed-card-actions">
                                                    <% if (!celebrant.is_self && !celebrant.is_preview) { %>
                                                      <button type="button" class="birthday-gift-btn" data-birthday-user-id="<%= celebrant.id %>">
                                                        <i data-lucide="gift"></i>
                                                        <span><%= tText("Envoyer un cadeau") %></span>
                                                      </button>
                                                    <% } else if (celebrant.is_preview) { %>
                                                      <button type="button" class="birthday-gift-btn birthday-gift-btn-demo" data-birthday-user-id="<%= celebrant.id %>">
                                                        <i data-lucide="gift"></i>
                                                        <span><%= tText("Bouton cadeau") %></span>
                                                      </button>
                                                    <% } else { %>
                                                      <span class="birthday-feed-self-pill"><%= tText("Profitez de votre journée") %></span>
                                                    <% } %>
                                                  </div>
                                                </div>
                                              </div>
                                            </article>
                                          <% }) %>

                                                <%
                                                  const activeMatches = (typeof liveGames !== 'undefined' && Array.isArray(liveGames)) ? liveGames : [];
                                                  activeMatches.forEach((game) => {
                                                    const gameNamesMap = {
                                                      domino: 'Domino',
                                                      connect4: 'Puissance 4',
                                                      gomoku: 'Gomoku',
                                                      tablefootball: 'Football Table'
                                                    };
                                                    const gameName = gameNamesMap[game.gameType] || 'Jeu';
                                                %>
                                                <article class="post-card active-match-card" data-feed-item-type="match" data-game-id="<%= game.id %>" data-started-at="<%= game.startedAt %>">
                                                  <div class="match-card-header" style="display: flex; justify-content: space-between; align-items: center; padding: 16px 20px 8px 20px;">
                                                    <div style="display: flex; align-items: center; gap: 8px;">
                                                      <span class="match-live-pulse-ring" style="display: inline-flex; align-items: center; justify-content: center; width: 8px; height: 8px; border-radius: 50%; background-color: #ef4444; box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.7); animation: matchPulse 1.5s infinite;"></span>
                                                      <span style="font-size: 11px; font-weight: 700; color: #ef4444; text-transform: uppercase; letter-spacing: 0.5px;"><%= tText("Match en direct") %></span>
                                                    </div>
                                                    <div class="match-game-badge" style="display: inline-flex; align-items: center; gap: 4px; padding: 4px 8px; border-radius: 6px; background-color: var(--bg-input); border: 1px solid var(--border-color); font-size: 11px; font-weight: 700; color: var(--text-primary);">
                                                      <i data-lucide="gamepad-2" style="width: 13px; height: 13px; color: var(--primary);"></i>
                                                      <span><%= gameName %></span>
                                                    </div>
                                                  </div>

                                                  <div class="match-vs-container" style="display: flex; align-items: center; justify-content: space-between; padding: 16px 24px; gap: 12px;">
                                                    <!-- Player 1 -->
                                                    <div class="match-player-profile" style="flex: 1; display: flex; flex-direction: column; align-items: center; text-align: center; min-width: 0;">
                                                      <div style="position: relative; width: 62px; height: 62px; margin-bottom: 8px;">
                                                        <img src="<%= game.player1.avatar %>" alt="<%= game.player1.name %>" style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover; border: 2px solid var(--primary); box-shadow: var(--shadow-sm);" onerror="this.onerror=null;this.src='/assets/avatar_placeholder.jpg';">
                                                      </div>
                                                      <span style="font-size: 13px; font-weight: 700; color: var(--text-primary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; width: 100%;"><%= game.player1.name %></span>
                                                      <span style="font-size: 11.5px; color: var(--text-secondary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; width: 100%;">@<%= game.player1.username %></span>
                                                    </div>

                                                    <!-- VS Separation & Live Timer -->
                                                    <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 6px; flex-shrink: 0; min-width: 60px;">
                                                      <div style="font-family: 'Outfit', sans-serif; font-size: 16px; font-weight: 900; text-transform: uppercase; color: var(--text-muted); background: var(--bg-input); border: 1px solid var(--border-color); border-radius: 50%; width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; box-shadow: var(--shadow-xs);">VS</div>
                                                      <div class="match-elapsed-timer" style="font-size: 12px; font-weight: 700; color: var(--text-primary); font-variant-numeric: tabular-nums;" data-started-at="<%= game.startedAt %>">
                                                        --:--
                                                      </div>
                                                    </div>

                                                    <!-- Player 2 -->
                                                    <div class="match-player-profile" style="flex: 1; display: flex; flex-direction: column; align-items: center; text-align: center; min-width: 0;">
                                                      <% if (game.player2) { %>
                                                        <div style="position: relative; width: 62px; height: 62px; margin-bottom: 8px;">
                                                          <img src="<%= game.player2.avatar %>" alt="<%= game.player2.name %>" style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover; border: 2px solid var(--primary); box-shadow: var(--shadow-sm);" onerror="this.onerror=null;this.src='/assets/avatar_placeholder.jpg';">
                                                        </div>
                                                        <span style="font-size: 13px; font-weight: 700; color: var(--text-primary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; width: 100%;"><%= game.player2.name %></span>
                                                        <span style="font-size: 11.5px; color: var(--text-secondary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; width: 100%;">@<%= game.player2.username %></span>
                                                      <% } else { %>
                                                        <div style="position: relative; width: 62px; height: 62px; margin-bottom: 8px;">
                                                          <img src="/assets/avatar_placeholder.jpg" alt="Bot" style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover; border: 2px solid var(--border-color); opacity: 0.6;">
                                                        </div>
                                                        <span style="font-size: 13px; font-weight: 700; color: var(--text-muted);"><%= tText("En attente...") %></span>
                                                        <span style="font-size: 11.5px; color: var(--text-muted);">--</span>
                                                      <% } %>
                                                    </div>
                                                  </div>

                                                  <div style="display: flex; align-items: center; justify-content: space-between; padding: 12px 20px; border-top: 1px solid var(--border-color); background: var(--bg-hover); gap: 12px;">
                                                    <!-- Live Mode Info -->
                                                    <div style="display: flex; align-items: center; gap: 6px;">
                                                      <% if (game.liveMode === 'paid') { %>
                                                        <span class="live-paywall-badge-paid" style="display: inline-flex; align-items: center; gap: 4px; padding: 4px 8px; border-radius: 6px; background-color: rgba(245, 158, 11, 0.1); border: 1px solid rgba(245, 158, 11, 0.2); font-size: 10.5px; font-weight: 800; color: #d97706;">
                                                          <i data-lucide="ticket" style="width: 13px; height: 13px;"></i>
                                                          <span><%= tText("Payant") %> (<%= parseFloat(game.livePrice || 0.50).toFixed(2) %> $)</span>
                                                        </span>
                                                      <% } else { %>
                                                        <span class="live-paywall-badge-free" style="display: inline-flex; align-items: center; gap: 4px; padding: 4px 8px; border-radius: 6px; background-color: rgba(16, 185, 129, 0.1); border: 1px solid rgba(16, 185, 129, 0.2); font-size: 10.5px; font-weight: 800; color: #059669;">
                                                          <i data-lucide="sparkles" style="width: 13px; height: 13px;"></i>
                                                          <span><%= tText("Gratuit") %></span>
                                                        </span>
                                                      <% } %>
                                                    </div>

                                                    <!-- Action button -->
                                                    <button class="spectate-game-action-btn settings-primary-btn" 
                                                            data-game-id="<%= game.id %>"
                                                            data-live-mode="<%= game.liveMode %>"
                                                            data-live-price="<%= game.livePrice %>"
                                                            style="height: 32px; font-size: 12px; padding: 0 16px; border-radius: 8px; font-weight: 700; background: linear-gradient(135deg, var(--primary) 0%, #4f46e5 100%); color: white; border: none; cursor: pointer; display: inline-flex; align-items: center; gap: 6px; box-shadow: var(--shadow-sm); transition: transform 0.15s ease;">
                                                      <i data-lucide="eye" style="width: 14px; height: 14px;"></i>
                                                      <span><%= tText("Regarder le live") %></span>
                                                    </button>
                                                  </div>
                                                </article>
                                                <%
                                                  });
                                                %>

                                                <% sortedPosts.forEach((post, postIndex)=> { %>
                                            <% while (feedAdCursor < feedAds.length &&
                                              feedDateValue(feedAds[feedAdCursor].created_at)>=
                                              feedDateValue(post.created_at)) { %>
                                              <%- renderSponsoredFeedAd(feedAds[feedAdCursor++]) %>
                                                 <% } %>
                                                   <article class="<%= postIndex >= progressiveFeedInitialBatchSize ? 'post-card progressive-hidden' : 'post-card' %>" id="post-<%= post.id %>"
                                                    data-feed-item-type="post" data-post-id="<%= post.id %>"
                                                    data-progressive-item="post"
                                                    data-progressive-index="<%= postIndex %>"
                                                    data-created-at="<%= post.created_at ? (post.created_at instanceof Date ? post.created_at.toISOString() : String(post.created_at)) : '' %>"
                                                    data-post-user-id="<%= post.user_id %>"
                                                    data-challenge-type="<%= post.challenge_type || '' %>"
                                                    style="<%= currentView === 'bookmarks' && !post.is_bookmarked ? 'display: none;' : '' %>">
                                                    <header class="post-header">
                                                      <div class="post-author-info">
                                                        <a href="/profile/u/<%= post.author_username %>"
                                                          class="post-author-link"
                                                          style="display: flex; align-items: center; gap: 12px; color: inherit; text-decoration: none;">
                                                          <div class="avatar author-avatar">
                                                            <img src="<%= post.author_avatar %>"
                                                              alt="<%= post.author_name %>">
                                                          </div>
                                                          <div class="author-details">
                                                            <h3 class="author-name">
                                                              <%= post.author_name %>
                                                              <% if ((post.author_certification_type || 'None') !== 'None') { %>
                                                                <span class="verified-badge-small" title="<%= post.author_certification_type %>" data-type="<%= post.author_certification_type %>" style="display: inline-flex; margin-left: 6px;">
                                                                  <i data-lucide="badge-check"></i>
                                                                </span>
                                                              <% } %>
                                                            </h3>
                                                            <span class="post-time">
                                                              <% let timeDiff=Date.now() - new
                                                                Date(post.created_at).getTime(); let
                                                                minutes=Math.floor(timeDiff / (1000 * 60)); let
                                                                hours=Math.floor(minutes / 60); let
                                                                days=Math.floor(hours / 24); let timeStr="" ; if (days>
                                                                0) timeStr = days + "d ago";
                                                                else if (hours > 0) timeStr = hours + "h ago";
                                                                else if (minutes > 0) timeStr = minutes + "m ago";
                                                                else timeStr = "Just now";
                                                                %>
                                                                <%= timeStr %>
                                                            </span>
                                                          </div>
                                                        </a>
                                                        <% if (post.user_id !==currentUser.id) { %>
                                                          <button type="button" class="follow-toggle-btn"
                                                            data-follow-target-id="<%= post.user_id %>"
                                                            data-following="<%= post.is_author_following ? '1' : '0' %>"
                                                            title="<%= post.is_author_following ? 'Ne plus suivre' : 'Suivre' %>"
                                                            aria-label="<%= post.is_author_following ? 'Ne plus suivre' : 'Suivre' %>">
                                                            <i data-lucide="<%= post.is_author_following ? 'user-check' : 'user-plus' %>"
                                                              style="width: 14px; height: 14px;"></i>
                                                          </button>
                                                          <% } %>
                                                      </div>
                                                      <button type="button" class="post-options-btn" aria-label="<%= tText("Post settings") %>">
                                                        <i data-lucide="more-horizontal"></i>
                                                      </button>
                                                    </header>

                                                    <div class="post-content">
                                                      <% if (post.bg_image_url) { %>
                                                        <!-- Custom Image Background post style -->
                                                        <% const alignMap={ 'left' : 'flex-start' , 'right' : 'flex-end'
                                                          , 'center' : 'center', 'justify': 'stretch' }; const posMap={ 'top' : 'flex-start'
                                                          , 'center' : 'center' , 'bottom' : 'flex-end' }; const
                                                          alignVal=alignMap[post.text_alignment] || 'center' ; const
                                                          posVal=posMap[post.text_position] || 'center' ; %>
                                                          <div class="post-bg-container"
                                                            style="background-image: url('<%= post.bg_image_url %>'); color: <%= post.text_color || '#ffffff' %>; text-align: <%= post.text_alignment || 'center' %>; font-family: <%= post.text_font || '\'Outfit\', sans-serif' %>; align-items: <%= alignVal %>; justify-content: <%= posVal %>; font-size: <%= post.text_size || '20px' %>; --bg-text-size: <%= post.text_size || '20px' %>;">
                                                            <p class="formatted-hashtag-text"
                                                              style="width: 100%; text-align: <%= post.text_alignment === 'justify' ? 'justify' : 'inherit' %>; margin: 0; padding: 0; white-space: pre-wrap;">
                                                              <%= post.content %>
                                                            </p>
                                                          </div>
                                                          <% if (post.challenge_type) { %>
                                                            <div class="challenge-post-card" data-challenge-post-id="<%= post.id %>"
                                                              data-challenge-type="<%= post.challenge_type || '' %>"
                                                              data-challenge-vote-mode="<%= post.challenge_vote_mode || 'free' %>"
