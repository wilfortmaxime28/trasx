                        <span class="live-blink-dot"></span>
                        <i data-lucide="eye"></i>
                        <span id="spectatorCountText"><%= tText("0 Spectateur") %></span>
                      </button>
                      
                      <!-- Forfeit Button -->
                      <button id="forfeitGameBtn" class="forfeit-game-btn">
