<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>TrasX - Secure Admin Panel</title>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #0f172a;
      --card-bg: #1e293b;
      --text-main: #f8fafc;
      --text-muted: #94a3b8;
      --primary: #3b82f6;
      --primary-hover: #2563eb;
      --border: #334155;
      --error: #ef4444;
      --error-bg: rgba(239, 68, 68, 0.1);
    }
    body {
      margin: 0;
      padding: 0;
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
      background: var(--bg);
      font-family: 'Inter', sans-serif;
      color: var(--text-main);
    }
    .admin-login-wrapper {
      width: 100%;
      max-width: 420px;
      padding: 40px;
      background: var(--card-bg);
      border-radius: 16px;
      box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
      border: 1px solid var(--border);
    }
    .header {
      text-align: center;
      margin-bottom: 30px;
    }
    .header h1 {
      font-family: 'Outfit', sans-serif;
      font-size: 32px;
      font-weight: 700;
      margin: 0 0 8px;
      letter-spacing: -0.5px;
      background: linear-gradient(135deg, #60a5fa, #3b82f6);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    .header p {
      color: var(--text-muted);
      font-size: 14px;
      margin: 0;
    }
    .form-group {
      margin-bottom: 20px;
    }
    .form-group label {
      display: block;
      margin-bottom: 8px;
      font-size: 13px;
      font-weight: 600;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .form-group input {
      width: 100%;
      padding: 14px 16px;
      background: rgba(15, 23, 42, 0.5);
      border: 1px solid var(--border);
      border-radius: 10px;
      color: var(--text-main);
      font-size: 15px;
      box-sizing: border-box;
      transition: all 0.2s ease;
    }
    .form-group input:focus {
      outline: none;
      border-color: var(--primary);
      box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.2);
    }
    .btn-submit {
      width: 100%;
      padding: 14px;
      background: var(--primary);
      color: white;
      border: none;
      border-radius: 10px;
      font-size: 16px;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.2s;
      margin-top: 10px;
    }
    .btn-submit:hover {
      background: var(--primary-hover);
    }
    .error-msg {
      background: var(--error-bg);
      color: var(--error);
      padding: 12px;
      border-radius: 8px;
      font-size: 14px;
      margin-bottom: 20px;
      border: 1px solid rgba(239, 68, 68, 0.2);
      text-align: center;
    }
  </style>
</head>
<body>
  <div class="admin-login-wrapper">
    <div class="header">
      <h1>TrasX Backoffice</h1>
      <p>Restricted access for system administrators</p>
    </div>

    <% if (error) { %>
      <div class="error-msg"><%= error %></div>
    <% } %>
    <% if (typeof success !== 'undefined' && success) { %>
      <div style="background: rgba(16, 185, 129, 0.1); color: #10b981; padding: 12px; border-radius: 8px; font-size: 14px; margin-bottom: 20px; border: 1px solid rgba(16, 185, 129, 0.2); text-align: center;">
        <%= success %>
      </div>
    <% } %>

    <form action="/backoffice-sec-9x2k" method="POST">
      <div class="form-group">
        <label>Email Administrateur</label>
        <input type="email" name="email" required placeholder="admin@example.com" autocomplete="off">
      </div>
      <% if (typeof isSmtpConfigured !== 'undefined' && !isSmtpConfigured) { %>
        <div class="form-group">
          <label>Mot de passe</label>
          <input type="password" name="password" required placeholder="••••••••" autocomplete="current-password">
        </div>
        <button type="submit" class="btn-submit">Se connecter</button>
      <% } else { %>
        <button type="submit" class="btn-submit">Demander un lien d'accès</button>
      <% } %>
    </form>
  </div>
</body>
</html>
