                <%= profileUser.bio || 'No bio yet.' %>
              </div>

              <div style="display: flex; justify-content: center; gap: 10px; margin-top: 16px; padding: 0 16px;">
                <% if (profileUser.id !==currentUser.id) { %>
                  <button type="button" class="follow-toggle-btn" data-follow-target-id="<%= profileUser.id %>"
                    data-following="<%= viewerFollowsProfile ? '1' : '0' %>"
                    title="<%= viewerFollowsProfile ? 'Unfollow' : 'Follow' %>"
