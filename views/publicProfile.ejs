                    data-profile-message-presence="<%= profilePresenceText || 'Offline' %>"
                    data-profile-message-username="<%= profileUser.username %>"
                    style="width: auto; padding: 0 18px; margin: 0; height: 40px; display: inline-flex; align-items: center; justify-content: center; gap: 8px;">
                    <i data-lucide="message-circle" style="width: 15px; height: 15px;"></i>
                    Message
                  </button>
                  <button type="button" class="profile-follow-btn"
                    style="width: auto; padding: 0 18px; margin: 0; height: 40px;"
                    onclick="document.getElementById('profilePostsSection').scrollIntoView({behavior:'smooth', block:'start'})">
                    View posts
