                                    <span class="verified-badge-small" title="<%= person.certification_type %>" data-type="<%= person.certification_type %>" style="display: inline-flex; margin-left: 4px;">
                                      <i data-lucide="badge-check"></i>
                                    </span>
                                  <% } %>
                                </div>
                                <div class="social-user-handle">@<%= String(person.username || 'unknown').trim().replace(/^@+/, '') %>
                                </div>
                              </div>
                            </a>
                            <span class="social-user-pill"
                              data-tone="<%= person.is_mutual ? 'success' : (person.is_following ? 'muted' : 'primary') %>">
                              <%= person.is_mutual ? 'Friends' : (person.is_following ? 'Following' : 'Follow back' ) %>
                            </span>
                          </div>
                          <% }) %>
                            <% } else { %>
                              <div style="color: var(--text-muted); font-size: 13px; padding: 4px 0;">No followers yet.
                              </div>
                              <% } %>
                    </div>
                  </section>

                  <section id="followingSection"
                    style="background: var(--bg-card); border: 1px solid var(--border-color); border-radius: 12px; padding: 14px; min-width: 0; display: none;">
                    <div
                      style="display: flex; justify-content: space-between; align-items: center; gap: 10px; margin-bottom: 12px;">
                      <div>
                        <h3 style="margin: 0; font-size: 15px; color: var(--text-main);">Following</h3>
                        <div style="font-size: 11px; color: var(--text-muted);">
                          <%= formatNumber(followingCount) %> total
                        </div>
                      </div>
                      <button type="button" class="profile-follow-btn profile-view-all-btn"
                        style="width: auto; margin: 0; padding: 8px 12px; font-size: 12px; height: 34px;"
                        data-open-list-modal="following"><%= tText("View all") %></button>
                    </div>
                    <div style="display: flex; flex-direction: column; gap: 8px; max-height: 240px; overflow: auto;">
                      <% if (followingPreview.length) { %>
                        <% followingPreview.forEach((person)=> { %>
                          <div class="social-user-item">
                            <a href="/profile/u/<%= person.username %>" class="social-user-link">
                              <div class="avatar social-user-avatar">
                                <img src="<%= person.avatar || '/assets/avatar_placeholder.jpg' %>" alt="<%= person.name %>"
                                  style="width:100%; height:100%; object-fit:cover;">
                              </div>
                              <div style="min-width: 0;">
                                <div class="social-user-name">
                                  <%= person.name %>
                                  <% if ((person.certification_type || 'None') !== 'None') { %>
                                    <span class="verified-badge-small" title="<%= person.certification_type %>" data-type="<%= person.certification_type %>" style="display: inline-flex; margin-left: 4px;">
                                      <i data-lucide="badge-check"></i>
                                    </span>
                                  <% } %>
                                </div>
                                <div class="social-user-handle">@<%= String(person.username || 'unknown').trim().replace(/^@+/, '') %>
                                </div>
                              </div>
                            </a>
                            <span class="social-user-pill" data-tone="<%= person.is_mutual ? 'success' : 'muted' %>">
                              <%= person.is_mutual ? 'Friends' : 'Following' %>
                            </span>
                          </div>
                          <% }) %>
                            <% } else { %>
                              <div style="color: var(--text-muted); font-size: 13px; padding: 4px 0;">This user is not
                                following anyone yet.</div>
                              <% } %>
                    </div>
                  </section>
                </div>

                <!-- GRID TABS -->
                <div class="profile-tabs" style="margin-top: 16px;">
                  <div class="profile-tab active" onclick="switchGrid('posts', this)">
                    <i data-lucide="grid" style="width: 18px;"></i> Posts
                  </div>
                  <div class="profile-tab" onclick="switchGrid('shorts', this)">
                    <i data-lucide="play-square" style="width: 18px;"></i> Shorts
                  </div>
                </div>

                <!-- POSTS GRID -->
                <div id="postsGrid" class="profile-grid profile-grid-container active">
                  <% if (userPosts && userPosts.length> 0) { %>
                    <% userPosts.forEach(post=> { %>
                      <div class="grid-item" data-post-id="<%= post.id %>" onclick="window.location.href='/#post-<%= post.id %>'" style="cursor: pointer;">
                        <% if (post.is_live === 1) { 
                             const ytId = getYouTubeId(post.live_url);
                        %>
                          <div style="position: relative; width: 100%; height: 100%;">
                            <img src="https://img.youtube.com/vi/<%= ytId %>/hqdefault.jpg" alt="<%= tText("Live YouTube") %>" style="width: 100%; height: 100%; object-fit: cover;">
                            <span style="position: absolute; top: 8px; left: 8px; background: #ef4444; color: white; font-size: 10px; font-weight: 700; padding: 2px 6px; border-radius: 4px; display: flex; align-items: center; gap: 4px; z-index: 2;">
                              <span style="width: 6px; height: 6px; background: white; border-radius: 50%; display: inline-block;"></span> LIVE
                            </span>
                          </div>
                        <% } else if (post.image_url) { %>
                          <% if (post.media_type === 'video' || post.image_url.endsWith('.mp4') || post.image_url.endsWith('.webm') || post.image_url.endsWith('.mov') || post.image_url.endsWith('.ogg')) { %>
                            <div style="position: relative; width: 100%; height: 100%;">
                              <% if (post.thumbnail_url) { %>
                                <img src="<%= post.thumbnail_url %>" alt="Post Thumbnail" style="width: 100%; height: 100%; object-fit: cover;">
                              <% } else { %>
                                <video src="<%= post.image_url %>" style="width: 100%; height: 100%; object-fit: cover;" muted playsinline preload="metadata"></video>
                              <% } %>
                              <span style="position: absolute; top: 8px; left: 8px; background: rgba(0, 0, 0, 0.6); color: white; font-size: 10px; font-weight: 700; padding: 2px 6px; border-radius: 4px; display: flex; align-items: center; gap: 4px; z-index: 2;">
                                <i data-lucide="play" style="width: 10px; height: 10px; fill: white;"></i> VIDEO
                              </span>
                            </div>
                          <% } else { %>
                            <img src="<%= post.image_url %>" alt="Post">
                          <% } %>
                          <% } else { %>
                            <!-- Text only post -->
                            <div
                              style="padding: 12px; font-size: 12px; color: var(--text-main); background: var(--bg-card); width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; text-align: center; border: 1px solid var(--border-color); box-sizing: border-box;">
                              <%= post.content.substring(0, 60) %>...
                            </div>
                            <% } %>
                              <div class="views" style="display: flex; gap: 8px;">
                                <span style="display: flex; align-items: center; gap: 3px;">
                                  <i data-lucide="eye" style="width: 12px; height: 12px;"></i>
                                  <%= formatNumber(post.views_count || 0) %>
                                </span>
                                <span style="display: flex; align-items: center; gap: 3px;">
                                  <i data-lucide="heart" style="width: 12px; height: 12px;"></i>
                                  <%= formatNumber(post.likes_count) %>
                                </span>
                              </div>
                      </div>
                      <% }) %>
                        <% } else { %>
                          <div
                            style="grid-column: span 3; text-align: center; padding: 40px; color: var(--text-muted);">
                            <%= t('profile.noPostsYet', 'No posts yet.' ) %>
                          </div>
                          <% } %>
                </div>

                <!-- SHORTS GRID -->
                <div id="shortsGrid" class="profile-grid profile-grid-container">
                  <% if (userReels && userReels.length> 0) { %>
                    <% userReels.forEach(reel=> { %>
                      <% let resolvedVideoUrl=reel.video_url; if (resolvedVideoUrl &&
                        resolvedVideoUrl.includes('unsplash.com')) { const
                        videoUrls=[ 'https://commondatastorage.googleapis.com/gtv-videos-bucket/sample/ForBiggerJoyrides.mp4'
                        , 'https://commondatastorage.googleapis.com/gtv-videos-bucket/sample/ForBiggerEscapes.mp4'
                        , 'https://commondatastorage.googleapis.com/gtv-videos-bucket/sample/ForBiggerBlazes.mp4'
                        , 'https://commondatastorage.googleapis.com/gtv-videos-bucket/sample/ForBiggerFun.mp4'
                        , 'https://commondatastorage.googleapis.com/gtv-videos-bucket/sample/ForBiggerMeltdowns.mp4' ];
                        const videoIdx=(reel.id - 1) % videoUrls.length; resolvedVideoUrl=videoUrls[videoIdx>= 0 ?
                        videoIdx : 0];
                        }
                        const reelMediaFit = reel.media_fit === 'contain' ? 'contain' : 'cover';
                        %>
                        <div class="grid-item" data-reel-id="<%= reel.id %>">
                          <% if (!reel.media_type || reel.media_type==='video' ) { %>
                            <video src="<%= resolvedVideoUrl %>" muted loop
                              style="object-fit: <%= reelMediaFit %>;"></video>
                            <% } else if (reel.media_type==='image_audio' ) { %>
                              <img src="<%= resolvedVideoUrl %>"
                                style="width: 100%; height: 100%; object-fit: <%= reelMediaFit %>;">
                              <% } else if (reel.media_type==='voice' ) { %>
                                <div
                                  style="width: 100%; height: 100%; background: linear-gradient(135deg, #4f46e5 0%, #06b6d4 100%); display: flex; align-items: center; justify-content: center; color: white;">
                                  <i data-lucide="mic" style="width: 24px; height: 24px;"></i>
                                </div>
                                <% } else if (reel.media_type==='audio' ) { %>
                                  <div
                                    style="width: 100%; height: 100%; background: linear-gradient(135deg, #1e1b4b 0%, #311042 100%); display: flex; align-items: center; justify-content: center; color: white;">
                                    <i data-lucide="music" style="width: 24px; height: 24px;"></i>
                                  </div>
                                  <% } %>
                                    <div class="views" style="display: flex; gap: 8px;">
                                      <span style="display: flex; align-items: center; gap: 3px;">
                                        <i data-lucide="eye" style="width: 12px; height: 12px;"></i>
                                        <%= formatNumber((reel.likes_count || 0) * 15 + (reel.id % 9) * 4 + 21) %>
                                      </span>
                                      <span style="display: flex; align-items: center; gap: 3px;">
                                        <i data-lucide="heart" style="width: 12px; height: 12px;"></i>
                                        <%= formatNumber(reel.likes_count) %>
                                      </span>
                                    </div>
                        </div>
                        <% }) %>
                          <% } else { %>
                            <div
                              style="grid-column: span 3; text-align: center; padding: 40px; color: var(--text-muted);">
                              <%= t('profile.noReelsYet', 'No reels yet.' ) %>
                            </div>
                            <% } %>
                </div>
            </div>
          </main>

          <%- include('partials/rightSidebar') %>
      </div>
    </div>

    <div class="chat-boxes-container" id="chatBoxesContainer"></div>

    <%- include('partials/mobileNav') %>

      <div id="appToast"
        style="position: fixed; bottom: 84px; left: 50%; transform: translateX(-50%) translateY(100px); background: var(--text-primary); color: var(--bg-card); padding: 12px 24px; border-radius: var(--border-radius-pill); font-size: 13px; font-weight: 600; box-shadow: var(--shadow-lg); z-index: 2000; transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275), opacity 0.3s ease; opacity: 0; pointer-events: none; border: 1px solid var(--border-color);">
        <%= t('settings.actionSuccessful', 'Action successful' ) %>
      </div>
      <div class="modal-overlay" id="socialListModal">
        <div class="modal-content" style="max-width: 520px; width: 100%;">
          <button class="modal-close" type="button"
            onclick="window.closeSocialListModal && window.closeSocialListModal()"
            data-close-list-modal="socialListModal"><i data-lucide="x"></i></button>
          <h2 class="modal-title" id="socialListModalTitle"><i data-lucide="users"></i>
            <%= t('profile.connections', 'Connections' ) %>
          </h2>
          <div style="display: flex; flex-direction: column; gap: 12px;">
            <div style="position: relative;">
              <input type="text" id="socialListSearch" placeholder="<%= t('header.searchPlaceholder', 'Search') %>"
                style="width: 100%; padding: 10px 12px 10px 36px; border-radius: 8px; border: 1px solid var(--border-color); background: var(--bg-dark); color: var(--text-main); font-size: 13px; outline: none;">
              <i data-lucide="search"
                style="position: absolute; left: 12px; top: 50%; transform: translateY(-50%); width: 14px; height: 14px; color: var(--text-muted);"></i>
            </div>
            <div id="socialListModalCount" style="font-size: 12px; color: var(--text-muted);"></div>
            <div id="socialListModalBody"
              style="display: flex; flex-direction: column; gap: 8px; max-height: 420px; overflow: auto;"></div>
          </div>
        </div>
      </div>

      <script>
        window.currentUserId = <%= currentUser.id %>;
        window.currentUserAvatar = "<%= currentUser.avatar %>";
        window.viewedProfileId = <%= profileUser.id %>;
        window.profileSocialLists = {
          followers: <%- JSON.stringify(followersList || []).replace(/</g, '\\u003c') %>,
          following: <%- JSON.stringify(followingList || []).replace(/</g, '\\u003c') %>
  };

        function switchGrid(gridName, tabElement) {
          document.querySelectorAll('.profile-tab').forEach(t => t.classList.remove('active'));
          tabElement.classList.add('active');

          document.getElementById('postsGrid').classList.remove('active');
          document.getElementById('shortsGrid').classList.remove('active');

          if (gridName === 'posts') {
            document.getElementById('postsGrid').classList.add('active');
          } else {
            document.getElementById('shortsGrid').classList.add('active');
          }
        }
      </script>
      <script src="/js/client.js?v=210"></script>
      </body>

      </html>
