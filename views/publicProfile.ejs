              </div>

              <div class="profile-stats-container">
                <button type="button" class="stat-box" data-follow-trigger="following">
                  <div class="stat-number" data-follow-stat="following">
                    <%= formatNumber(followingCount) %>
                  </div>
                  <div class="stat-label">Following</div>
                </button>
                <button type="button" class="stat-box" data-follow-trigger="followers">
                  <div class="stat-number" data-follow-stat="followers">
                    <%= formatNumber(followersCount) %>
                  </div>
                  <div class="stat-label">Followers</div>
                </button>
                <div class="stat-box">
                  <div class="stat-number">
                    <%= formatNumber(totalLikesCount) %>
                  </div>
                  <div class="stat-label">Likes</div>
                </div>
              </div>

              <% const followersPreview=(followersList || []).slice(0, 5); const followingPreview=(followingList ||
                []).slice(0, 5); %>
