<%- include('partials/head') %>
<%
function getYouTubeId(url) {
  if (!url) return null;
  const cleaned = url.trim();
  if (cleaned.length === 11 && !cleaned.includes('/') && !cleaned.includes('.')) {
    return cleaned;
  }
  const regExp = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|\&v=|live\/)([^#\&\?]*).*/;
  const match = cleaned.match(regExp);
  return (match && match[2].length === 11) ? match[2] : null;
}
%>
  <%- include('partials/header') %>
    <style>
      .profile-page-wrapper {
        padding: 0;
        width: 100%;
        box-sizing: border-box;
        max-width: 600px;
        margin: 0 auto;
        background: var(--bg-card);
        min-height: 100%;
        border-left: 1px solid var(--border-color);
        border-right: 1px solid var(--border-color);
      }

      .profile-cover-wrap {
        background: var(--primary);
        padding: 80px 20px 80px;
        text-align: center;
        color: #fff;
        position: relative;
        clip-path: polygon(0 0, 100% 0, 100% 70%, 0 100%);
      }

      .profile-avatar-wrapper {
        position: relative;
        margin-top: -110px;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 30px;
        z-index: 2;
      }

      .profile-avatar-circle {
        width: 150px;
        height: 150px;
        border-radius: 50%;
        border: 6px solid var(--bg-card);
        object-fit: cover;
        background: var(--bg-card);
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.2);
      }

      .alert {
        padding: 16px;
        border-radius: 8px;
        margin: 16px;
        font-weight: 500;
      }

      .alert.success {
        background: rgba(16, 185, 129, 0.1);
        color: var(--success);
        border: 1px solid rgba(16, 185, 129, 0.2);
      }

      .alert.error {
        background: rgba(239, 68, 68, 0.1);
        color: #ef4444;
        border: 1px solid rgba(239, 68, 68, 0.2);
      }

      .profile-stats-container {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 16px;
        margin: 20px 32px;
        padding: 16px 0;
        align-items: stretch;
      }

      .stat-box {
        text-align: center;
        min-width: 0;
        border-right: 1px solid var(--border-color);
      }

      button.stat-box {
        background: none;
        border: none;
        border-right: 1px solid var(--border-color);
        padding: 0;
        margin: 0;
        width: 100%;
        font-family: inherit;
        cursor: pointer;
        outline: none;
        display: block;
      }

      .stat-box:last-child, button.stat-box:last-child {
        border-right: none;
      }

      .stat-label {
        color: var(--text-muted);
        font-size: 14px;
        font-weight: 400;
        margin-top: 4px;
      }

      @media screen and (max-width: 768px) {
        .profile-stats-container {
          gap: 14px;
          margin: 20px 16px;
          padding: 12px 0;
        }

        .stat-box {
          padding: 0 10px;
        }
      }

      .stat-number {
        font-size: 20px;
        font-weight: 600;
        color: var(--text-main);
      }

      .profile-tabs {
        display: flex;
        border-top: 1px solid var(--border-color);
        border-bottom: 1px solid var(--border-color);
        margin-top: 24px;
      }

      .profile-tab {
        flex: 1;
        text-align: center;
        padding: 14px;
        cursor: pointer;
        font-weight: 500;
        color: var(--text-muted);
        border-bottom: 2px solid transparent;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
      }

      .profile-tab.active {
        color: var(--primary);
        border-bottom-color: var(--primary);
      }

      .profile-grid-container {
        display: none;
      }

      .profile-grid-container.active {
        display: grid;
      }

      .profile-grid {
        grid-template-columns: repeat(3, 1fr);
        gap: 2px;
      }

      .grid-item {
        aspect-ratio: 1;
        background: var(--bg-card);
        position: relative;
        overflow: hidden;
        cursor: pointer;
        border: 1px solid var(--border-color);
      }

      .grid-item img,
      .grid-item video {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .grid-item .views {
        position: absolute;
        bottom: 8px;
        left: 8px;
        color: white;
        font-size: 12px;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 4px;
        text-shadow: 0 1px 3px rgba(0, 0, 0, 0.8);
      }

      .profile-follow-btn {
        display: block;
        width: 200px;
        margin: 20px auto;
        padding: 12px;
        border-radius: 30px;
        background: var(--primary);
        color: white;
        text-align: center;
        text-decoration: none;
        font-weight: 500;
        font-size: 16px;
        box-shadow: 0 8px 20px rgba(59, 130, 246, 0.3);
        transition: transform 0.2s;
        border: none;
        cursor: pointer;
      }

      .profile-follow-btn:hover {
        transform: translateY(-2px);
      }

      .profile-social-grid {
        padding: 0 16px 24px 16px;
        display: none;
        grid-template-columns: 1fr;
        gap: 12px;
      }

      #socialListModal {
        position: fixed;
        inset: 0;
        display: none;
        justify-content: center;
        align-items: center;
        background: rgba(0, 0, 0, 0.7);
        z-index: 1000;
        padding: 20px;
        backdrop-filter: blur(5px);
      }

      #socialListModal.active {
        display: flex;
      }

      @media screen and (max-width: 768px) {
        .profile-social-grid {
          grid-template-columns: 1fr;
        }
      }
    </style>

