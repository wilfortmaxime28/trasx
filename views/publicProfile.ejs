                      style="display: flex; justify-content: space-between; align-items: center; gap: 10px; margin-bottom: 12px;">
                      <div>
                        <h3 style="margin: 0; font-size: 15px; color: var(--text-main);">Followers</h3>
                        <div style="font-size: 11px; color: var(--text-muted);">
