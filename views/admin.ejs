    const tableSearchInputs = Array.from(document.querySelectorAll('[data-table-search-input]'));
    const accountChartsData = <%- JSON.stringify(typeof accountChartsData !== 'undefined' ? accountChartsData : {}) %>;
    const countryChartsData = <%- JSON.stringify(typeof countryChartsData !== 'undefined' ? countryChartsData : {}) %>;
    const accountPeriodButtons = Array.from(document.querySelectorAll('[data-account-period-btn]'));
    const adminAccountCharts = document.getElementById('adminAccountCharts');
    const userAccountCharts = document.getElementById('userAccountCharts');
