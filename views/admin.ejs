      : [];
    const adminConversationsList = Array.isArray(typeof adminConversations !== 'undefined' ? adminConversations : [])
      ? (typeof adminConversations !== 'undefined' ? adminConversations : [])
      : [];
    const adminConversationMessagesList = Array.isArray(typeof adminConversationMessages !== 'undefined' ? adminConversationMessages : [])
      ? (typeof adminConversationMessages !== 'undefined' ? adminConversationMessages : [])
      : [];
    const adminPostCommentsList = Array.isArray(typeof adminPostComments !== 'undefined' ? adminPostComments : [])
      ? (typeof adminPostComments !== 'undefined' ? adminPostComments : [])
      : [];
    const activeModerationNotices = moderationNoticesList.filter((notice) => notice.status === 'active');
    const activeProfileModerationCount = activeModerationNotices.filter((notice) => notice.target_type === 'profile').length;
    const activePostModerationCount = activeModerationNotices.filter((notice) => notice.target_type === 'post').length;
    const postModerationReasons = [
      'Spam ou contenu trompeur',
      'Harcèlement ou intimidation',
      'Discours haineux',
      'Violence ou menace',
      'Contenu sexuel ou nudité',
      'Arnaque ou fraude',
      'Violation des droits',
      'Vente ou activité interdite',
      'Autre'
    ];
    const profileModerationReasons = [
      'Usurpation d identité',
      'Compte frauduleux',
      'Spam ou activité suspecte',
      'Harcèlement ou intimidation',
      'Discours haineux',
      'Menace pour la sécurité',
      'Contenu inapproprié répété',
      'Autre'
    ];
    const accountRestrictionReasons = Array.isArray(typeof adminAccountRestrictionReasons !== 'undefined' ? adminAccountRestrictionReasons : [])
      ? (typeof adminAccountRestrictionReasons !== 'undefined' ? adminAccountRestrictionReasons : [])
      : [];
    const blockedAccountsList = Array.isArray(typeof blockedAccounts !== 'undefined' ? blockedAccounts : [])
      ? (typeof blockedAccounts !== 'undefined' ? blockedAccounts : [])
      : [];
