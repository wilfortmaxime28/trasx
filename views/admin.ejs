      );
    const revenueEntries = Array.isArray(platformRevenueEntries) ? platformRevenueEntries : [];
    const moderationNoticesList = Array.isArray(typeof adminModerationNotices !== 'undefined' ? adminModerationNotices : [])
      ? (typeof adminModerationNotices !== 'undefined' ? adminModerationNotices : [])
      : [];
    const postsForReviewList = Array.isArray(typeof postsForReview !== 'undefined' ? postsForReview : [])
