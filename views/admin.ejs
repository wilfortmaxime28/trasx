                  <div style="font-size: 12px; color: var(--text-muted);">
                    <% if (officialSeedStats.pexelsApiKey) { %>
                      Clé active : <strong><%= officialSeedStats.pexelsKeyPreview %></strong>
                    <% } else { %>
                      Aucune clé Pexels enregistrée.
                    <% } %>
                  </div>
                </div>

                <div style="display: grid; gap: 6px;">
                  <label for="officialSeedPixabayApiKey" style="font-size: 12px; font-weight: 700; color: var(--text-main);">Clé API Pixabay</label>
                  <input
                    id="officialSeedPixabayApiKey"
                    type="text"
                    name="official_seed_pixabay_api_key"
                    class="compact-input"
                    placeholder="Collez votre clé Pixabay"
                    value="<%= officialSeedStats.pixabayApiKey || '' %>"
                    autocomplete="off"
                  >
                  <div style="font-size: 12px; color: var(--text-muted);">
                    <% if (officialSeedStats.pixabayApiKey) { %>
                      Clé active : <strong><%= officialSeedStats.pixabayKeyPreview %></strong>
                    <% } else { %>
                      Aucune clé Pixabay enregistrée.
                    <% } %>
                  </div>
                </div>

                <div style="display: grid; gap: 6px;">
                  <label for="officialSeedJamendoClientId" style="font-size: 12px; font-weight: 700; color: var(--text-main);">Clé Client ID Jamendo (Audio)</label>
                  <input
                    id="officialSeedJamendoClientId"
                    type="text"
                    name="official_seed_jamendo_client_id"
                    class="compact-input"
                    placeholder="Collez votre Client ID Jamendo"
                    value="<%= officialSeedStats.jamendoClientId || '' %>"
                    autocomplete="off"
                  >
                  <div style="font-size: 12px; color: var(--text-muted);">
                    <% if (officialSeedStats.jamendoClientId) { %>
                      Clé active : <strong><%= officialSeedStats.jamendoKeyPreview %></strong>
                    <% } else { %>
                      Aucune clé Jamendo enregistrée. Les vidéos muettes utiliseront les sons locaux de la plateforme en fallback.
                    <% } %>
                  </div>
                </div>

                <button type="submit" class="btn btn-secondary" style="width: 100%;">Enregistrer les paramètres d'API</button>
              </form>

              <form action="/admin/official-seeds/create" method="POST">
                <input type="hidden" name="redirectTo" value="<%= adminPaths.users || '/admin/users' %>">
                <button type="submit" class="btn btn-secondary" style="width: 100%;">Créer 100 comptes officiels</button>
              </form>

              <form action="/admin/official-seeds/generate" method="POST" style="display: grid; gap: 10px;">
                <input type="hidden" name="redirectTo" value="<%= adminPaths.users || '/admin/users' %>">
                <select name="content_type" class="compact-select" required>
                  <option value="feed">Feed</option>
                  <option value="shorts">Shorts</option>
                  <option value="status">Status</option>
                </select>
                <button type="submit" class="btn btn-success" style="width: 100%;">Générer 100 publications</button>
              </form>

              <form
                action="/admin/official-seeds/delete"
                method="POST"
                onsubmit="return confirm('Supprimer tous les comptes officiels TRASX et leurs contenus liés ? Cette action est irréversible.')"
              >
                <input type="hidden" name="redirectTo" value="<%= adminPaths.users || '/admin/users' %>">
                <input type="hidden" name="confirm_delete" value="yes">
                <button type="submit" class="btn" style="width: 100%; background: var(--danger); color: #fff;">Supprimer comptes officiels</button>
              </form>
            <% } else { %>
              <div style="padding: 14px; border-radius: 14px; background: rgba(245, 158, 11, 0.1); border: 1px solid rgba(245, 158, 11, 0.2); font-size: 13px; color: var(--text-main);">
                Vous pouvez consulter les statistiques, mais vous n’avez pas le droit de gérer les comptes officiels TRASX.
              </div>
            <% } %>
          </div>
        </div>
      </div>

      <div class="section-card" id="users">
        <div class="section-header">
          <div>
            <h3>Base des utilisateurs</h3>
            <p>Recherchez, filtrez et gerez les comptes, les audiences et les soldes depuis un seul tableau.</p>
          </div>
        </div>
        <div class="table-toolbar">
          <div class="table-toolbar-main">
            <label class="search-field">
              <i data-lucide="search"></i>
              <input type="search" id="adminUserSearch" placeholder="Rechercher par nom, pseudo, email...">
            </label>
            <select id="adminUserStatusFilter">
              <option value="">Tous les statuts</option>
              <option value="Active">Actifs</option>
              <option value="Paused">En pause</option>
              <option value="Partially Blocked">Partiellement bloques</option>
              <option value="Blocked">Bloques</option>
              <option value="Frozen">Gelés</option>
            </select>
            <button type="button" class="btn btn-secondary" id="adminUserResetFilters">Réinitialiser</button>
          </div>
          <div class="table-toolbar-actions">
            <button type="button" class="btn btn-success" id="adminExportUsersCsv">
              <i data-lucide="download" style="width: 15px; height: 15px;"></i>
              Exporter CSV
            </button>
            <% if (hasPageAccess('balances')) { %><a href="<%= adminPaths.balances || '/admin/balances' %>" class="btn btn-secondary">Créditer des comptes</a><% } %>
          </div>
        </div>
        <div class="admin-user-table-hint">Cliquez sur une ligne pour ouvrir la fiche détaillée de l'utilisateur.</div>
        <div style="overflow-x: auto;">
          <table class="admin-user-table">
            <thead>
              <tr>
                <th>Utilisateur</th>
                <th>Email</th>
                <th>Accès rapide</th>
              </tr>
            </thead>
            <tbody>
              <% users.forEach(user => { %>
                <tr
                  class="admin-user-row"
                  data-user-row
                  data-user-status="<%= user.account_status %>"
                  data-user-search="<%= `${user.first_name || ''} ${user.last_name || ''} ${user.username || ''} ${user.email || ''}`.toLowerCase() %>"
                  data-user-modal-template="admin-user-detail-template-<%= user.id %>"
                >
                  <td>
                    <div class="user-info">
                      <img src="<%= user.avatar || 'https://via.placeholder.com/150' %>" class="user-avatar" alt="Avatar">
                      <div class="admin-user-main">
                        <div class="admin-user-name">@<%= user.username %></div>
                        <div class="admin-user-subline"><%= user.first_name %> <%= user.last_name %></div>
                      </div>
                    </div>
                  </td>
                  <td class="admin-user-email" style="color: var(--text-muted);"><strong><%= user.email %></strong></td>
                  <td style="color: var(--primary); font-weight: 700;">Voir la fiche</td>
                </tr>
                <template id="admin-user-detail-template-<%= user.id %>">
                  <div class="admin-user-modal-grid">
                    <div class="admin-user-sheet">
                      <div class="admin-user-sheet-card">
                        <div class="admin-user-hero">
                          <img src="<%= user.avatar || 'https://via.placeholder.com/150' %>" class="user-avatar" alt="Avatar">
                          <div class="admin-user-hero-copy">
                            <div class="admin-user-hero-name"><%= user.first_name %> <%= user.last_name %></div>
                            <div class="admin-user-hero-meta">@<%= user.username %> · <%= user.email %></div>
                            <div>
                              <% if(user.account_status === 'Active') { %>
                                <span class="badge active">Actif</span>
                              <% } else if(user.account_status === 'Paused') { %>
                                <span class="badge paused">En pause</span>
                              <% } else if(user.account_status === 'Partially Blocked') { %>
                                <span class="badge partially">Partiellement bloqué</span>
                              <% } else if(user.account_status === 'Frozen') { %>
                                <span class="badge frozen">❄️ Gelé</span>
                              <% } else { %>
                                <span class="badge blocked">Bloqué</span>
                              <% } %>
                            </div>
                          </div>
                        </div>
                      </div>

                      <div class="admin-user-sheet-card">
                        <h4>Soldes du compte</h4>
                        <div class="admin-user-detail-grid">
                          <div class="admin-user-detail-tile">
                            <span class="admin-user-detail-label">Compte de dépôt</span>
                            <strong class="admin-user-detail-value"><%= formatUsd(user.deposit_account_balance) %></strong>
                          </div>
                          <div class="admin-user-detail-tile">
                            <span class="admin-user-detail-label">Compte de retrait</span>
                            <strong class="admin-user-detail-value"><%= formatUsd(user.withdrawal_account_balance) %></strong>
                          </div>
                          <div class="admin-user-detail-tile">
                            <span class="admin-user-detail-label">Compte bonus</span>
                            <strong class="admin-user-detail-value"><%= formatUsd(user.bonus_account_balance) %></strong>
                          </div>
                          <div class="admin-user-detail-tile">
                            <span class="admin-user-detail-label">Jetons</span>
                            <strong class="admin-user-detail-value"><%= formatTokenBalance(user.token_balance) %></strong>
                          </div>
                        </div>
                      </div>

                      <div class="admin-user-sheet-card">
                        <h4>Audience et visibilité</h4>
                        <div class="admin-user-detail-grid">
                          <div class="admin-user-detail-tile">
                            <span class="admin-user-detail-label">Abonnés</span>
                            <strong class="admin-user-detail-value"><%= Number(user.followers_count || 0) %></strong>
                          </div>
                          <div class="admin-user-detail-tile">
                            <span class="admin-user-detail-label">Abonnements</span>
                            <strong class="admin-user-detail-value"><%= Number(user.following_count || 0) %></strong>
                          </div>
                          <div class="admin-user-detail-tile">
                            <span class="admin-user-detail-label">Posts de base / jour</span>
                            <strong class="admin-user-detail-value"><%= Number(user.promo_post_daily_base || 0) %></strong>
                          </div>
                          <div class="admin-user-detail-tile">
                            <span class="admin-user-detail-label">Shorts de base / jour</span>
                            <strong class="admin-user-detail-value"><%= Number(user.promo_reel_daily_base || 0) %></strong>
                          </div>
                          <div class="admin-user-detail-tile">
                            <span class="admin-user-detail-label">Cible actuelle posts / jour</span>
                            <strong class="admin-user-detail-value"><%= Number(user.post_daily_reach_target || 0) %></strong>
                          </div>
                          <div class="admin-user-detail-tile">
                            <span class="admin-user-detail-label">Cible actuelle shorts / jour</span>
                            <strong class="admin-user-detail-value"><%= Number(user.reel_daily_reach_target || 0) %></strong>
                          </div>
                        </div>
                      </div>
                    </div>

                    <div class="admin-user-sheet">
                      <div class="admin-user-sheet-card">
                        <h4>Résumé du compte</h4>
                        <div class="admin-user-summary-list">
                          <div class="admin-user-summary-row">
                            <span>Prénom</span>
                            <strong><%= user.first_name || '—' %></strong>
                          </div>
                          <div class="admin-user-summary-row">
                            <span>Nom</span>
                            <strong><%= user.last_name || '—' %></strong>
                          </div>
                          <div class="admin-user-summary-row">
                            <span>Email</span>
                            <strong><%= user.email || '—' %></strong>
                          </div>
                          <div class="admin-user-summary-row">
                            <span>Pseudo</span>
                            <strong>@<%= user.username || '—' %></strong>
                          </div>
                          <div class="admin-user-summary-row">
                            <span>Téléphone</span>
                            <strong><%= user.phone || '—' %></strong>
                          </div>
                          <div class="admin-user-summary-row">
                            <span>Pays</span>
                            <strong><%= user.country || '—' %></strong>
                          </div>
                          <div class="admin-user-summary-row">
                            <span>Certification actuelle</span>
                            <strong>
                              <% const currentCertColor = certificationColorMap[user.certification_type || 'None'] || '#94a3b8'; %>
                              <span class="cert-badge-preview" style="color: <%= currentCertColor %>;">
                                <i data-lucide="badge-check"></i>
                                <span><%= user.certification_type || 'None' %></span>
                              </span>
                            </strong>
                          </div>
                          <div class="admin-user-summary-row">
                            <span>Compte vérifié</span>
                            <strong><%= Number(user.is_verified || 0) === 1 ? 'Oui' : 'Non' %></strong>
                          </div>
                        </div>
                        <% if (user.account_restriction_reason) { %>
                          <div style="margin-top: 14px; padding: 14px; border-radius: 14px; border: 1px solid rgba(239, 90, 90, 0.18); background: rgba(239, 90, 90, 0.06);">
                            <div style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; color: var(--danger); margin-bottom: 8px;">Restriction active</div>
                            <div style="font-weight: 700; color: var(--text-main);"><%= user.account_restriction_reason %></div>
                            <% if (user.account_restriction_details) { %>
                              <div style="margin-top: 6px; font-size: 12px; line-height: 1.45; color: var(--text-muted);"><%= user.account_restriction_details %></div>
                            <% } %>
                            <% if (user.account_restriction_updated_at) { %>
                              <div style="margin-top: 8px; font-size: 11px; color: var(--text-soft);">
                                Mis à jour le <%= new Date(user.account_restriction_updated_at).toLocaleString('fr-FR') %>
                              </div>
                            <% } %>
                          </div>
                        <% } %>
                      </div>

                      <div class="admin-user-sheet-card">
                        <h4>Actions administrateur</h4>
                        <%
                          const currentRestrictionReason = String(user.account_restriction_reason || '').trim();
                          const currentRestrictionReasonIsPreset = accountRestrictionReasons.includes(currentRestrictionReason);
                          const currentStatusUsesRestriction = ['Paused', 'Partially Blocked', 'Blocked'].includes(user.account_status);
                        %>

                        <%# --- FREEZE / UNFREEZE per user --- %>
                        <div style="margin-bottom: 14px; padding: 12px; border-radius: 12px; border: 1px solid rgba(14, 165, 233, 0.2); background: rgba(14, 165, 233, 0.05);">
                          <div style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; color: #0ea5e9; margin-bottom: 10px; display: flex; align-items: center; gap: 6px;">
                            <i data-lucide="snowflake" style="width: 13px; height: 13px;"></i> Gel du compte
                          </div>
                          <% if (user.account_status === 'Frozen') { %>
                            <p style="margin: 0 0 10px; font-size: 12px; color: var(--text-secondary);">Ce compte est actuellement <strong style="color:#0ea5e9;">gelé</strong>. L'utilisateur ne peut pas se connecter.</p>
                            <form action="/admin/user-freeze" method="POST" class="action-form">
                              <input type="hidden" name="userId" value="<%= user.id %>">
                              <input type="hidden" name="action" value="unfreeze">
                              <input type="hidden" name="redirectTo" value="<%= adminPaths.users || '/admin/users' %>">
                              <button type="submit" class="btn" style="background: var(--success); width: 100%; font-size: 12px;">✅ Dégeler et réactiver</button>
                            </form>
                          <% } else { %>
                            <p style="margin: 0 0 10px; font-size: 12px; color: var(--text-secondary);">Geler bloque immédiatement la connexion de l'utilisateur.</p>
                            <form action="/admin/user-freeze" method="POST" class="action-form" onsubmit="return confirm('Geler le compte de @<%= user.username %> ? L\'utilisateur ne pourra plus se connecter.')">
                              <input type="hidden" name="userId" value="<%= user.id %>">
                              <input type="hidden" name="action" value="freeze">
                              <input type="hidden" name="redirectTo" value="<%= adminPaths.users || '/admin/users' %>">
                              <button type="submit" class="btn" style="background: #0ea5e9; width: 100%; font-size: 12px;">❄️ Geler le compte</button>
                            </form>
                          <% } %>
                        </div>

                        <form action="/admin/user-status" method="POST" class="mini-form" data-account-status-form style="margin-bottom: 14px;">
                          <input type="hidden" name="userId" value="<%= user.id %>">
                          <input type="hidden" name="redirectTo" value="<%= adminPaths.users || '/admin/users' %>">
                          <div class="mini-label">Statut du compte et motif visible côté utilisateur</div>
                          <select name="status" class="compact-select" data-account-status-select>
                            <option value="Active" <%= user.account_status === 'Active' ? 'selected' : '' %>>Actif</option>
                            <option value="Paused" <%= user.account_status === 'Paused' ? 'selected' : '' %>>En pause</option>
                            <option value="Partially Blocked" <%= user.account_status === 'Partially Blocked' ? 'selected' : '' %>>Partiellement bloqué</option>
                            <option value="Blocked" <%= user.account_status === 'Blocked' ? 'selected' : '' %>>Bloqué</option>
                          </select>
                          <div data-account-restriction-fields style="display: <%= currentStatusUsesRestriction ? 'grid' : 'none' %>; gap: 8px;">
                            <select name="reason" class="compact-select" data-account-reason-select>
                              <option value="">Choisir une raison</option>
                              <% accountRestrictionReasons.forEach((reason) => { %>
                                <option
                                  value="<%= reason %>"
                                  <%= (currentRestrictionReasonIsPreset && currentRestrictionReason === reason) || (!currentRestrictionReasonIsPreset && currentRestrictionReason && reason === 'Autre') ? 'selected' : '' %>
                                >
                                  <%= reason %>
                                </option>
                              <% }) %>
                            </select>
                            <input
                              type="text"
                              name="custom_reason"
                              class="compact-input"
                              data-account-custom-reason
                              maxlength="120"
                              placeholder="Raison personnalisée"
                              value="<%= !currentRestrictionReasonIsPreset ? currentRestrictionReason : '' %>"
                              style="display: <%= !currentRestrictionReasonIsPreset && currentRestrictionReason ? 'block' : 'none' %>;"
                            >
                            <input
                              type="text"
                              name="details"
                              class="compact-input"
                              maxlength="500"
                              placeholder="Détail visible par l'utilisateur"
                              value="<%= user.account_restriction_details || '' %>"
                            >
                          </div>
                          <button type="submit" class="btn" style="width: fit-content;">Appliquer</button>
                        </form>

                        <% if (canManageUserCertification) { %>
                        <form action="/admin/user-certification" method="POST" class="mini-form" style="margin-bottom: 14px;">
                          <input type="hidden" name="userId" value="<%= user.id %>">
                          <div class="mini-label">Icône de certification</div>
                          <select name="certification_type" class="compact-select" required>
                            <% certificationOptionsList.forEach((option) => { %>
                              <option value="<%= option.value %>" <%= (user.certification_type || 'None') === option.value ? 'selected' : '' %>>
                                <%= option.label %>
                              </option>
                            <% }) %>
                          </select>
                          <div style="display: flex; flex-wrap: wrap; gap: 8px;">
                            <% certificationOptionsList.forEach((option) => { %>
                              <span class="cert-badge-preview" style="color: <%= option.color %>;">
                                <i data-lucide="badge-check"></i>
                                <span><%= option.label %></span>
                              </span>
                            <% }) %>
                          </div>
                          <button type="submit" class="btn" style="width: fit-content;">Mettre à jour la certification</button>
                        </form>
                        <% } %>

                        <% if (canManageBalancesFlag) { %>
                        <form action="/admin/balance-debit" method="POST" class="mini-form" style="margin-bottom: 14px;">
                          <input type="hidden" name="userId" value="<%= user.id %>">
                          <input type="hidden" name="redirectTo" value="<%= adminPaths.users || '/admin/users' %>">
                          <div class="mini-label">Débiter un compte utilisateur</div>
                          <select name="account_type" class="compact-select" required>
                            <option value="deposit">Compte de dépôt</option>
                            <option value="withdrawal">Compte de retrait</option>
                            <option value="bonus">Compte bonus</option>
                          </select>
                          <input type="number" name="amount" class="compact-input" min="0.01" step="0.01" placeholder="Montant à débiter en USD" required>
                          <input type="text" name="note" class="compact-input" maxlength="180" placeholder="Raison ou note optionnelle">
                          <button type="submit" class="btn" style="background: #ef4444; width: fit-content;">Débiter le compte</button>
                        </form>
                        <% } %>

                        <form action="/admin/moderation/report-profile" method="POST" class="mini-form" data-moderation-reason-form style="margin-bottom: 14px;">
                          <input type="hidden" name="userId" value="<%= user.id %>">
                          <input type="hidden" name="redirectTo" value="<%= adminPaths.users || '/admin/users' %>">
                          <div class="mini-label">Alerte profil</div>
                          <select name="reason" class="compact-select" data-moderation-reason-select required>
                            <option value="">Choisir une raison</option>
                            <% profileModerationReasons.forEach((reason) => { %>
                              <option value="<%= reason %>"><%= reason %></option>
                            <% }) %>
                          </select>
                          <input type="text" name="custom_reason" class="compact-input" data-moderation-custom-reason maxlength="120" placeholder="Raison personnalisée" style="display: none;">
                          <input type="text" name="details" class="compact-input" maxlength="500" placeholder="Détail visible par l'utilisateur">
                          <button type="submit" class="btn" style="background: var(--warning); color: #0f172a; width: fit-content;">Signaler le profil</button>
                        </form>

                        <form action="/admin/user-delete" method="POST" class="action-form" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet utilisateur ? Cette action est irréversible.');">
                          <input type="hidden" name="userId" value="<%= user.id %>">
                          <button type="submit" class="btn" style="background: var(--danger);">Supprimer l'utilisateur</button>
                        </form>
                      </div>
                    </div>
                  </div>
                </template>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Bulk Actions Card -->
      <div class="section-card" style="margin-top: 24px; border-color: rgba(14, 165, 233, 0.3);">
        <div class="section-header">
          <div>
            <h3>Actions de masse : Gel des comptes</h3>
            <p>Gelez ou dégelez tous les comptes utilisateurs de la plateforme d'un coup. Les administrateurs ne sont pas affectés.</p>
          </div>
        </div>
        <div style="padding: 24px; display: grid; grid-template-columns: 1fr 1fr; gap: 24px;">
          <div style="padding: 20px; border-radius: 12px; border: 1px solid rgba(14, 165, 233, 0.15); background: rgba(14, 165, 233, 0.03);">
            <h4 style="margin: 0 0 8px; color: #0ea5e9; display: flex; align-items: center; gap: 8px;">
              <i data-lucide="snowflake" style="width: 18px; height: 18px;"></i> Geler tous les comptes actifs
            </h4>
            <p style="font-size: 13px; color: var(--text-muted); margin: 0 0 16px; line-height: 1.4;">
              Cette action va passer tous les utilisateurs dont le statut est actuellement <strong>Actif</strong> à l'état <strong>Gelé</strong>. Ils seront déconnectés immédiatement et bloqués à la connexion.
            </p>
            <form action="/admin/user-freeze-all" method="POST" onsubmit="return confirm('ATTENTION : Vous êtes sur le point de GELER TOUS les comptes utilisateurs actifs de la plateforme. Ils seront déconnectés immédiatement et ne pourront plus se connecter. Voulez-vous continuer ?')">
              <input type="hidden" name="action" value="freeze">
              <button type="submit" class="btn" style="background: #0ea5e9; color: #fff; width: 100%;">
                Geler tous les comptes
              </button>
            </form>
          </div>
          
          <div style="padding: 20px; border-radius: 12px; border: 1px solid rgba(34, 181, 115, 0.15); background: rgba(34, 181, 115, 0.03);">
            <h4 style="margin: 0 0 8px; color: var(--success); display: flex; align-items: center; gap: 8px;">
              <i data-lucide="user-check" style="width: 18px; height: 18px;"></i> Dégeler et réactiver tous les comptes
            </h4>
            <p style="font-size: 13px; color: var(--text-muted); margin: 0 0 16px; line-height: 1.4;">
              Cette action va repasser tous les utilisateurs dont le statut est actuellement <strong>Gelé</strong> à l'état <strong>Actif</strong>, restaurant leur accès complet.
            </p>
            <form action="/admin/user-freeze-all" method="POST" onsubmit="return confirm('Voulez-vous dégeler et réactiver tous les comptes utilisateurs gelés de la plateforme ?')">
              <input type="hidden" name="action" value="unfreeze">
              <button type="submit" class="btn" style="background: var(--success); color: #fff; width: 100%;">
                Dégeler tous les comptes
              </button>
            </form>
          </div>
        </div>
      </div>

      <div class="admin-user-modal" id="adminUserModal" aria-hidden="true">
        <div class="admin-user-modal-dialog" role="dialog" aria-modal="true" aria-labelledby="adminUserModalTitle">
          <div class="admin-user-modal-header">
            <div>
              <h3 class="admin-user-modal-title" id="adminUserModalTitle">Fiche utilisateur</h3>
              <p class="admin-user-modal-subtitle" id="adminUserModalSubtitle">Consultez les détails du compte, les audiences, les soldes et les actions disponibles.</p>
            </div>
            <button type="button" class="btn admin-user-modal-close" id="adminUserModalClose" aria-label="Fermer">
              <i data-lucide="x" style="width: 18px; height: 18px;"></i>
            </button>
          </div>
          <div class="admin-user-modal-body" id="adminUserModalBody"></div>
        </div>
      </div>
      <% } %>

      <% if (isPage('conversations')) { %>
      <div class="section-card" id="admin-conversations">
        <div class="section-header">
          <div>
            <h3>Conversations des utilisateurs</h3>
            <p>Accédez à toutes les conversations privées échangées sur la plateforme.</p>
          </div>
        </div>
        <% if (adminConversationsList.length > 0) { %>
          <div class="table-search-row">
            <label class="search-field">
              <i data-lucide="search"></i>
              <input type="search" data-table-search-input data-table-target="adminConversationsTable" placeholder="Rechercher dans les conversations...">
            </label>
          </div>
          <div style="overflow-x: auto;">
            <table id="adminConversationsTable">
              <thead>
                <tr>
                  <th>Participants</th>
                  <th>Dernier message</th>
                  <th>Total</th>
                  <th>Dernière activité</th>
                  <th>Détail</th>
                </tr>
              </thead>
              <tbody>
                <% adminConversationsList.forEach((conversation, conversationIndex) => { %>
                  <% 
                    const conversationTemplateId = `admin-conversation-template-${conversationIndex}`;
                    const conversationMessages = adminConversationMessagesList
                      .filter((message) => {
                        const senderId = Number(message.sender_id || 0);
                        const receiverId = Number(message.receiver_id || 0);
                        const a = Number(conversation.user_a_id || 0);
                        const b = Number(conversation.user_b_id || 0);
                        return (senderId === a && receiverId === b) || (senderId === b && receiverId === a);
                      })
                      .slice()
                      .reverse();
                    const conversationPreview = String(conversation.display_preview || '').trim() || 'Message sans texte';
                  %>
                  <tr
                    class="admin-open-modal-row"
                    data-modal-template="<%= conversationTemplateId %>"
                    data-modal-title="Conversation privée"
                    data-modal-subtitle="Historique complet de cette conversation utilisateur."
                  >
                    <td>
                      <div style="display: grid; gap: 10px;">
                        <div class="user-info">
                          <img src="<%= conversation.user_a_avatar || 'https://via.placeholder.com/150' %>" class="user-avatar" alt="Avatar">
                          <div class="admin-user-main">
                            <div class="admin-user-name">@<%= conversation.user_a_username || 'utilisateur' %></div>
                            <div class="admin-user-subline"><%= conversation.user_a_name || 'Utilisateur' %></div>
                          </div>
                        </div>
                        <div class="user-info">
                          <img src="<%= conversation.user_b_avatar || 'https://via.placeholder.com/150' %>" class="user-avatar" alt="Avatar">
                          <div class="admin-user-main">
                            <div class="admin-user-name">@<%= conversation.user_b_username || 'utilisateur' %></div>
                            <div class="admin-user-subline"><%= conversation.user_b_name || 'Utilisateur' %></div>
                          </div>
                        </div>
                      </div>
                    </td>
                    <td style="max-width: 360px;">
                      <div style="display: grid; gap: 6px;">
                        <strong><%= conversationPreview || 'Aucun aperçu' %></strong>
                        <div class="admin-conversation-route">
                          <span><strong>Expéditeur :</strong> @<%= conversation.last_sender_username || 'utilisateur' %></span>
                          <span><strong>Destinataire :</strong> @<%= conversation.last_receiver_username || 'utilisateur' %></span>
                        </div>
                      </div>
                    </td>
                    <td><%= Number(conversation.total_messages || 0) %> messages</td>
                    <td><%= new Date(conversation.last_message_at).toLocaleString() %></td>
                    <td style="color: var(--primary); font-weight: 700;">Voir</td>
                  </tr>
                  <template id="<%= conversationTemplateId %>">
                    <div class="admin-user-sheet">
                      <div class="admin-user-sheet-card">
                        <div class="admin-user-detail-grid">
                          <div class="admin-user-detail-tile">
                            <span class="admin-user-detail-label">Participant 1</span>
                            <strong class="admin-user-detail-value">@<%= conversation.user_a_username || 'utilisateur' %></strong>
                          </div>
                          <div class="admin-user-detail-tile">
                            <span class="admin-user-detail-label">Participant 2</span>
                            <strong class="admin-user-detail-value">@<%= conversation.user_b_username || 'utilisateur' %></strong>
                          </div>
                          <div class="admin-user-detail-tile">
                            <span class="admin-user-detail-label">Volume</span>
                            <strong class="admin-user-detail-value"><%= Number(conversation.total_messages || 0) %> messages</strong>
                          </div>
                          <div class="admin-user-detail-tile">
                            <span class="admin-user-detail-label">Dernière activité</span>
                            <strong class="admin-user-detail-value"><%= new Date(conversation.last_message_at).toLocaleString() %></strong>
                          </div>
                          <div class="admin-user-detail-tile">
                            <span class="admin-user-detail-label">Dernier expéditeur</span>
                            <strong class="admin-user-detail-value">@<%= conversation.last_sender_username || 'utilisateur' %></strong>
                          </div>
                          <div class="admin-user-detail-tile">
                            <span class="admin-user-detail-label">Dernier destinataire</span>
                            <strong class="admin-user-detail-value">@<%= conversation.last_receiver_username || 'utilisateur' %></strong>
                          </div>
                        </div>
                      </div>
                      <div class="admin-user-sheet-card">
                        <h4>Historique</h4>
                        <div class="admin-audit-thread">
                          <% conversationMessages.forEach((message) => { %>
                            <% const isUserA = Number(message.sender_id || 0) === Number(conversation.user_a_id || 0); %>
                            <% 
                              const isSharedPost = message.structured_content && message.structured_content.type === 'shared_post';
                              const isSharedReel = message.structured_content && message.structured_content.type === 'shared_reel';
                              const sharedContentMessage = isSharedPost
                                ? (message.structured_content.post && typeof message.structured_content.post === 'object' ? message.structured_content.post : {})
                                : (isSharedReel
                                  ? (message.structured_content.reel && typeof message.structured_content.reel === 'object' ? message.structured_content.reel : {})
                                  : null);
                              const sharedContentUrl = (isSharedPost || isSharedReel)
                                ? String(message.structured_content.appUrl || message.structured_content.shareUrl || '').trim()
                                : '';
                              const sharedContentExcerpt = sharedContentMessage
                                ? String(sharedContentMessage.excerpt || sharedContentMessage.content || sharedContentMessage.caption || '').trim()
                                : '';
                              const sharedContentPreviewImage = sharedContentMessage
                                ? String(sharedContentMessage.previewImageUrl || '').trim()
                                : '';
                            %>
                            <article class="admin-audit-bubble <%= isUserA ? 'is-left' : 'is-right' %>">
                              <div class="admin-audit-bubble-head">
                                <strong>@<%= message.sender_username || 'utilisateur' %> → @<%= message.receiver_username || 'utilisateur' %></strong>
                                <span><%= new Date(message.created_at).toLocaleString() %></span>
                              </div>
                              <div class="admin-audit-bubble-body">
                                <% if (sharedContentMessage) { %>
                                  <div class="admin-shared-post-card">
                                    <div class="admin-shared-post-kicker"><%= isSharedReel ? 'Short partagé' : 'Publication partagée' %></div>
                                    <div class="admin-shared-post-author">
                                      <img src="<%= sharedContentMessage.authorAvatar || '/assets/avatar_placeholder.jpg' %>" alt="Avatar partagé">
                                      <div class="admin-shared-post-author-meta">
                                        <strong><%= sharedContentMessage.authorName || sharedContentMessage.authorUsername || (isSharedReel ? 'Short' : 'Publication') %></strong>
                                        <% if (sharedContentMessage.authorUsername) { %>
                                          <span>@<%= sharedContentMessage.authorUsername %></span>
                                        <% } %>
                                      </div>
                                    </div>
                                    <% if (sharedContentPreviewImage) { %>
                                      <a href="<%= sharedContentUrl || '#' %>" class="admin-shared-post-media" target="_blank" rel="noopener">
                                        <img src="<%= sharedContentPreviewImage %>" alt="Aperçu du contenu partagé">
                                      </a>
                                    <% } %>
                                    <p><%= sharedContentExcerpt || (isSharedReel ? 'Short partagé sans texte.' : 'Publication partagée sans texte.') %></p>
                                    <% if (sharedContentUrl) { %>
                                      <a href="<%= sharedContentUrl %>" class="admin-shared-post-link" target="_blank" rel="noopener"><%= isSharedReel ? 'Ouvrir le short' : 'Ouvrir la publication' %></a>
                                    <% } %>
                                  </div>
                                <% } else if (message.display_content) { %>
                                  <p><%= message.display_content %></p>
                                <% } %>
                                <% if (message.attachment_url) { %>
                                  <div class="admin-audit-attachment">
                                    <span>Pièce jointe :</span>
                                    <strong><%= message.attachment_name || message.attachment_type || 'fichier' %></strong>
                                  </div>
                                <% } %>
                              </div>
                            </article>
                          <% }) %>
                        </div>
                      </div>
                    </div>
                  </template>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } else { %>
          <p style="color: var(--text-muted); margin: 0;">Aucune conversation disponible pour le moment.</p>
        <% } %>
      </div>

      <div class="admin-user-modal" id="adminUserModal" aria-hidden="true">
        <div class="admin-user-modal-dialog" role="dialog" aria-modal="true" aria-labelledby="adminUserModalTitle">
          <div class="admin-user-modal-header">
            <div>
              <h3 class="admin-user-modal-title" id="adminUserModalTitle">Conversation privée</h3>
              <p class="admin-user-modal-subtitle" id="adminUserModalSubtitle">Historique complet de cette conversation utilisateur.</p>
            </div>
            <button type="button" class="btn admin-user-modal-close" id="adminUserModalClose" aria-label="Fermer">
              <i data-lucide="x" style="width: 18px; height: 18px;"></i>
            </button>
          </div>
          <div class="admin-user-modal-body" id="adminUserModalBody"></div>
        </div>
      </div>
      <% } %>

      <% if (isPage('comments')) { %>
      <div class="section-card" id="admin-comments">
        <div class="section-header">
          <div>
            <h3>Commentaires des posts</h3>
            <p>Consultez tous les commentaires publiés sous les posts avec le contexte complet de la publication.</p>
          </div>
        </div>
        <% if (adminPostCommentsList.length > 0) { %>
          <div class="table-search-row">
            <label class="search-field">
              <i data-lucide="search"></i>
              <input type="search" data-table-search-input data-table-target="adminCommentsTable" placeholder="Rechercher dans les commentaires...">
            </label>
          </div>
          <div style="overflow-x: auto;">
            <table id="adminCommentsTable">
              <thead>
                <tr>
                  <th>Commentaire</th>
                  <th>Auteur</th>
                  <th>Post</th>
                  <th>Propriétaire du post</th>
                  <th>Date</th>
                  <th>Détail</th>
                </tr>
              </thead>
              <tbody>
                <% adminPostCommentsList.forEach((comment) => { %>
                  <% const commentTemplateId = `admin-comment-template-${comment.id}`; %>
                  <tr
                    class="admin-open-modal-row"
                    data-modal-template="<%= commentTemplateId %>"
                    data-modal-title="Commentaire de post"
                    data-modal-subtitle="Détail complet du commentaire et du post concerné."
                  >
                    <td style="max-width: 300px;"><strong><%= comment.content || 'Commentaire vocal' %></strong></td>
                    <td>
                      <div style="font-weight: 700;">@<%= comment.commenter_username || 'utilisateur' %></div>
                      <div style="font-size: 12px; color: var(--text-muted);"><%= comment.commenter_name || 'Utilisateur' %></div>
                    </td>
                    <td style="max-width: 240px;"><%= comment.post_content || 'Post média ou sans texte' %></td>
                    <td>
                      <div style="font-weight: 700;">@<%= comment.post_owner_username || 'utilisateur' %></div>
                      <div style="font-size: 12px; color: var(--text-muted);"><%= comment.post_owner_name || 'Utilisateur' %></div>
                    </td>
                    <td><%= new Date(comment.created_at).toLocaleString() %></td>
                    <td style="color: var(--primary); font-weight: 700;">Voir</td>
                  </tr>
                  <template id="<%= commentTemplateId %>">
                    <div class="admin-user-modal-grid">
                      <div class="admin-user-sheet">
                        <div class="admin-user-sheet-card">
                          <h4>Commentaire</h4>
                          <div class="admin-audit-comment-card">
                            <div class="admin-audit-comment-head">
                              <strong>@<%= comment.commenter_username || 'utilisateur' %></strong>
                              <span><%= new Date(comment.created_at).toLocaleString() %></span>
                            </div>
                            <p><%= comment.content || 'Commentaire vocal' %></p>
                            <% if (comment.voice_url) { %>
                              <div class="admin-audit-attachment">
                                <span>Note vocale :</span>
                                <strong><%= Number(comment.voice_duration_seconds || 0) %> sec</strong>
                              </div>
                            <% } %>
                          </div>
                        </div>
                        <div class="admin-user-sheet-card">
                          <h4>Post concerné</h4>
                          <div class="admin-audit-comment-card">
                            <div class="admin-audit-comment-head">
                              <strong>@<%= comment.post_owner_username || 'utilisateur' %></strong>
                              <span>Post #<%= comment.post_id %></span>
                            </div>
                            <p><%= comment.post_content || 'Post média ou sans texte' %></p>
                            <% if (comment.post_image_url) { %>
                              <img src="<%= comment.post_image_url %>" alt="Aperçu du post" class="admin-audit-post-preview">
                            <% } %>
                          </div>
                        </div>
                      </div>
                      <div class="admin-user-sheet">
                        <div class="admin-user-sheet-card">
                          <h4>Contexte</h4>
                          <div class="admin-user-summary-list">
                            <div class="admin-user-summary-row"><span>ID commentaire</span><strong>#<%= comment.id %></strong></div>
                            <div class="admin-user-summary-row"><span>ID post</span><strong>#<%= comment.post_id %></strong></div>
                            <div class="admin-user-summary-row"><span>Auteur</span><strong>@<%= comment.commenter_username || 'utilisateur' %></strong></div>
                            <div class="admin-user-summary-row"><span>Propriétaire</span><strong>@<%= comment.post_owner_username || 'utilisateur' %></strong></div>
                            <div class="admin-user-summary-row"><span>Parent</span><strong><%= comment.parent_id ? `#${comment.parent_id}` : 'Commentaire principal' %></strong></div>
                          </div>
                        </div>
                      </div>
                    </div>
                  </template>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } else { %>
          <p style="color: var(--text-muted); margin: 0;">Aucun commentaire de post disponible pour le moment.</p>
        <% } %>
      </div>

      <div class="admin-user-modal" id="adminUserModal" aria-hidden="true">
        <div class="admin-user-modal-dialog" role="dialog" aria-modal="true" aria-labelledby="adminUserModalTitle">
          <div class="admin-user-modal-header">
            <div>
              <h3 class="admin-user-modal-title" id="adminUserModalTitle">Commentaire de post</h3>
              <p class="admin-user-modal-subtitle" id="adminUserModalSubtitle">Détail complet du commentaire et du post concerné.</p>
            </div>
            <button type="button" class="btn admin-user-modal-close" id="adminUserModalClose" aria-label="Fermer">
              <i data-lucide="x" style="width: 18px; height: 18px;"></i>
            </button>
          </div>
          <div class="admin-user-modal-body" id="adminUserModalBody"></div>
        </div>
      </div>
      <% } %>

      <% if (isPage('moderation')) { %>
      <div class="section-card" id="moderation">
        <div class="section-header">
          <div>
            <h3>Analyse des posts et moderation</h3>
            <p>Surveillez les signalements profil et post, puis intervenez sans quitter le tableau de bord.</p>
          </div>
        </div>
        <div class="settings-form" style="max-width: none;">
          <div style="display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 16px; margin-bottom: 24px;">
            <div style="padding: 16px; border-radius: 12px; border: 1px solid var(--border); background: rgba(239, 68, 68, 0.08);">
              <div style="font-size: 12px; color: var(--text-muted); margin-bottom: 6px;">Alertes actives</div>
              <div style="font-size: 28px; font-weight: 700; font-family: 'Outfit', sans-serif;"><%= activeModerationNotices.length %></div>
            </div>
            <div style="padding: 16px; border-radius: 12px; border: 1px solid var(--border); background: rgba(245, 158, 11, 0.08);">
              <div style="font-size: 12px; color: var(--text-muted); margin-bottom: 6px;">Profils signales</div>
              <div style="font-size: 28px; font-weight: 700; font-family: 'Outfit', sans-serif;"><%= activeProfileModerationCount %></div>
            </div>
            <div style="padding: 16px; border-radius: 12px; border: 1px solid var(--border); background: rgba(59, 130, 246, 0.08);">
              <div style="font-size: 12px; color: var(--text-muted); margin-bottom: 6px;">Posts signales</div>
              <div style="font-size: 28px; font-weight: 700; font-family: 'Outfit', sans-serif;"><%= activePostModerationCount %></div>
            </div>
          </div>

          <div style="margin-bottom: 24px;">
            <div style="font-family: 'Outfit', sans-serif; font-size: 16px; font-weight: 600; margin-bottom: 12px;">Dernieres alertes admin</div>
            <% if (moderationNoticesList.length > 0) { %>
              <div class="table-search-row" style="padding-left: 0; padding-right: 0; padding-bottom: 14px; justify-content: flex-start;">
                <label class="search-field">
                  <i data-lucide="search"></i>
                  <input type="search" data-table-search-input data-table-target="adminModerationAlertsTable" placeholder="Rechercher dans les alertes...">
                </label>
              </div>
              <div style="overflow-x: auto;">
                <table id="adminModerationAlertsTable">
                  <thead>
                    <tr>
                      <th>Date</th>
                      <th>Type</th>
                      <th>Utilisateur</th>
                      <th>Raison</th>
                      <th>Detail</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% moderationNoticesList.forEach((notice) => { %>
                      <%
                        const noticeTypeLabel = notice.target_type === 'post'
                          ? 'Post'
                          : notice.notice_kind === 'restriction'
                            ? 'Restriction compte'
                            : 'Profil';
                        const noticeBadgeClass = notice.target_type === 'post'
                          ? 'blocked'
                          : notice.notice_kind === 'restriction'
                            ? 'blocked'
                            : 'paused';
                      %>
                      <tr>
                        <td><%= new Date(notice.updated_at || notice.created_at).toLocaleString() %></td>
                        <td>
                          <span class="badge <%= noticeBadgeClass %>">
                            <%= noticeTypeLabel %>
                          </span>
                        </td>
                        <td>
                          <div style="font-weight: 600;">@<%= notice.target_username %></div>
                          <div style="font-size: 12px; color: var(--text-muted);"><%= notice.target_name || 'Utilisateur' %></div>
                        </td>
                        <td><%= notice.reason %></td>
                        <td style="color: var(--text-muted);">
                          <%= notice.details || (notice.target_type === 'post' && notice.post_content ? String(notice.post_content).slice(0, 90) : 'Sans detail') %>
                        </td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            <% } else { %>
              <p style="margin: 0; color: var(--text-muted);">Aucune alerte de moderation admin pour le moment.</p>
            <% } %>
          </div>

          <!-- USER REPORTS DASHBOARD -->
          <div style="margin-bottom: 24px;">
            <div style="font-family: 'Outfit', sans-serif; font-size: 16px; font-weight: 600; margin-bottom: 12px;">Signalements des utilisateurs (<%= typeof postReports !== 'undefined' ? postReports.length : 0 %>)</div>
            <% if (typeof postReports !== 'undefined' && postReports.length > 0) { %>
              <div style="overflow-x: auto;">
                <table>
                  <thead>
                    <tr>
                      <th>Date</th>
                      <th>Auteur</th>
                      <th>Rapporteur</th>
                      <th>Raison</th>
                      <th>Détails</th>
                      <th>Contenu du Post</th>
                      <th>Action</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% postReports.forEach((report) => { %>
                      <tr id="report-row-<%= report.id %>">
                        <td><%= new Date(report.created_at).toLocaleString() %></td>
                        <td>
                          <strong>@<%= report.author_username %></strong>
                          <div style="font-size: 11px; color: var(--text-muted);">Total signalements : <%= report.author_report_count %></div>
                        </td>
                        <td>@<%= report.reporter_username %></td>
                        <td>
                          <span class="badge blocked" style="text-transform: capitalize;">
                            <%= report.reason %>
                          </span>
                        </td>
                        <td style="max-width: 150px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"><%= report.details || 'Aucun' %></td>
                        <td style="max-width: 200px; font-size: 12px;">
                          <% if (report.post_image_url) { %>
                            <% if (String(report.post_media_type || '').toLowerCase() === 'video') { %>
                              <div style="display: flex; align-items: center; gap: 8px;">
                                <video src="<%= report.post_image_url %>" style="width: 40px; height: 40px; object-fit: cover; border-radius: 4px;" muted></video>
                                <span style="font-size: 11px; color: var(--text-muted);"><%= report.post_content ? report.post_content.slice(0, 30) : 'Vidéo' %></span>
                              </div>
                            <% } else { %>
                              <div style="display: flex; align-items: center; gap: 8px;">
                                <img src="<%= report.post_image_url %>" style="width: 40px; height: 40px; object-fit: cover; border-radius: 4px;">
                                <span style="font-size: 11px; color: var(--text-muted);"><%= report.post_content ? report.post_content.slice(0, 30) : 'Image' %></span>
                              </div>
                            <% } %>
                          <% } else { %>
                            <%= report.post_content ? (report.post_content.length > 50 ? report.post_content.slice(0, 50) + '...' : report.post_content) : 'Aucun' %>
                          <% } %>
                        </td>
                        <td>
                          <div style="display: flex; gap: 6px;">
                            <button onclick="handleReportAction(<%= report.id %>, 'dismiss', null)" class="btn" style="padding: 6px 12px; font-size: 12px; background: var(--bg-card); border: 1px solid var(--border); color: var(--text-main);">Ignorer</button>
                            <button onclick="handleReportAction(<%= report.id %>, 'delete-post', <%= report.post_id %>)" class="btn" style="padding: 6px 12px; font-size: 12px; background: var(--warning); border: none; color: black;">Supprimer Post</button>
                            <button onclick="handleReportAction(<%= report.id %>, 'block-user', <%= report.author_id %>)" class="btn" style="padding: 6px 12px; font-size: 12px; background: var(--danger); border: none; color: white;">Bloquer Auteur</button>
                          </div>
                        </td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            <% } else { %>
              <p style="margin: 0; color: var(--text-muted);">Aucun signalement d'utilisateur en attente.</p>
            <% } %>
          </div>

          <div style="font-family: 'Outfit', sans-serif; font-size: 16px; font-weight: 600; margin-bottom: 12px;">Tous les posts a analyser</div>
          <% if (postsForReviewList.length > 0) { %>
            <div class="post-review-grid">
              <% postsForReviewList.forEach((post) => { %>
                <% const previewMedia = post.thumbnail_url || post.image_url || post.image_url_2 || post.image_url_3 || post.image_url_4 || ''; %>
                <% const trimmedContent = String(post.content || '').trim(); %>
                <article class="post-review-card">
                  <div style="display: flex; align-items: center; justify-content: space-between; gap: 12px;">
                    <div class="user-info" style="min-width: 0;">
                      <img src="<%= post.author_avatar || 'https://via.placeholder.com/150' %>" class="user-avatar" alt="Avatar">
                      <div style="min-width: 0;">
                        <div style="font-weight: 600;"><%= post.author_name || 'Utilisateur' %></div>
                        <div style="font-size: 12px; color: var(--text-muted);">@<%= post.author_username || 'unknown' %></div>
                      </div>
                    </div>
                    <span class="notice-chip"><i data-lucide="clock-3" style="width: 12px; height: 12px;"></i> <%= new Date(post.created_at).toLocaleDateString() %></span>
                  </div>

                  <div class="post-review-preview">
                    <% if (previewMedia && String(post.media_type || '').toLowerCase() === 'video') { %>
                      <video src="<%= previewMedia %>" muted playsinline preload="metadata"></video>
                    <% } else if (previewMedia) { %>
                      <img src="<%= previewMedia %>" alt="Apercu du post">
                    <% } else if (trimmedContent) { %>
                      <div class="post-review-copy" style="padding: 18px; width: 100%; color: var(--text-main);">
                        <%= trimmedContent.length > 220 ? `${trimmedContent.slice(0, 220)}...` : trimmedContent %>
                      </div>
                    <% } else { %>
                      <div class="post-review-copy" style="padding: 18px;">Post sans texte ni media.</div>
                    <% } %>
                  </div>

                  <div class="post-review-copy">
                    <%= trimmedContent ? (trimmedContent.length > 180 ? `${trimmedContent.slice(0, 180)}...` : trimmedContent) : 'Aucun texte pour ce post.' %>
                  </div>

                  <div class="post-review-stats">
                    <span><strong style="color: var(--text-main);"><%= Number(post.likes_count || 0) %></strong> j'aime</span>
                    <span><strong style="color: var(--text-main);"><%= Number(post.comments_count || 0) %></strong> commentaires</span>
                    <span><strong style="color: var(--text-main);"><%= Number(post.shares_count || 0) %></strong> partages</span>
                    <% if (Number(post.is_trade || 0) === 1) { %>
                      <span><strong style="color: var(--warning);">Post de trade</strong></span>
                    <% } %>
                  </div>

                  <form action="/admin/moderation/report-post" method="POST" class="mini-form" data-moderation-reason-form style="margin-top: 0; padding-top: 0; border-top: none;">
                    <input type="hidden" name="postId" value="<%= post.id %>">
                    <input type="hidden" name="redirectTo" value="<%= adminPaths.moderation || '/admin/moderation' %>">
                    <div class="mini-label">Signaler ce post</div>
                    <select name="reason" class="compact-select" data-moderation-reason-select required>
                      <option value="">Choisir une raison</option>
                      <% postModerationReasons.forEach((reason) => { %>
                        <option value="<%= reason %>"><%= reason %></option>
                      <% }) %>
                    </select>
                    <input type="text" name="custom_reason" class="compact-input" data-moderation-custom-reason maxlength="120" placeholder="Raison personnalisée" style="display: none;">
                    <input type="text" name="details" class="compact-input" maxlength="500" placeholder="Detail visible par l utilisateur">
                    <button type="submit" class="btn" style="background: var(--danger); width: fit-content;">Signaler le post</button>
                  </form>
                </article>
              <% }) %>
            </div>
          <% } else { %>
            <p style="margin: 0; color: var(--text-muted);">Aucun post disponible pour l analyse.</p>
          <% } %>
        </div>
      </div>
      <% } %>

      <!-- Balance Top-ups -->
      <% if (isPage('balances')) { %>
      <div class="section-card" id="balances">
        <div class="section-header">
          <div>
            <h3>Crédits des comptes</h3>
            <p>Alimentez un utilisateur ou l'ensemble de la base depuis l'interface admin.</p>
          </div>
        </div>
        <div class="settings-form" style="max-width: none; padding-bottom: 20px;">
          <div id="balanceTopupStatus" style="display: none; margin-bottom: 18px; padding: 12px 14px; border-radius: 8px; border: 1px solid var(--border); font-size: 13px; line-height: 1.45;"></div>

          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px;">
            <form action="/admin/balance-topup" method="POST" data-admin-balance-form data-admin-balance-scope="user" style="display: grid; gap: 12px; padding-right: 24px; border-right: 1px solid var(--border);">
              <input type="hidden" name="scope" value="user">
              <div style="font-family: 'Outfit', sans-serif; font-size: 16px; font-weight: 600; margin-bottom: 2px;">Créditer un utilisateur</div>
              <div class="form-group">
                <label>Pseudo ou email</label>
                <input type="text" name="user_lookup" placeholder="username or user@email.com" autocomplete="off" required>
              </div>
              <div class="form-group">
                <label>Compte à créditer</label>
                <select name="account_type" required>
                  <option value="deposit">Compte de dépôt</option>
                  <option value="withdrawal">Compte de retrait</option>
                  <option value="bonus">Compte bonus</option>
                </select>
              </div>
              <div class="form-group">
                <label>Montant ($)</label>
                <input type="number" name="amount" min="0.01" step="0.01" placeholder="25.00" required>
              </div>
              <div class="form-group">
                <label>Note du message</label>
                <input type="text" name="note" placeholder="Crédit plateforme">
              </div>
              <button type="submit" class="btn" style="width: fit-content;">Créditer l'utilisateur</button>
            </form>

            <form action="/admin/balance-topup" method="POST" data-admin-balance-form data-admin-balance-scope="all" style="display: grid; gap: 12px;">
              <input type="hidden" name="scope" value="all">
              <div style="font-family: 'Outfit', sans-serif; font-size: 16px; font-weight: 600; margin-bottom: 2px;">Créditer tous les utilisateurs</div>
              <div class="form-group">
                <label>Montant par utilisateur ($)</label>
                <input type="number" name="amount" min="0.01" step="0.01" placeholder="5.00" required>
              </div>
              <div class="form-group">
                <label>Compte à créditer</label>
                <select name="account_type" required>
                  <option value="deposit">Compte de dépôt</option>
                  <option value="withdrawal">Compte de retrait</option>
                  <option value="bonus">Compte bonus</option>
                </select>
              </div>
              <div class="form-group">
                <label>Note du message</label>
                <input type="text" name="note" placeholder="Bonus plateforme">
              </div>
              <button type="submit" class="btn" style="width: fit-content;">Créditer tous les utilisateurs</button>
            </form>
          </div>
        </div>
      </div>
      <% } %>

      <!-- Post Backgrounds Management -->
      <% if (isPage('backgrounds')) { %>
      <div class="section-card" id="backgrounds">
        <div class="section-header">
          <div>
            <h3>Gestion des fonds de posts</h3>
            <p>Ajoutez, monetisez et attribuez les fonds premium aux bons comptes de retrait.</p>
          </div>
        </div>
        <div style="padding: 24px; display: grid; grid-template-columns: 1fr 2fr; gap: 32px;">
          
          <!-- Add Background Form -->
          <div style="border-right: 1px solid var(--border); padding-right: 32px;">
            <h4 style="margin-top: 0; margin-bottom: 16px; font-family: 'Outfit', sans-serif;">Ajouter un nouveau fond</h4>
            <form action="/admin/background-add" method="POST" enctype="multipart/form-data">
              <div class="form-group">
                <label>Téléverser une image</label>
                <input type="file" name="bgFile" accept="image/*">
              </div>
              <div style="text-align: center; color: var(--text-muted); font-size: 13px; margin: 12px 0;">-- OR --</div>
              <div class="form-group">
                <label>URL de l'image</label>
                <input type="text" name="imageUrl" placeholder="https://images.unsplash.com/... or /assets/...">
              </div>
              
              <!-- Toggle paid -->
              <div style="display: flex; align-items: center; justify-content: space-between; background: rgba(47, 111, 237, 0.05); padding: 12px; border-radius: 12px; border: 1px solid var(--border); margin-bottom: 16px;">
                <div>
                  <div style="font-weight: 600; font-size: 14px;">Fond premium</div>
                  <div style="font-size: 11px; color: var(--text-muted);">Les utilisateurs paient avec leur solde de jetons pour l'utiliser.</div>
                </div>
                <input type="checkbox" name="isPaid" id="isPaidCheckbox" style="width: auto; cursor: pointer;" onchange="document.getElementById('priceInputGroup').style.display = this.checked ? 'block' : 'none';">
              </div>
              
              <div class="form-group" id="priceInputGroup" style="display: none;">
                <label>Prix ($ USD / équivalence jeton)</label>
                <input type="number" step="0.01" name="price" value="0.10" min="0.01">
              </div>

              <div class="form-group">
                <label>Créateur mentionné (optionnel)</label>
                <input type="text" name="creatorUserLookup" list="backgroundCreatorLookupList" placeholder="@pseudo ou email">
                <datalist id="backgroundCreatorLookupList">
                  <% users.forEach(user => { %>
                    <option value="@<%= user.username %>"><%= user.email %> - <%= user.first_name %> <%= user.last_name %></option>
                    <option value="<%= user.email %>">@<%= user.username %> - <%= user.first_name %> <%= user.last_name %></option>
                  <% }) %>
                </datalist>
                <div style="font-size: 11px; color: var(--text-muted); margin-top: 6px;">
                  Si vous choisissez un créateur, les paiements du fond premium vont sur son compte de retrait. Sinon, ils vont sur le compte admin.
                </div>
              </div>
              
              <button type="submit" class="btn" style="width: 100%;">Ajouter le fond</button>
            </form>
          </div>
          
          <!-- Backgrounds List Grid -->
          <div>
            <h4 style="margin-top: 0; margin-bottom: 16px; font-family: 'Outfit', sans-serif;">Fonds existants</h4>
            <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); gap: 16px; max-height: 450px; overflow-y: auto; padding-right: 8px;">
              <% backgrounds.forEach(bg => { %>
                <div style="background: var(--card-soft); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; display: flex; flex-direction: column; position: relative;">
                  <img src="<%= bg.image_url %>" style="width: 100%; height: 100px; object-fit: cover;" alt="Background">
                  <div style="padding: 8px; flex: 1; display: flex; flex-direction: column; justify-content: space-between;">
                    <div>
                      <% if (bg.is_paid) { %>
                        <span class="badge" style="background: rgba(245, 158, 11, 0.15); color: var(--warning); padding: 2px 6px; font-size: 10px;">$<%= parseFloat(bg.price).toFixed(2) %></span>
                      <% } else { %>
                        <span class="badge" style="background: rgba(16, 185, 129, 0.15); color: var(--success); padding: 2px 6px; font-size: 10px;">Gratuit</span>
                      <% } %>
                      <div style="font-size: 10px; color: var(--text-muted); margin-top: 6px;">
                        <%= bg.creator_user_id ? `Créateur : ${String(bg.creator_name || '').trim() || 'Inconnu'}${bg.creator_username ? ` (@${bg.creator_username})` : ''}` : 'Destinataire : compte admin' %>
                      </div>
                    </div>
                    <form action="/admin/background-delete" method="POST" onsubmit="return confirm('Supprimer ce fond ?');" style="margin-top: 8px;">
                      <input type="hidden" name="bgId" value="<%= bg.id %>">
                      <button type="submit" class="btn" style="background: var(--danger); width: 100%; padding: 4px 8px; font-size: 11px;">Supprimer</button>
                    </form>
                  </div>
                </div>
              <% }) %>
            </div>
          </div>
          
        </div>
      </div>
      <% } %>

      <!-- SMTP Settings -->
      <% if (isPage('rules')) { %>
      <div class="section-card" id="event-thresholds">
        <div class="section-header">
          <div>
            <h3>Regles globales et tarification</h3>
            <p>Definissez les seuils d'acces, la fenetre promo, les bonus de portee et le prix du token.</p>
          </div>
        </div>
        <div class="settings-form" style="max-width: none;">
          <div style="display: grid; grid-template-columns: repeat(2, minmax(280px, 1fr)); gap: 20px;">
            <div style="border: 1px solid var(--border); border-radius: 18px; padding: 20px; background: var(--card-soft);">
              <div style="font-family: 'Outfit', sans-serif; font-size: 18px; font-weight: 700; margin-bottom: 6px;">Seuil global</div>
              <div style="font-size: 13px; color: var(--text-muted); margin-bottom: 16px;">Appliquez une regle commune a tous les comptes.</div>
              <form action="/admin/event-thresholds" method="POST" style="display: grid; gap: 12px;">
                <input type="hidden" name="scope" value="global">
                <div class="form-group">
                  <label>Seuil global d'abonnés</label>
                  <input type="number" name="followers_threshold" min="0" step="1" value="1000">
                </div>
                <button type="submit" class="btn" style="width: fit-content;">Appliquer globalement</button>
              </form>
            </div>

            <div style="border: 1px solid var(--border); border-radius: 18px; padding: 20px; background: var(--card-soft);">
              <div style="font-family: 'Outfit', sans-serif; font-size: 18px; font-weight: 700; margin-bottom: 6px;">Seuil par utilisateur</div>
              <div style="font-size: 13px; color: var(--text-muted); margin-bottom: 16px;">Ajustez un cas particulier sans toucher au reste de la base.</div>
              <form action="/admin/event-thresholds" method="POST" style="display: grid; gap: 12px;">
                <input type="hidden" name="scope" value="user">
                <div class="form-group">
                  <label>ID utilisateur</label>
                  <input type="number" name="user_id" min="1" step="1" placeholder="16" required>
                </div>
                <div class="form-group">
                  <label>Seuil d'abonnés</label>
                  <input type="number" name="followers_threshold" min="0" step="1" value="1000" required>
                </div>
                <button type="submit" class="btn" style="width: fit-content;">Mettre à jour le seuil utilisateur</button>
              </form>
            </div>

            <div style="border: 1px solid var(--border); border-radius: 18px; padding: 20px; background: var(--card-soft);">
              <div style="font-family: 'Outfit', sans-serif; font-size: 18px; font-weight: 700; margin-bottom: 6px;">Promotion et portée</div>
              <div style="font-size: 13px; color: var(--text-muted); margin-bottom: 16px;">Définissez la fenêtre promo et les bonus de visibilité.</div>
              <form action="/admin/settings" method="POST" style="display: grid; gap: 12px;">
                <div class="form-group">
                  <label>Fenêtre promo nouveau compte (jours)</label>
                  <input type="number" name="new_user_promo_days" min="1" step="1" value="<%= Number(newUserPromoDays || 30) %>">
                </div>
                <div class="form-group">
                  <label>Vues de base par jour pour les posts/shorts des nouveaux comptes</label>
                  <input type="number" name="new_user_daily_view_base" min="0" step="1" value="<%= Number(newUserDailyViewBase || 1000) %>">
                </div>
                <div class="form-group">
                  <label>Vues quotidiennes supplémentaires par hashtag payant utilisé</label>
                  <input type="number" name="paid_hashtag_view_bonus" min="0" step="1" value="<%= Number(paidHashtagViewBonus || 50) %>">
                </div>
                <div class="form-group">
                  <label>Vues quotidiennes supplémentaires par tranche de 1 $ de fond premium</label>
                  <input type="number" name="paid_background_view_bonus_per_dollar" min="0" step="1" value="<%= Number(paidBackgroundViewBonusPerDollar || 100) %>">
                </div>
                <button type="submit" class="btn" style="width: fit-content;">Enregistrer les règles promo</button>
              </form>
            </div>

            <div style="border: 1px solid var(--border); border-radius: 18px; padding: 20px; background: var(--card-soft);">
              <div style="font-family: 'Outfit', sans-serif; font-size: 18px; font-weight: 700; margin-bottom: 6px;">Tarification et frais</div>
              <div style="font-size: 13px; color: var(--text-muted); margin-bottom: 16px;">Gérez le prix du jeton, l'accès aux événements et les retraits.</div>
              <form action="/admin/settings" method="POST" style="display: grid; gap: 12px;">
                <div class="form-group">
                  <label>Frais de déblocage des événements ($)</label>
                  <input type="number" name="events_unlock_fee" min="0" step="0.01" value="<%= Number(eventsUnlockFee || 0).toFixed(2) %>">
                </div>
                <div class="form-group">
                  <label>Prix du jeton (USDT par jeton)</label>
                  <input type="number" name="token_price_usd" min="0.0001" step="0.0001" value="<%= Number(tokenPriceUsd || 0.1).toFixed(4) %>">
                </div>
                <div class="form-group">
                  <label>Montant minimum de retrait ($)</label>
                  <input type="number" name="min_withdrawal_amount" min="0.01" step="0.01" value="<%= Number(minWithdrawalAmount || 50).toFixed(2) %>">
                </div>
                <div class="form-group">
                  <label>Frais de retrait (%)</label>
                  <input type="number" name="withdrawal_fee_percent" min="0" max="100" step="0.1" value="<%= Number(withdrawalFeePercent || 30).toFixed(1) %>">
                </div>
                <button type="submit" class="btn" style="width: fit-content;">Enregistrer les paramètres tarifaires</button>
              </form>
            </div>

            <div style="border: 1px solid var(--border); border-radius: 18px; padding: 20px; background: var(--card-soft);">
              <div style="font-family: 'Outfit', sans-serif; font-size: 18px; font-weight: 700; margin-bottom: 6px;">Boutons de téléchargement d'applications</div>
              <div style="font-size: 13px; color: var(--text-muted); margin-bottom: 16px;">Affichez ou masquez individuellement les boutons de téléchargement d'applications sur la page de connexion.</div>
              <form action="/admin/settings" method="POST" style="display: grid; gap: 12px;">
                <div class="form-group">
                  <label>Bouton de téléchargement Android</label>
                  <select name="show_app_download_android" style="padding: 10px; border-radius: 8px; border: 1px solid var(--border); background: var(--bg); color: var(--text); font-family: inherit;">
                    <option value="1" <%= Number(showAppDownloadAndroid) === 1 ? 'selected' : '' %>>Afficher</option>
                    <option value="0" <%= Number(showAppDownloadAndroid) === 0 ? 'selected' : '' %>>Masquer</option>
                  </select>
                </div>
                <div class="form-group">
                  <label>Bouton de téléchargement iPhone</label>
                  <select name="show_app_download_ios" style="padding: 10px; border-radius: 8px; border: 1px solid var(--border); background: var(--bg); color: var(--text); font-family: inherit;">
                    <option value="1" <%= Number(showAppDownloadIos) === 1 ? 'selected' : '' %>>Afficher</option>
                    <option value="0" <%= Number(showAppDownloadIos) === 0 ? 'selected' : '' %>>Masquer</option>
                  </select>
                </div>
                <button type="submit" class="btn" style="width: fit-content;">Enregistrer les paramètres d'affichage</button>
              </form>
            </div>
          </div>
        </div>
      </div>
      <% } %>

      <% if (isPage('kyc')) { %>
      <div class="section-card" id="kyc-requests">
        <div class="section-header">
          <div>
            <h3>Requêtes KYC en attente</h3>
            <p>Validez ou refusez les demandes de vérification d'identité en cours.</p>
          </div>
        </div>
        <div class="settings-form" style="padding: 16px;">
          <% if (kycRequests && kycRequests.length > 0) { %>
            <div style="display: grid; gap: 20px;">
              <% kycRequests.forEach((request) => { %>
                <div style="border: 1px solid var(--border); border-radius: 12px; padding: 18px; background: rgba(255,255,255,0.03);">
                  <div style="display: flex; justify-content: space-between; gap: 12px; flex-wrap: wrap; margin-bottom: 12px;">
                    <div>
                      <div style="font-weight: 700; font-size: 16px; color: var(--text-main);"><%= request.name %></div>
                      <div style="font-size: 13px; color: var(--text-muted);">@<%= request.username %> · <%= request.email %></div>
                    </div>
                    <div style="display: flex; gap: 8px; align-items: center;">
                      <span class="badge" style="background: rgba(239, 68, 68, 0.15); color: #ef4444; font-weight: 600; text-transform: uppercase; font-size: 11px;">
                        <%= request.request_type %>
                      </span>
                      <span class="badge" style="background: rgba(59, 130, 246, 0.12); color: var(--primary); font-weight: 600; text-transform: uppercase; font-size: 11px;">
                        <%= request.status %>
                      </span>
                    </div>
                  </div>

                  <!-- Side-by-side Images and AI Details -->
                  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; margin-bottom: 16px;">
                    <!-- Document Thumbnail -->
                    <div style="display: flex; flex-direction: column; gap: 6px;">
                      <span style="font-size: 12px; font-weight: 600; color: var(--text-muted);">Document d'identité :</span>
                      <% if (request.document_url) { %>
                        <a href="<%= request.document_url %>" target="_blank" style="display: block; border-radius: 8px; overflow: hidden; border: 1px solid var(--border); background: #000; height: 140px;">
                          <img src="<%= request.document_url %>" style="width: 100%; height: 100%; object-fit: cover;" alt="Document">
                        </a>
                      <% } else { %>
                        <div style="height: 140px; background: var(--card-soft); border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 12px; color: var(--text-muted);">Aucun document</div>
                      <% } %>
                    </div>

                    <!-- Selfie Thumbnail -->
                    <div style="display: flex; flex-direction: column; gap: 6px;">
                      <span style="font-size: 12px; font-weight: 600; color: var(--text-muted);">Selfie en direct :</span>
                      <% if (request.selfie_url) { %>
                        <a href="<%= request.selfie_url %>" target="_blank" style="display: block; border-radius: 8px; overflow: hidden; border: 1px solid var(--border); background: #000; height: 140px;">
                          <img src="<%= request.selfie_url %>" style="width: 100%; height: 100%; object-fit: cover;" alt="Selfie">
                        </a>
                      <% } else { %>
                        <div style="height: 140px; background: var(--card-soft); border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 12px; color: var(--text-muted);">Aucun selfie</div>
                      <% } %>
                    </div>

                    <!-- AI Match Scores -->
                    <div style="background: rgba(255,255,255,0.02); border-radius: 8px; padding: 12px; border: 1px solid var(--border); display: flex; flex-direction: column; gap: 8px;">
                      <div style="font-weight: 600; font-size: 13px; border-bottom: 1px solid var(--border); padding-bottom: 4px;">Scores d'analyse IA :</div>
                      <div style="font-size: 12px;">Score de correspondance visage : 
                        <strong style="color: <%= (request.face_match_score !== null && request.face_match_score >= 80) ? '#22c55e' : '#f59e0b' %>">
                          <%= request.face_match_score !== null ? request.face_match_score + '%' : 'N/A' %>
                        </strong>
                      </div>
                      <div style="font-size: 12px;">Score global de vérification : 
                        <strong style="color: <%= (request.verification_score !== null && request.verification_score >= 80) ? '#22c55e' : '#f59e0b' %>">
                          <%= request.verification_score !== null ? request.verification_score + '%' : 'N/A' %>
                        </strong>
                      </div>
                      <div style="font-size: 11px; color: var(--text-muted); line-height: 1.3;">
                        Notes : <%= request.verification_notes || 'Aucune note.' %>
                      </div>
                    </div>
                  </div>

                  <!-- OCR Excerpt if exists -->
                  <% if (request.ocr_text_excerpt) { %>
                    <div style="background: rgba(0,0,0,0.2); border-radius: 6px; padding: 8px 12px; margin-bottom: 16px; border-left: 3px solid var(--primary);">
                      <div style="font-size: 11px; font-weight: 600; color: var(--text-muted); margin-bottom: 4px;">Extrait de texte OCR détecté :</div>
                      <div style="font-size: 12px; color: var(--text-main); font-family: monospace; max-height: 80px; overflow-y: auto; white-space: pre-wrap;"><%= request.ocr_text_excerpt %></div>
                    </div>
                  <% } %>

                  <div style="display: flex; gap: 10px; flex-wrap: wrap;">
                    <form action="/admin/kyc-review" method="POST">
                      <input type="hidden" name="request_id" value="<%= request.id %>">
                      <input type="hidden" name="action" value="approve">
                      <button type="submit" class="btn">Approuver</button>
                    </form>
                    <form action="/admin/kyc-review" method="POST">
                      <input type="hidden" name="request_id" value="<%= request.id %>">
                      <input type="hidden" name="action" value="reject">
                      <button type="submit" class="btn" style="background: var(--danger);">Refuser</button>
                    </form>
                  </div>
                </div>
              <% }) %>
            </div>
          <% } else { %>
            <p style="color: var(--text-muted); margin: 0;">Aucune requête KYC en attente pour le moment.</p>
          <% } %>
        </div>
      </div>

      <!-- Historique des KYC révisés -->
      <div class="section-card" style="margin-top: 24px;">
        <div class="section-header">
          <h3>Historique des KYC révisés</h3>
          <p>Consultez les dernières requêtes KYC traitées automatiquement ou manuellement.</p>
        </div>
        <div style="padding: 16px; overflow-x: auto;">
          <% if (reviewedKycRequests && reviewedKycRequests.length > 0) { %>
            <table class="data-table" style="width: 100%; border-collapse: collapse; font-size: 13px;">
              <thead>
                <tr style="border-bottom: 1px solid var(--border); text-align: left;">
                  <th style="padding: 8px;">Utilisateur</th>
                  <th style="padding: 8px;">Type</th>
                  <th style="padding: 8px;">Date Demande</th>
                  <th style="padding: 8px;">Statut</th>
                  <th style="padding: 8px;">Détails & Documents</th>
                </tr>
              </thead>
              <tbody>
                <% reviewedKycRequests.forEach((reqKyc) => { %>
                  <tr style="border-bottom: 1px solid var(--border);">
                    <td style="padding: 8px;">
                      <div style="font-weight: 600;"><%= reqKyc.name %></div>
                      <div style="font-size: 11px; color: var(--text-muted);">@<%= reqKyc.username %></div>
                    </td>
                    <td style="padding: 8px;">
                      <span style="font-size: 11px; font-weight: 600; text-transform: uppercase;"><%= reqKyc.request_type %></span>
                    </td>
                    <td style="padding: 8px; color: var(--text-muted);">
                      <%= new Date(reqKyc.created_at).toLocaleDateString('fr-FR', {hour: '2-digit', minute:'2-digit'}) %>
                    </td>
                    <td style="padding: 8px;">
                      <span class="badge" style="background: <%= reqKyc.status === 'approved' ? 'rgba(34, 197, 94, 0.12)' : 'rgba(239, 68, 68, 0.12)' %>; color: <%= reqKyc.status === 'approved' ? '#22c55e' : '#ef4444' %>;">
                        <%= reqKyc.status %>
                      </span>
                    </td>
                    <td style="padding: 8px;">
                      <div style="display: flex; gap: 8px; align-items: center;">
                        <% if (reqKyc.document_url) { %>
                          <a href="<%= reqKyc.document_url %>" target="_blank" style="color: var(--primary); text-decoration: underline;">Doc</a>
                        <% } %>
                        <% if (reqKyc.selfie_url) { %>
                          <a href="<%= reqKyc.selfie_url %>" target="_blank" style="color: var(--primary); text-decoration: underline;">Selfie</a>
                        <% } %>
                        <span style="font-size: 11px; color: var(--text-muted);">(Match: <%= reqKyc.face_match_score || 'N/A' %>%)</span>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          <% } else { %>
            <p style="color: var(--text-muted); margin: 0;">Aucun historique de KYC disponible.</p>
          <% } %>
        </div>
      </div>
      <% } %>

      <!-- Disputes Section -->
      <% if (isPage('disputes')) { %>
      <div class="section-card" id="disputes-management">
        <div class="section-header">
          <div>
            <h3>Gestion des litiges</h3>
            <p>Arbitrez les litiges du marché P2P et traitez les blocages de compte contestés.</p>
          </div>
        </div>

        <!-- Tab Controls -->
        <div style="display: flex; border-bottom: 1px solid var(--border); background: rgba(255,255,255,0.01); flex-wrap: wrap;">
          <button onclick="switchDisputeTab('account-disputes')" id="tabBtn-account-disputes" class="tab-button active" style="flex: 1; min-width: 150px; padding: 14px; background: none; border: none; border-bottom: 2px solid var(--primary); color: var(--text-main); font-weight: 600; cursor: pointer; transition: all 0.2s; font-size: 14px;">
            Litiges Comptes Bloqués (<%= accountDisputes ? accountDisputes.length : 0 %>)
          </button>
          <button onclick="switchDisputeTab('p2p-disputes')" id="tabBtn-p2p-disputes" class="tab-button" style="flex: 1; min-width: 150px; padding: 14px; background: none; border: none; border-bottom: 2px solid transparent; color: var(--text-muted); font-weight: 600; cursor: pointer; transition: all 0.2s; font-size: 14px;">
            Litiges Marché P2P (<%= p2pDisputes ? p2pDisputes.length : 0 %>)
          </button>
          <button onclick="switchDisputeTab('all-blocked-accounts')" id="tabBtn-all-blocked-accounts" class="tab-button" style="flex: 1; min-width: 150px; padding: 14px; background: none; border: none; border-bottom: 2px solid transparent; color: var(--text-muted); font-weight: 600; cursor: pointer; transition: all 0.2s; font-size: 14px;">
            Tous les Comptes Bloqués (<%= blockedAccountsList.length %>)
          </button>
        </div>

        <div style="padding: 20px;">
          <!-- Tab 1: Account Block Disputes -->
          <div id="disputeTab-account-disputes" class="dispute-tab-content">
            <% if (accountDisputes && accountDisputes.length > 0) { %>
              <div style="display: grid; gap: 16px;">
                <% accountDisputes.forEach((dispute) => { %>
                  <div style="border: 1px solid var(--border); border-radius: 12px; padding: 16px; background: rgba(255,255,255,0.02); display: flex; flex-direction: column; gap: 12px;">
                    <div style="display: flex; justify-content: space-between; align-items: start; flex-wrap: wrap; gap: 8px;">
                      <div>
                        <div style="font-weight: 700; font-size: 15px;"><%= dispute.user_name %></div>
                        <div style="font-size: 12px; color: var(--text-muted);">@<%= dispute.username %> · <%= dispute.email %></div>
                      </div>
                      <span class="badge" style="background: <%= dispute.status === 'pending' ? 'rgba(245, 158, 11, 0.12)' : 'rgba(34, 197, 94, 0.12)' %>; color: <%= dispute.status === 'pending' ? '#f59e0b' : '#22c55e' %>; font-size: 11px;">
                        <%= dispute.status === 'pending' ? 'En attente' : 'Résolu' %>
                      </span>
                    </div>

                    <div style="background: rgba(0,0,0,0.15); padding: 12px; border-radius: 8px; border-left: 3px solid var(--warning); font-size: 13px; line-height: 1.5; color: var(--text-main);">
                      <div style="font-size: 11px; color: var(--text-muted); font-weight: 600; margin-bottom: 4px;">Message de contestation :</div>
                      <%= dispute.message || 'Aucun message fourni.' %>
                    </div>

                    <div style="font-size: 11px; color: var(--text-muted);">
                      Soumis le : <%= new Date(dispute.created_at).toLocaleString('fr-FR') %>
                    </div>

                    <% if (dispute.userKyc) { %>
                      <div style="background: rgba(255,255,255,0.01); border: 1px solid var(--border); border-radius: 8px; padding: 12px; margin-top: 8px;">
                        <div style="font-weight: 600; font-size: 13px; margin-bottom: 8px; color: var(--primary);">Document KYC de <%= dispute.user_name %> :</div>
                        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 12px;">
                          <!-- Document Thumbnail -->
                          <div style="display: flex; flex-direction: column; gap: 4px;">
                            <span style="font-size: 11px; color: var(--text-muted);">Document :</span>
                            <% if (dispute.userKyc.document_url) { %>
                              <a href="<%= dispute.userKyc.document_url %>" target="_blank" style="display: block; border-radius: 6px; overflow: hidden; border: 1px solid var(--border); background: #000; height: 100px;">
                                <img src="<%= dispute.userKyc.document_url %>" style="width: 100%; height: 100%; object-fit: cover;" alt="Document">
                              </a>
                            <% } else { %>
                              <div style="height: 100px; background: rgba(255,255,255,0.03); border-radius: 6px; display: flex; align-items: center; justify-content: center; font-size: 11px; color: var(--text-muted);">Aucun document</div>
                            <% } %>
                          </div>
                          <!-- Selfie Thumbnail -->
                          <div style="display: flex; flex-direction: column; gap: 4px;">
                            <span style="font-size: 11px; color: var(--text-muted);">Selfie :</span>
                            <% if (dispute.userKyc.selfie_url) { %>
                              <a href="<%= dispute.userKyc.selfie_url %>" target="_blank" style="display: block; border-radius: 6px; overflow: hidden; border: 1px solid var(--border); background: #000; height: 100px;">
                                <img src="<%= dispute.userKyc.selfie_url %>" style="width: 100%; height: 100%; object-fit: cover;" alt="Selfie">
                              </a>
                            <% } else { %>
                              <div style="height: 100px; background: rgba(255,255,255,0.03); border-radius: 6px; display: flex; align-items: center; justify-content: center; font-size: 11px; color: var(--text-muted);">Aucun selfie</div>
                            <% } %>
                          </div>
                          <!-- Info -->
                          <div style="font-size: 12px; display: flex; flex-direction: column; justify-content: center; gap: 4px;">
                            <div><strong>Nom soumis :</strong> <%= dispute.userKyc.submitted_full_name || 'N/A' %></div>
                            <div><strong>Né(e) le :</strong> <%= dispute.userKyc.submitted_dob || 'N/A' %></div>
                            <div><strong>Email :</strong> <%= dispute.userKyc.submitted_email || 'N/A' %></div>
                          </div>
                        </div>
                      </div>
                    <% } %>

                    <% if (dispute.conflictingKyc) { %>
                      <div style="background: rgba(239, 68, 68, 0.05); border: 1px solid rgba(239, 68, 68, 0.2); border-radius: 8px; padding: 12px; margin-top: 8px;">
                        <div style="font-weight: 700; font-size: 13px; margin-bottom: 8px; color: #ef4444; display: flex; align-items: center; gap: 6px;">
                          <span>⚠️</span> Conflit KYC détecté avec <%= dispute.conflictingKyc.name %> (@<%= dispute.conflictingKyc.username %>)
                        </div>
                        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 12px;">
                          <!-- Document Thumbnail -->
                          <div style="display: flex; flex-direction: column; gap: 4px;">
                            <span style="font-size: 11px; color: var(--text-muted);">Document conflit :</span>
                            <% if (dispute.conflictingKyc.document_url) { %>
                              <a href="<%= dispute.conflictingKyc.document_url %>" target="_blank" style="display: block; border-radius: 6px; overflow: hidden; border: 1px solid rgba(239, 68, 68, 0.2); background: #000; height: 100px;">
                                <img src="<%= dispute.conflictingKyc.document_url %>" style="width: 100%; height: 100%; object-fit: cover;" alt="Document conflit">
                              </a>
                            <% } else { %>
                              <div style="height: 100px; background: rgba(255,255,255,0.03); border-radius: 6px; display: flex; align-items: center; justify-content: center; font-size: 11px; color: var(--text-muted);">Aucun document</div>
                            <% } %>
                          </div>
                          <!-- Selfie Thumbnail -->
                          <div style="display: flex; flex-direction: column; gap: 4px;">
                            <span style="font-size: 11px; color: var(--text-muted);">Selfie conflit :</span>
                            <% if (dispute.conflictingKyc.selfie_url) { %>
                              <a href="<%= dispute.conflictingKyc.selfie_url %>" target="_blank" style="display: block; border-radius: 6px; overflow: hidden; border: 1px solid rgba(239, 68, 68, 0.2); background: #000; height: 100px;">
                                <img src="<%= dispute.conflictingKyc.selfie_url %>" style="width: 100%; height: 100%; object-fit: cover;" alt="Selfie conflit">
                              </a>
                            <% } else { %>
                              <div style="height: 100px; background: rgba(255,255,255,0.03); border-radius: 6px; display: flex; align-items: center; justify-content: center; font-size: 11px; color: var(--text-muted);">Aucun selfie</div>
                            <% } %>
                          </div>
                          <!-- Info -->
                          <div style="font-size: 12px; display: flex; flex-direction: column; justify-content: center; gap: 4px;">
                            <div><strong>Nom soumis :</strong> <%= dispute.conflictingKyc.submitted_full_name || 'N/A' %></div>
                            <div><strong>Né(e) le :</strong> <%= dispute.conflictingKyc.submitted_dob || 'N/A' %></div>
                            <div><strong>Email :</strong> <%= dispute.conflictingKyc.submitted_email || 'N/A' %></div>
                          </div>
                        </div>
                      </div>
                    <% } %>

                    <% if (dispute.status === 'pending') { %>
                      <div style="display: flex; gap: 10px; margin-top: 8px; flex-wrap: wrap;">
                        <form action="/admin/disputes/resolve-account" method="POST">
                          <input type="hidden" name="dispute_id" value="<%= dispute.id %>">
                          <input type="hidden" name="action" value="approve">
                          <button type="submit" class="btn">Approuver & Débloquer</button>
                        </form>
                        <form action="/admin/disputes/resolve-account" method="POST">
                          <input type="hidden" name="dispute_id" value="<%= dispute.id %>">
                          <input type="hidden" name="action" value="reverify">
                          <button type="submit" class="btn" style="background: var(--warning); color: #000;">Autoriser à revérifier</button>
                        </form>
                        <form action="/admin/disputes/resolve-account" method="POST">
                          <input type="hidden" name="dispute_id" value="<%= dispute.id %>">
                          <input type="hidden" name="action" value="reject">
                          <button type="submit" class="btn" style="background: var(--danger);">Rejeter la contestation</button>
                        </form>
                      </div>
                    <% } %>
                  </div>
                <% }) %>
              </div>
            <% } else { %>
              <p style="color: var(--text-muted); margin: 0; text-align: center; padding: 20px;">Aucun litige de compte bloqué en attente.</p>
            <% } %>
          </div>

          <!-- Tab 2: P2P Disputes -->
          <div id="disputeTab-p2p-disputes" class="dispute-tab-content" style="display: none;">
            <% if (p2pDisputes && p2pDisputes.length > 0) { %>
              <div style="display: grid; gap: 16px;">
                <% p2pDisputes.forEach((order) => { %>
                  <div style="border: 1px solid var(--border); border-radius: 12px; padding: 16px; background: rgba(255,255,255,0.02); display: flex; flex-direction: column; gap: 12px;">
                    <div style="display: flex; justify-content: space-between; align-items: start; flex-wrap: wrap; gap: 8px;">
                      <div>
                        <div style="font-weight: 700; font-size: 15px;">Ordre #<%= order.id %> · Litige Marché P2P</div>
                        <div style="font-size: 12px; color: var(--text-muted);">
                          Offre #<%= order.offer_id %> (<%= order.offer_type %>) · Actif : <strong><%= order.amount %> <%= order.asset_code %></strong> pour <strong><%= order.total_price %> USDT</strong>
                        </div>
                      </div>
