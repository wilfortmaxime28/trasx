    const usdFormatter = new Intl.NumberFormat('fr-FR', { style: 'currency', currency: 'USD', maximumFractionDigits: 2 });
    const chartState = { period: 'daily' };

    const escapeHtml = (value) => String(value ?? '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');

    const formatTrendValue = (value, unit, short = false) => {
      const numericValue = Number(value || 0);
      if (unit === 'token') {
        return short
          ? `${numericValue.toFixed(2).replace(/\.?0+$/, '')} tok`
          : `${numericValue.toFixed(4).replace(/\.?0+$/, '')} tokens`;
      }
      if (unit === 'count') {
        return short
          ? `${Math.round(numericValue)}`
          : `${Math.round(numericValue)} comptes`;
      }
      if (short) {
        return usdFormatter.format(numericValue).replace(',00', '');
      }
      return usdFormatter.format(numericValue);
    };

    const renderTrendCards = (container, groupData) => {
      if (!container) return;

      const labels = Array.isArray(groupData?.labels) ? groupData.labels : [];
      const seriesList = Array.isArray(groupData?.series) ? groupData.series : [];
      if (!labels.length || !seriesList.length) {
        container.innerHTML = '<div class="account-trend-card"><div class="account-trend-head"><div><h5>Aucune donnée</h5><p>Les graphiques apparaîtront ici dès que des mouvements seront enregistrés.</p></div></div></div>';
        return;
      }

      const barsClass = labels.length <= 5
        ? 'account-trend-bars is-wide'
        : labels.length === 6
          ? 'account-trend-bars is-compact'
          : 'account-trend-bars';

      container.innerHTML = seriesList.map((series) => {
        const values = Array.isArray(series.values) ? series.values.map((value) => Number(value || 0)) : [];
        const maxValue = Math.max(...values, 0);
        const bars = labels.map((label, index) => {
          const value = Number(values[index] || 0);
          const height = maxValue > 0 ? Math.max(10, Math.round((value / maxValue) * 110)) : 8;
          return `
            <div class="account-trend-bar">
              <div class="account-trend-bar-value">${escapeHtml(formatTrendValue(value, series.unit, true))}</div>
              <div class="account-trend-bar-fill" style="height: ${height}px; background: ${escapeHtml(series.color || 'var(--primary)')};"></div>
              <div class="account-trend-bar-label">${escapeHtml(label)}</div>
            </div>
          `;
        }).join('');

        return `
          <article class="account-trend-card">
            <div class="account-trend-head">
              <div>
                <h5>${escapeHtml(series.label || 'Compte')}</h5>
                <p>Progression ${chartState.period === 'daily' ? 'journalière' : chartState.period === 'monthly' ? 'mensuelle' : 'annuelle'}</p>
              </div>
              <span class="account-trend-dot" style="background: ${escapeHtml(series.color || 'var(--primary)')};"></span>
            </div>
            <div class="account-trend-current">
              <strong>${escapeHtml(formatTrendValue(series.currentValue || 0, series.unit, false))}</strong>
              <span>actuel</span>
            </div>
            <div class="${barsClass}">
              ${bars}
            </div>
          </article>
        `;
      }).join('');
    };

    const renderAccountCharts = () => {
