              <div style="display: flex; justify-content: space-between; gap: 12px; font-size: 13px;">
                <span style="color: var(--text-muted);">Shorts</span>
                <strong><%= officialSeedStats.mediaLibrary.shortsSummaryText %></strong>
              </div>
              <div style="display: flex; justify-content: space-between; gap: 12px; font-size: 13px;">
                <span style="color: var(--text-muted);">Status</span>
                <strong><%= officialSeedStats.mediaLibrary.statusSummaryText %></strong>
              </div>
            </div>
            <div style="margin-top: 14px; font-size: 12px; color: var(--text-muted); line-height: 1.5;">
              Les comptes créés sont marqués <code>account_type = official_seed</code> et leurs contenus sont enregistrés avec <code>source = official_seed</code>.
            </div>
            <div style="margin-top: 8px; font-size: 12px; color: var(--text-muted); line-height: 1.5;">
              Les photos de profil et les médias Internet utilisent la clé Pexels enregistrée dans le dashboard admin.
            </div>
          </div>

          <div style="padding: 18px; border-radius: 18px; border: 1px solid rgba(15, 23, 42, 0.1); background: var(--surface, #fff); display: grid; gap: 12px;">
            <% if (canManageOfficialSeedsFlag) { %>
              <form action="/admin/official-seeds/settings" method="POST" style="display: grid; gap: 12px;">
                <input type="hidden" name="redirectTo" value="<%= adminPaths.users || '/admin/users' %>">
                
                <div style="display: grid; gap: 6px;">
                  <label for="officialSeedMediaProvider" style="font-size: 12px; font-weight: 700; color: var(--text-main);">Fournisseur de Médias</label>
