                      <th>Détail</th>
                      <th>Dernière mise à jour</th>
                      <th>Action</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% blockedAccountsList.forEach((user) => { %>
                      <tr data-table-search-row="<%= `${user.first_name || ''} ${user.last_name || ''} ${user.username || ''} ${user.email || ''} ${user.account_restriction_reason || ''} ${user.account_restriction_details || ''}`.toLowerCase() %>">
