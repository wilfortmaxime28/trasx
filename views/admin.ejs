<!DOCTYPE html>
<html lang="fr" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>TrasX - Tableau de bord administrateur</title>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <script src="https://unpkg.com/lucide@latest"></script>
  <script src="https://cdn.jsdelivr.net/npm/jsqr@1.4.0/dist/jsQR.min.js"></script>
  <style>
    :root {
      --page-bg: #f6f8fc;
      --sidebar-bg: #ffffff;
      --rail-bg: #eef3fb;
      --card-bg: #ffffff;
      --card-soft: #f8fbff;
      --text-main: #162338;
      --text-muted: #6b7a90;
      --text-soft: #97a3b7;
      --primary: #2f6fed;
      --primary-hover: #2058c4;
      --primary-soft: rgba(47, 111, 237, 0.1);
      --border: #d9e2ef;
      --border-strong: #c8d4e5;
      --success: #22b573;
      --warning: #caa63d;
      --danger: #ef5a5a;
      --shadow: 0 18px 44px rgba(22, 35, 56, 0.05);
      --radius-xl: 28px;
      --radius-lg: 22px;
      --radius-md: 16px;
      --radius-sm: 12px;
      --sidebar-w: 280px;
      --rail-w: 320px;
    }

    @media (prefers-color-scheme: dark) {
      :root {
        --page-bg: #0f1727;
        --sidebar-bg: #121d30;
        --rail-bg: #162236;
        --card-bg: #172437;
        --card-soft: #132032;
        --text-main: #f5f8ff;
        --text-muted: #a6b3c8;
        --text-soft: #8593aa;
        --border: rgba(151, 169, 196, 0.18);
        --border-strong: rgba(151, 169, 196, 0.28);
        --shadow: 0 24px 48px rgba(0, 0, 0, 0.28);
      }
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      margin: 0;
      min-height: 100vh;
      display: grid;
      grid-template-columns: var(--sidebar-w) var(--rail-w) minmax(0, 1fr);
      background: var(--page-bg);
      font-family: 'Inter', sans-serif;
      color: var(--text-main);
    }

    a {
      color: inherit;
    }

    .sidebar,
    .insight-rail {
      position: sticky;
      top: 0;
      height: 100vh;
      overflow-y: auto;
      box-sizing: border-box;
    }

    .sidebar {
      background: var(--sidebar-bg);
      border-right: 1px solid var(--border);
      padding: 28px 22px 24px;
      display: flex;
      flex-direction: column;
      gap: 22px;
    }

    .sidebar-header {
      display: grid;
      gap: 12px;
    }

    .sidebar-header h1 {
      margin: 0;
      font-family: 'Outfit', sans-serif;
      font-size: 22px;
      line-height: 1.1;
      letter-spacing: -0.03em;
    }

    .sidebar-brand-subtitle {
      margin: 0;
      font-size: 12px;
      line-height: 1.3;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #71839f;
    }

    .sidebar-feature-card {
      background: linear-gradient(180deg, var(--card-soft) 0%, var(--card-bg) 100%);
      border: 1px solid var(--border);
      border-radius: 22px;
      padding: 20px;
      box-shadow: var(--shadow);
      display: grid;
      gap: 10px;
    }

    .sidebar-chip {
      width: fit-content;
      padding: 6px 12px;
      border-radius: 999px;
      background: var(--primary-soft);
      color: var(--primary);
      font-size: 12px;
      font-weight: 700;
    }

    .sidebar-feature-card h3 {
      margin: 0;
      font-size: 15px;
      line-height: 1.45;
      font-family: 'Outfit', sans-serif;
    }

    .sidebar-feature-card p {
      margin: 0;
      color: var(--text-muted);
      font-size: 13px;
      line-height: 1.5;
    }

    .nav-menu {
      display: grid;
      gap: 18px;
      flex: 1;
    }

    .nav-group {
      display: grid;
      gap: 8px;
    }

    .sidebar-section-title {
      margin: 0 2px 6px;
      color: #8b9ab2;
      font-size: 12px;
      font-weight: 800;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }

    .nav-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 14px;
      border-radius: 14px;
      color: var(--text-main);
      text-decoration: none;
      transition: 0.2s ease;
      font-weight: 600;
    }

    .nav-item i {
      width: 18px;
      height: 18px;
      color: #63748f;
      transition: 0.2s ease;
    }

    .nav-item:hover,
    .nav-item.active {
      background: #edf3ff;
      color: var(--primary);
    }

    .nav-item:hover i,
    .nav-item.active i {
      color: var(--primary);
    }

    .sidebar-footer {
      display: grid;
      gap: 10px;
      padding-top: 12px;
      border-top: 1px solid var(--border);
    }

    .logout-btn {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 12px 14px;
      border-radius: 14px;
      color: var(--danger);
      text-decoration: none;
      font-weight: 600;
      transition: 0.2s ease;
    }

    .logout-btn:hover {
      background: rgba(239, 90, 90, 0.08);
    }

    .logout-btn i {
      width: 18px;
      height: 18px;
    }

    .change-password-btn {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 12px 14px;
      border-radius: 14px;
      color: var(--text-muted);
      text-decoration: none;
      font-weight: 600;
      transition: 0.2s ease;
      cursor: pointer;
      border: none;
      background: transparent;
      width: 100%;
      text-align: left;
      font-family: inherit;
      font-size: inherit;
    }

    .change-password-btn:hover {
      background: rgba(47, 111, 237, 0.08);
      color: var(--primary);
    }

    .change-password-btn i {
      width: 18px;
      height: 18px;
    }

    .insight-rail {
      background: var(--rail-bg);
      border-right: 1px solid var(--border);
      padding: 34px 28px;
    }

    .insight-rail-inner {
      display: grid;
      gap: 26px;
    }

    .rail-header h2 {
      margin: 0 0 8px;
      font-family: 'Outfit', sans-serif;
      font-size: 18px;
      line-height: 1.2;
    }

    .rail-header p {
      margin: 0;
      color: var(--text-muted);
      font-size: 14px;
      line-height: 1.45;
    }

    .rail-group {
      display: grid;
      gap: 12px;
    }

    .rail-group-title {
      margin: 0;
      color: #7385a2;
      font-size: 11px;
      font-weight: 800;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .rail-stat-card {
      background: rgba(255, 255, 255, 0.72);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 14px 16px;
      display: grid;
      gap: 8px;
    }

    .rail-stat-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      font-size: 14px;
      font-weight: 700;
    }

    .rail-stat-value {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 40px;
      padding: 4px 10px;
      border-radius: 999px;
      background: rgba(22, 35, 56, 0.06);
      color: var(--text-main);
      font-size: 12px;
      font-weight: 800;
    }

    .rail-stat-note {
      margin: 0;
      color: var(--text-muted);
      font-size: 13px;
      line-height: 1.45;
    }

    .rail-list {
      display: grid;
      gap: 8px;
    }

    .rail-list-line {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding: 10px 0;
      border-bottom: 1px dashed var(--border);
      font-size: 13px;
      color: var(--text-muted);
    }

    .rail-list-line:last-child {
      border-bottom: none;
      padding-bottom: 0;
    }

    .rail-list-line strong {
      color: var(--text-main);
      font-weight: 700;
    }

    .rail-quick-links {
      display: grid;
      gap: 10px;
    }

    .rail-link {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding: 12px 14px;
      border-radius: 14px;
      background: rgba(255, 255, 255, 0.72);
      border: 1px solid var(--border);
      color: var(--text-main);
      text-decoration: none;
      font-size: 13px;
      font-weight: 700;
    }

    .rail-link i {
      width: 16px;
      height: 16px;
      color: var(--primary);
    }

    .main-content {
      min-width: 0;
      display: flex;
      flex-direction: column;
    }

    .topbar {
      position: sticky;
      top: 0;
      z-index: 20;
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 20px;
      padding: 34px 48px 24px;
      background: linear-gradient(180deg, rgba(246, 248, 252, 0.96) 0%, rgba(246, 248, 252, 0.88) 100%);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(217, 226, 239, 0.85);
    }

    .topbar-copy {
      display: grid;
      gap: 10px;
      min-width: 0;
    }

    .topbar-breadcrumbs {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 8px;
      color: #7b8ca8;
      font-size: 12px;
      font-weight: 700;
    }

    .topbar-breadcrumbs span:not(:last-child)::after {
      content: ">";
      margin-left: 8px;
      color: #a0aec0;
    }

    .topbar h2 {
      margin: 0;
      font-family: 'Outfit', sans-serif;
      font-size: clamp(30px, 3vw, 44px);
      line-height: 1.02;
      letter-spacing: -0.04em;
    }

    .topbar-actions {
      display: flex;
      align-items: center;
      gap: 12px;
      flex-shrink: 0;
    }

    .admin-pill {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 8px 12px;
      border-radius: 14px;
      border: 1px solid var(--border);
      background: var(--card-bg);
      box-shadow: var(--shadow);
    }

    .admin-avatar {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--primary) 0%, #5b8cff 100%);
      color: #ffffff;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-weight: 800;
      font-family: 'Outfit', sans-serif;
    }

    .admin-pill-copy {
      display: grid;
      gap: 2px;
    }

    .admin-pill-copy strong {
      font-size: 13px;
      line-height: 1.2;
    }

    .admin-pill-copy span {
      font-size: 11px;
      color: var(--text-muted);
      line-height: 1.2;
    }

    .pdf-btn {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 14px 18px;
      border: none;
      border-radius: 14px;
      background: #122139;
      color: #ffffff;
      font-size: 14px;
      font-weight: 700;
      cursor: pointer;
      box-shadow: var(--shadow);
    }

    .content-wrapper {
      padding: 28px 48px 56px;
      overflow-x: hidden;
    }

    .alert-banner {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 14px 16px;
      border-radius: 16px;
      margin-bottom: 18px;
      font-size: 14px;
      font-weight: 700;
    }

    .hero-card {
      display: grid;
      gap: 18px;
      margin-bottom: 28px;
    }

    .page-meta-pills {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    .meta-pill {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 14px;
      border-radius: 12px;
      background: var(--card-bg);
      border: 1px solid var(--border);
      color: #5f708d;
      font-size: 13px;
      font-weight: 700;
    }

    .hero-note {
      background: linear-gradient(135deg, #2f6fed 0%, #356cf0 100%);
      color: #ffffff;
      border-radius: 20px;
      padding: 24px 28px;
      line-height: 1.65;
      font-size: 14px;
      font-weight: 600;
      box-shadow: 0 20px 50px rgba(47, 111, 237, 0.2);
    }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 18px;
      margin-bottom: 28px;
    }

    .stat-card {
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 22px 24px;
      display: flex;
      align-items: flex-start;
      gap: 16px;
      box-shadow: var(--shadow);
    }

    .stat-icon {
      width: 44px;
      height: 44px;
      flex-shrink: 0;
      border-radius: 14px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-right: 0;
    }

    .stat-icon.blue { background: rgba(47, 111, 237, 0.1); color: var(--primary); }
    .stat-icon.green { background: rgba(34, 181, 115, 0.12); color: var(--success); }
    .stat-icon.red { background: rgba(239, 90, 90, 0.1); color: var(--danger); }
    .stat-icon.frozen { background: rgba(14, 165, 233, 0.12); color: #0ea5e9; }

    .stat-info h3 {
      margin: 0 0 4px;
      font-size: 20px;
      font-weight: 800;
      font-family: 'Outfit', sans-serif;
      letter-spacing: -0.03em;
    }

    .stat-info p {
      margin: 0;
      color: var(--text-muted);
      font-size: 13px;
      line-height: 1.45;
    }

    .section-card {
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 24px;
      margin-bottom: 28px;
      overflow: hidden;
      box-shadow: var(--shadow);
      scroll-margin-top: 120px;
    }

    .section-header {
      padding: 22px 28px;
      border-bottom: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
      background: rgba(248, 251, 255, 0.8);
    }

    .section-header h3 {
      margin: 0;
      font-family: 'Outfit', sans-serif;
      font-size: 24px;
      line-height: 1.1;
      letter-spacing: -0.03em;
    }

    .section-header p {
      margin: 6px 0 0;
      color: var(--text-muted);
      font-size: 14px;
    }

    .section-card > .settings-form,
    .section-card > div[style*="padding: 24px"],
    .section-card > div[style*="padding: 24px; display: grid"] {
      background: transparent;
    }

    .account-trends-shell {
      padding: 24px 28px 28px;
      display: grid;
      gap: 24px;
    }

    .account-trends-toolbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      flex-wrap: wrap;
    }

    .account-trends-toggle {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 6px;
      border: 1px solid var(--border);
      border-radius: 999px;
      background: var(--card-soft);
    }

    .account-trends-toggle button {
      border: none;
      background: transparent;
      color: var(--text-muted);
      border-radius: 999px;
      padding: 10px 16px;
      font-size: 13px;
      font-weight: 700;
      cursor: pointer;
      transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease;
    }

    .account-trends-toggle button.is-active {
      background: var(--primary);
      color: #ffffff;
      box-shadow: 0 12px 24px rgba(47, 111, 237, 0.22);
    }

    .account-trends-note {
      color: var(--text-muted);
      font-size: 13px;
      line-height: 1.5;
      max-width: 720px;
    }

    .account-trends-group {
      display: grid;
      gap: 16px;
    }

    .account-trends-group-header h4 {
      margin: 0;
      font-family: 'Outfit', sans-serif;
      font-size: 20px;
      letter-spacing: -0.03em;
    }

    .account-trends-group-header p {
      margin: 6px 0 0;
      color: var(--text-muted);
      font-size: 13px;
    }

    .account-trends-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 18px;
    }

    .account-trend-card {
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 18px;
      background: linear-gradient(180deg, var(--card-soft) 0%, var(--card-bg) 100%);
      display: grid;
      gap: 14px;
      min-width: 0;
    }

    .account-trend-head {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 12px;
    }

    .account-trend-head h5 {
      margin: 0;
      font-size: 15px;
      font-weight: 800;
      line-height: 1.3;
    }

    .account-trend-head p {
      margin: 4px 0 0;
      color: var(--text-muted);
      font-size: 12px;
    }

    .account-trend-dot {
      width: 12px;
      height: 12px;
      border-radius: 999px;
      flex-shrink: 0;
      margin-top: 4px;
    }

    .account-trend-current {
      display: flex;
      align-items: baseline;
      gap: 8px;
      font-family: 'Outfit', sans-serif;
    }

    .account-trend-current strong {
      font-size: 26px;
      line-height: 1;
      letter-spacing: -0.04em;
    }

    .account-trend-current span {
      color: var(--text-muted);
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    .account-trend-bars {
      display: grid;
      grid-template-columns: repeat(7, minmax(0, 1fr));
      align-items: end;
      gap: 10px;
      min-height: 150px;
    }

    .account-trend-bars.is-compact {
      grid-template-columns: repeat(6, minmax(0, 1fr));
    }

    .account-trend-bars.is-wide {
      grid-template-columns: repeat(5, minmax(0, 1fr));
    }

    .account-trend-bar {
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      gap: 8px;
      min-width: 0;
    }

    .account-trend-bar-fill {
      width: 100%;
      min-height: 8px;
      border-radius: 999px 999px 10px 10px;
      background: var(--primary);
      box-shadow: inset 0 -8px 16px rgba(255, 255, 255, 0.12);
    }

    .account-trend-bar-label {
      color: var(--text-soft);
      font-size: 11px;
      text-align: center;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .account-trend-bar-value {
      color: var(--text-muted);
      font-size: 11px;
      text-align: center;
      line-height: 1.3;
      min-height: 28px;
    }

    .admin-management-grid {
      padding: 24px 28px 28px;
      display: grid;
      gap: 22px;
    }

    .admin-permission-card {
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 20px;
      background: linear-gradient(180deg, var(--card-soft) 0%, var(--card-bg) 100%);
      display: grid;
      gap: 16px;
    }

    .admin-permission-card h4 {
      margin: 0;
      font-family: 'Outfit', sans-serif;
      font-size: 20px;
      letter-spacing: -0.03em;
    }

    .admin-permission-card p {
      margin: 0;
      color: var(--text-muted);
      font-size: 13px;
      line-height: 1.55;
    }

    .admin-form-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 14px;
    }

    .admin-form-grid .form-group.full-width {
      grid-column: 1 / -1;
    }

    .admin-checkbox-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }

    .admin-checkbox-item {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      padding: 14px;
      border-radius: 16px;
      border: 1px solid var(--border);
      background: rgba(255, 255, 255, 0.6);
    }

    .admin-checkbox-item input {
      margin-top: 2px;
      width: 16px;
      height: 16px;
      accent-color: var(--primary);
      flex-shrink: 0;
    }

    .admin-checkbox-item strong {
      display: block;
      font-size: 14px;
      margin-bottom: 4px;
    }

    .admin-checkbox-item span {
      display: block;
      color: var(--text-muted);
      font-size: 12px;
      line-height: 1.45;
    }

    .admin-admins-list {
      display: grid;
      gap: 16px;
    }

    .admin-account-card {
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 20px;
      background: var(--card-bg);
      display: grid;
      gap: 16px;
    }

    .admin-account-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      flex-wrap: wrap;
    }

    .admin-account-title {
      display: grid;
      gap: 4px;
    }

    .admin-account-title strong {
      font-size: 16px;
      font-weight: 800;
    }

    .admin-account-title span {
      color: var(--text-muted);
      font-size: 12px;
    }

    .admin-role-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 7px 12px;
      border-radius: 999px;
      background: rgba(47, 111, 237, 0.1);
      color: var(--primary);
      font-size: 12px;
      font-weight: 800;
    }

    .cert-badge-preview {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(15, 23, 42, 0.05);
      color: var(--text-main);
