                <div class="stat-icon blue"><i data-lucide="users"></i></div>
                <div class="stat-info"><h3>Utilisateurs</h3><p>Comptes, audiences, soldes et statuts.</p></div>
              </a><% } %>
              <% if (hasPageAccess('moderation')) { %><a href="<%= adminPaths.moderation || '/admin/moderation' %>" class="stat-card" style="text-decoration: none;">
                <div class="stat-icon red"><i data-lucide="shield-alert"></i></div>
                <div class="stat-info"><h3>Modération</h3><p>Signalements, alertes et revue des posts.</p></div>
              </a><% } %>
              <% if (hasPageAccess('revenue')) { %><a href="<%= adminPaths.revenue || '/admin/revenue' %>" class="stat-card" style="text-decoration: none;">
                <div class="stat-icon green"><i data-lucide="landmark"></i></div>
                <div class="stat-info"><h3>Revenus</h3><p>Encaissements USD et token.</p></div>
              </a><% } %>
              <% if (hasPageAccess('transactions')) { %><a href="<%= adminPaths.transactions || '/admin/transactions' %>" class="stat-card" style="text-decoration: none;">
                <div class="stat-icon blue"><i data-lucide="arrow-left-right"></i></div>
                <div class="stat-info"><h3>Transactions</h3><p>Depots, retraits et bénéfices.</p></div>
              </a><% } %>
              <% if (hasPageAccess('backgrounds')) { %><a href="<%= adminPaths.backgrounds || '/admin/backgrounds' %>" class="stat-card" style="text-decoration: none;">
                <div class="stat-icon green"><i data-lucide="image"></i></div>
                <div class="stat-info"><h3>Fonds</h3><p>Fonds premium et attribution des revenus.</p></div>
              </a><% } %>
              <% if (hasPageAccess('smtp')) { %><a href="<%= adminPaths.smtp || '/admin/system-settings' %>" class="stat-card" style="text-decoration: none;">
                <div class="stat-icon blue"><i data-lucide="settings"></i></div>
                <div class="stat-info"><h3>Paramètres</h3><p>SMTP, sécurité et actions critiques.</p></div>
              </a><% } %>
              <% if (hasPageAccess('admins')) { %><a href="<%= adminPaths.admins || '/admin/admins' %>" class="stat-card" style="text-decoration: none;">
                <div class="stat-icon blue"><i data-lucide="user-cog"></i></div>
                <div class="stat-info"><h3>Admins</h3><p>Création, droits et vues personnalisées.</p></div>
              </a><% } %>
            </div>
          </div>
      </div>
      <% } %>

      <% if (isPage('admins')) { %>
      <div class="section-card" id="admin-management">
        <div class="section-header">
          <div>
            <h3>Gestion des administrateurs</h3>
            <p>Le super admin peut créer d'autres admins, définir leurs droits et personnaliser exactement les pages qu'ils peuvent voir.</p>
          </div>
        </div>
        <div class="admin-management-grid">
          <% if (canManageAdminsFlag) { %>
          <div class="admin-permission-card">
            <h4>Créer un administrateur</h4>
            <p>Choisissez ses informations, ses pages visibles et les actions qu'il pourra réellement exécuter dans le backoffice.</p>
            <form action="/admin/admins/create" method="POST" style="display: grid; gap: 16px;">
              <div class="admin-form-grid">
                <div class="form-group">
                  <label>Nom affiché</label>
                  <input type="text" name="display_name" placeholder="Ex. Marie Superviseur">
                </div>
                <div class="form-group">
                  <label>Email admin</label>
                  <input type="email" name="email" required placeholder="admin@trasx.com">
                </div>
                <div class="form-group">
                  <label>Mot de passe</label>
                  <input type="password" name="password" required minlength="6" placeholder="Au moins 6 caractères">
                </div>
                <div class="form-group">
                  <label style="display: flex; align-items: center; gap: 10px; cursor: pointer; padding-top: 30px;">
                    <input type="checkbox" name="is_super_admin" value="1" style="width: 16px; height: 16px; accent-color: var(--primary);">
                    <span>Créer comme super admin</span>
                  </label>
                </div>
                <div class="form-group full-width">
                  <label>Pages visibles</label>
                  <div class="admin-checkbox-grid">
                    <% adminPagePermissionsList.forEach((permission) => { %>
                      <label class="admin-checkbox-item">
                        <input type="checkbox" name="pages" value="<%= permission.key %>" <%= permission.key === 'overview' ? 'checked' : '' %>>
                        <span>
                          <strong><%= permission.label %></strong>
                          <span><%= permission.description %></span>
                        </span>
                      </label>
                    <% }) %>
                  </div>
                </div>
                <div class="form-group full-width">
                  <label>Droits d'action</label>
                  <div class="admin-checkbox-grid">
                    <% adminActionPermissionsList.forEach((permission) => { %>
                      <label class="admin-checkbox-item">
                        <input type="checkbox" name="actions" value="<%= permission.key %>">
                        <span>
                          <strong><%= permission.label %></strong>
                          <span><%= permission.description %></span>
                        </span>
                      </label>
                    <% }) %>
                  </div>
                </div>
              </div>
              <div>
                <button type="submit" class="btn">Créer cet administrateur</button>
              </div>
            </form>
          </div>

          <div class="admin-permission-card">
            <h4>Administrateurs existants</h4>
            <p>Mettez à jour leurs informations, leurs vues personnalisées et leurs droits d'action sans quitter le tableau de bord.</p>
            <% if (adminAccountsList.length > 0) { %>
              <div class="admin-admins-list">
                <% adminAccountsList.forEach((adminAccount) => { %>
                  <div class="admin-account-card">
                    <div class="admin-account-head">
                      <div class="admin-account-title">
                        <strong><%= adminAccount.display_name || adminAccount.email %></strong>
                        <span><%= adminAccount.email %> · ID #<%= adminAccount.id %></span>
                      </div>
                      <span class="admin-role-badge">
                        <i data-lucide="<%= adminAccount.is_super_admin ? 'shield-check' : 'user-cog' %>" style="width: 14px; height: 14px;"></i>
                        <%= adminAccount.is_super_admin ? 'Super admin' : 'Admin personnalisé' %>
                      </span>
                    </div>

                    <form action="/admin/admins/update" method="POST" style="display: grid; gap: 16px;">
                      <input type="hidden" name="admin_id" value="<%= adminAccount.id %>">
                      <div class="admin-form-grid">
                        <div class="form-group">
                          <label>Nom affiché</label>
                          <input type="text" name="display_name" value="<%= adminAccount.display_name || '' %>" placeholder="Nom affiché admin">
                        </div>
                        <div class="form-group">
                          <label>Email admin</label>
                          <input type="email" name="email" required value="<%= adminAccount.email || '' %>">
                        </div>
                        <div class="form-group">
                          <label>Nouveau mot de passe</label>
                          <input type="password" name="password" minlength="6" placeholder="Laisser vide pour ne pas changer">
                        </div>
                        <div class="form-group">
                          <label style="display: flex; align-items: center; gap: 10px; cursor: pointer; padding-top: 30px;">
                            <input type="checkbox" name="is_super_admin" value="1" style="width: 16px; height: 16px; accent-color: var(--primary);" <%= adminAccount.is_super_admin ? 'checked' : '' %>>
                            <span>Super admin</span>
                          </label>
                        </div>
                        <div class="form-group full-width">
                          <label>Pages visibles</label>
                          <div class="admin-checkbox-grid">
                            <% adminPagePermissionsList.forEach((permission) => { %>
                              <label class="admin-checkbox-item">
                                <input
                                  type="checkbox"
                                  name="pages"
                                  value="<%= permission.key %>"
                                  <%= adminAccount.resolvedPermissions?.pages?.[permission.key] ? 'checked' : '' %>
                                >
                                <span>
                                  <strong><%= permission.label %></strong>
                                  <span><%= permission.description %></span>
                                </span>
                              </label>
                            <% }) %>
                          </div>
                        </div>
                        <div class="form-group full-width">
                          <label>Droits d'action</label>
                          <div class="admin-checkbox-grid">
                            <% adminActionPermissionsList.forEach((permission) => { %>
                              <label class="admin-checkbox-item">
                                <input
                                  type="checkbox"
                                  name="actions"
                                  value="<%= permission.key %>"
                                  <%= adminAccount.resolvedPermissions?.actions?.[permission.key] ? 'checked' : '' %>
                                >
                                <span>
                                  <strong><%= permission.label %></strong>
                                  <span><%= permission.description %></span>
                                </span>
                              </label>
                            <% }) %>
                          </div>
                        </div>
                      </div>
                      <div>
                        <button type="submit" class="btn">Enregistrer les accès</button>
                      </div>
                    </form>
                  </div>
                <% }) %>
              </div>
            <% } else { %>
              <p>Aucun autre administrateur n'est enregistré pour le moment.</p>
            <% } %>
          </div>
          <% } else { %>
            <div class="admin-permission-card">
              <h4>Accès restreint</h4>
              <p>Votre compte peut voir cette page mais ne possède pas le droit de créer ou modifier des administrateurs. Demandez au super admin de vous attribuer l'action <strong>Gérer les admins</strong>.</p>
            </div>
          <% } %>
        </div>
      </div>
      <% } %>

      <% if (isPage('revenue')) { %>
      <div class="section-card" id="platform-revenue">
        <div class="section-header">
          <div>
            <h3>Compte des revenus plateforme</h3>
            <p>Suivi des encaissements USD et token convertis selon la valeur du token active.</p>
          </div>
        </div>
        <div class="settings-form" style="max-width: none;">
          <div style="display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 16px; margin-bottom: 24px;">
            <div style="padding: 16px; border-radius: 12px; border: 1px solid var(--border); background: rgba(59, 130, 246, 0.08);">
              <div style="font-size: 12px; color: var(--text-muted); margin-bottom: 6px;">Revenu total (équivalent USD)</div>
              <div style="font-size: 28px; font-weight: 700; font-family: 'Outfit', sans-serif;">$<%= Number(revenueSummary.total_usd_equivalent || 0).toFixed(2) %></div>
            </div>
            <div style="padding: 16px; border-radius: 12px; border: 1px solid var(--border); background: rgba(16, 185, 129, 0.08);">
              <div style="font-size: 12px; color: var(--text-muted); margin-bottom: 6px;">Services en espèces collectés</div>
              <div style="font-size: 28px; font-weight: 700; font-family: 'Outfit', sans-serif;">$<%= Number(revenueSummary.total_usd_native || 0).toFixed(2) %></div>
            </div>
            <div style="padding: 16px; border-radius: 12px; border: 1px solid var(--border); background: rgba(245, 158, 11, 0.08);">
              <div style="font-size: 12px; color: var(--text-muted); margin-bottom: 6px;">Services en jetons collectés</div>
              <div style="font-size: 28px; font-weight: 700; font-family: 'Outfit', sans-serif;"><%= Number(revenueSummary.total_tokens_native || 0).toFixed(4).replace(/\.?0+$/, '') %></div>
            </div>
          </div>

          <div style="font-size: 12px; color: var(--text-muted); margin-bottom: 14px;">
            Total des entrées enregistrées : <strong style="color: var(--text-main);"><%= Number(revenueSummary.entries_count || 0) %></strong>
          </div>

          <% if (revenueEntries.length > 0) { %>
            <div class="table-search-row">
              <label class="search-field">
                <i data-lucide="search"></i>
                <input type="search" data-table-search-input data-table-target="adminRevenueTable" placeholder="Rechercher dans les revenus...">
              </label>
            </div>
            <div style="overflow-x: auto;">
              <table id="adminRevenueTable">
                <thead>
                  <tr>
                    <th>Date</th>
                    <th>Service</th>
                    <th>Payeur</th>
                    <th>Devise</th>
                    <th>Montant</th>
                    <th>USD Eq.</th>
                    <th>Référence</th>
                  </tr>
                </thead>
                <tbody>
                  <% revenueEntries.forEach((entry) => { %>
                    <tr>
                      <td><%= new Date(entry.created_at).toLocaleString() %></td>
                      <td>
                        <div style="font-weight: 600;"><%= entry.entry_type %></div>
                        <div style="font-size: 12px; color: var(--text-muted);"><%= entry.note || 'Paiement de service plateforme' %></div>
                      </td>
                      <td>
                        <% if (entry.payer_username) { %>
                          <div style="font-weight: 600;">@<%= entry.payer_username %></div>
                          <div style="font-size: 12px; color: var(--text-muted);"><%= entry.payer_name || 'Utilisateur' %></div>
                        <% } else { %>
                          <span style="color: var(--text-muted);">Système</span>
                        <% } %>
                      </td>
                      <td><span class="badge <%= entry.currency === 'USD' ? 'active' : 'paused' %>"><%= entry.currency %></span></td>
                      <td><%= Number(entry.amount_native || 0).toFixed(entry.currency === 'TOKEN' ? 4 : 2) %></td>
                      <td>$<%= Number(entry.amount_usd || 0).toFixed(2) %></td>
                      <td style="color: var(--text-muted);"><%= entry.reference_id || '-' %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } else { %>
            <p style="color: var(--text-muted); margin: 0;">Aucune entree de revenu n'a encore ete enregistree.</p>
          <% } %>
        </div>
      </div>
      <% } %>

      <!-- Deposits & Withdrawals History -->
      <% if (isPage('transactions')) { %>
      <div class="section-card" id="transactions-history">
        <div class="section-header" style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border); padding-bottom: 14px; margin-bottom: 20px;">
          <h3 style="margin: 0; font-size: 18px; font-weight: 700; color: var(--text-main);">Historique des Transactions (Dépôts & Retraits)</h3>
          
          <div style="display: flex; gap: 8px; background: rgba(47, 111, 237, 0.06); padding: 4px; border-radius: 12px; border: 1px solid var(--border);">
            <button onclick="switchAdminTxTab('deposits')" id="admin-tx-tab-deposits" style="padding: 6px 16px; border-radius: 6px; border: none; font-size: 13px; font-weight: 600; cursor: pointer; transition: all 0.2s;" class="admin-tx-tab-btn active-tab-btn">Dépôts</button>
            <button onclick="switchAdminTxTab('withdrawals')" id="admin-tx-tab-withdrawals" style="padding: 6px 16px; border-radius: 6px; border: none; font-size: 13px; font-weight: 600; cursor: pointer; transition: all 0.2s;" class="admin-tx-tab-btn">Retraits & Bénéfice</button>
          </div>
        </div>

        <style>
          .admin-tx-tab-btn {
            background: transparent;
            color: var(--text-muted);
          }
          .admin-tx-tab-btn.active-tab-btn {
            background: var(--primary);
            color: white;
          }
        </style>

        <div class="settings-form" style="max-width: none;">
          <!-- Deposits Tab -->
          <div id="admin-tx-content-deposits" class="admin-tx-tab-content">
            <% if (typeof deposits !== 'undefined' && deposits.length > 0) { %>
              <div class="table-search-row">
                <label class="search-field">
                  <i data-lucide="search"></i>
                  <input type="search" data-table-search-input data-table-target="adminDepositsTable" placeholder="Rechercher dans les dépôts...">
                </label>
              </div>
              <div style="overflow-x: auto;">
                <table id="adminDepositsTable">
                  <thead>
                    <tr>
                      <th>Date</th>
                      <th>Utilisateur</th>
                      <th>De (Portefeuille)</th>
                      <th>Vers (Plateforme)</th>
                      <th>Montant</th>
                      <th>Confirmations</th>
                      <th>Statut</th>
                      <th>Transaction</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% deposits.forEach((d) => { %>
                      <tr>
                        <td><%= new Date(d.created_at).toLocaleString() %></td>
                        <td>
                          <div style="font-weight: 600;">@<%= d.username || 'Inconnu' %></div>
                          <div style="font-size: 12px; color: var(--text-muted);"><%= d.user_name || d.email || 'Utilisateur' %></div>
                        </td>
                        <td style="font-family: monospace; font-size: 12px; color: var(--text-muted);"><%= d.from_address %></td>
                        <td style="font-family: monospace; font-size: 12px; color: var(--text-muted);"><%= d.to_address %></td>
                        <td style="font-weight: 700; color: var(--success);">+<%= Number(d.amount_usdt).toFixed(2) %> USDT</td>
                        <td><span style="font-weight: 500;"><%= d.confirmations %>/12</span></td>
                        <td>
                          <span class="badge <%= d.status === 'confirmed' ? 'active' : 'paused' %>">
                            <%= d.status === 'confirmed' ? 'Confirmé' : 'En attente' %>
                          </span>
                        </td>
                        <td>
                          <% if (d.tx_hash) { %>
                            <a href="https://bscscan.com/tx/<%= d.tx_hash %>" target="_blank" style="color: var(--primary); text-decoration: none; display: inline-flex; align-items: center; gap: 4px; font-weight: 500;">
                              Voir <i data-lucide="external-link" style="width: 12px; height: 12px;"></i>
                            </a>
                          <% } else { %>
                            -
                          <% } %>
                        </td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            <% } else { %>
              <p style="color: var(--text-muted); margin: 0; text-align: center; padding: 20px 0;">Aucun dépôt enregistré pour le moment.</p>
            <% } %>
          </div>

          <!-- Withdrawals Tab -->
          <div id="admin-tx-content-withdrawals" class="admin-tx-tab-content" style="display: none;">
            <% 
              let totalProfit = 0;
              if (typeof withdrawals !== 'undefined') {
                withdrawals.forEach(w => {
                  if (w.status === 'completed') {
                    totalProfit += Math.max(0, Number(w.fee_usdt || 0) - Number(w.gas_cost_usdt || 0));
                  }
                });
              }
            %>
            <div style="display: flex; gap: 16px; margin-bottom: 20px; align-items: center; background: rgba(16, 185, 129, 0.06); border: 1px solid rgba(16, 185, 129, 0.15); padding: 16px; border-radius: 10px;">
              <i data-lucide="piggy-bank" style="width: 24px; height: 24px; color: var(--success);"></i>
              <div>
                <div style="font-size: 12px; color: var(--text-muted); margin-bottom: 2px;">Bénéfice net total accumulé sur les retraits (après déduction gas)</div>
                <div style="font-size: 20px; font-weight: 700; color: var(--success); font-family: 'Outfit', sans-serif;">$<%= totalProfit.toFixed(2) %> USD</div>
              </div>
            </div>

            <% if (typeof withdrawals !== 'undefined' && withdrawals.length > 0) { %>
              <div class="table-search-row">
                <label class="search-field">
                  <i data-lucide="search"></i>
                  <input type="search" data-table-search-input data-table-target="adminWithdrawalsTable" placeholder="Rechercher dans les retraits...">
                </label>
              </div>
              <div style="overflow-x: auto;">
                <table id="adminWithdrawalsTable">
                  <thead>
                    <tr>
                      <th>Date</th>
                      <th>Utilisateur</th>
                      <th>Adresse Dest.</th>
                      <th>Brut Demandé</th>
                      <th>Frais Brut</th>
                      <th>Frais Gas BSC</th>
                      <th style="background: rgba(16, 185, 129, 0.05);">Bénéfice Net</th>
                      <th>Net Transféré</th>
                      <th>Statut</th>
                      <th>Détails</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% withdrawals.forEach((w) => { %>
                      <% 
                        const profit = w.status === 'completed' ? Math.max(0, Number(w.fee_usdt || 0) - Number(w.gas_cost_usdt || 0)) : 0;
                      %>
                      <tr>
                        <td><%= new Date(w.created_at).toLocaleString() %></td>
                        <td>
                          <div style="font-weight: 600;">@<%= w.username || 'Inconnu' %></div>
                          <div style="font-size: 12px; color: var(--text-muted);"><%= w.user_name || w.email || 'Utilisateur' %></div>
                        </td>
                        <td style="font-family: monospace; font-size: 12px; color: var(--text-muted);"><%= w.recipient_address %></td>
                        <td style="font-weight: 600; color: var(--text-main);"><%= Number(w.amount_usdt).toFixed(2) %> USDT</td>
                        <td style="color: var(--danger); font-size: 13px;"><%= Number(w.fee_usdt).toFixed(2) %> USDT</td>
                        <td style="color: #fb923c; font-size: 13px;"><%= Number(w.gas_cost_usdt).toFixed(4) %> USDT</td>
                        <td style="font-weight: 700; color: var(--success); background: rgba(16, 185, 129, 0.05); font-size: 13.5px;">
                          <%= w.status === 'completed' ? `+$${profit.toFixed(2)}` : '-' %>
                        </td>
                        <td style="font-weight: 600; color: var(--primary); font-size: 13px;"><%= Number(w.net_amount_usdt).toFixed(2) %> USDT</td>
                        <td>
                          <% 
                            let statusClass = 'paused'; 
                            let statusLabel = 'En attente';
                            if (w.status === 'completed') {
                              statusClass = 'active';
                              statusLabel = 'Réussi';
                            } else if (w.status === 'failed') {
                              statusClass = 'blocked';
                              statusLabel = 'Échoué';
                            }
                          %>
                          <span class="badge <%= statusClass %>"><%= statusLabel %></span>
                        </td>
                        <td>
                          <% if (w.tx_hash) { %>
                            <a href="https://bscscan.com/tx/<%= w.tx_hash %>" target="_blank" style="color: var(--primary); text-decoration: none; display: inline-flex; align-items: center; gap: 4px; font-weight: 500; font-size: 12.5px;">
                              Voir <i data-lucide="external-link" style="width: 11px; height: 11px;"></i>
                            </a>
                          <% } else if (w.status === 'failed') { %>
                            <div style="font-size: 11px; color: var(--danger); max-width: 150px; line-height: 1.3;" title="<%= w.error_message %>">
                              <%= w.error_message || 'Échec transaction' %>
                            </div>
                          <% } else { %>
                            -
                          <% } %>
                        </td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            <% } else { %>
              <p style="color: var(--text-muted); margin: 0; text-align: center; padding: 20px 0;">Aucun retrait enregistré pour le moment.</p>
            <% } %>
          </div>
        </div>
      </div>

      <!-- Manual Deposit Recovery Card -->
      <div class="section-card" id="admin-deposit-recovery" style="margin-top: 24px;">
        <div class="section-header" style="border-bottom: 1px solid var(--border); padding-bottom: 14px; margin-bottom: 20px;">
          <h3 style="margin: 0; font-size: 18px; font-weight: 700; color: var(--text-main);">Récupération manuelle de dépôt via TxID</h3>
          <p style="color: var(--text-muted); margin-top: 4px; font-size: 13px;">Saisissez le TxID d'une transaction BSC et l'ID de l'utilisateur pour forcer la détection on-chain et créditer son compte.</p>
        </div>
        
        <form id="adminRecoverDepositForm" onsubmit="handleAdminRecoverDeposit(event)" style="max-width: 600px;">
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px;">
            <div class="form-group">
              <label style="display: block; margin-bottom: 6px; font-weight: 500; font-size: 13px; color: var(--text-muted);">ID Utilisateur</label>
              <input type="number" id="adminRecoverUserId" required placeholder="Ex. 512" style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid var(--border); background: var(--bg-dark); color: var(--text-main);">
            </div>
            <div class="form-group">
