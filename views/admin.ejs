                <i data-lucide="scan" style="width: 32px; height: 32px; color: var(--primary);"></i>
                <div style="font-size: 14px; font-weight: 600;">Glissez-déposez le QR Code du reçu</div>
                <div style="font-size: 12px; color: var(--text-muted);">ou cliquez pour parcourir les fichiers</div>
                <input type="file" id="qr-file-input" accept="image/*" style="display: none;">
              </div>

              <!-- Manual Input Form -->
              <form id="decryptForm" class="settings-form" style="padding: 0; max-width: none;">
                <div class="form-group" style="margin-bottom: 16px;">
                  <label for="encryptedCode">Code Chiffré du Reçu (ou texte décodé du QR Code)</label>
                  <textarea id="encryptedCode" name="encryptedCode" rows="4" style="width: 100%; padding: 12px; background: var(--card-bg); border: 1px solid var(--border); border-radius: 12px; color: var(--text-main); font-family: monospace; font-size: 11px; resize: vertical; box-sizing: border-box;" placeholder="Entrez le code cryptographié ici..."></textarea>
                </div>
                <button type="submit" class="btn" style="width: 100%; display: flex; align-items: center; justify-content: center; gap: 8px; font-weight: 600;">
                  <i data-lucide="unlock" style="width: 16px; height: 16px;"></i> Décrypter et Vérifier
                </button>
              </form>
            </div>

            <!-- Right Panel: Results -->
            <div id="decrypt-results-wrapper" style="border: 1px solid var(--border); border-radius: 16px; background: var(--card-soft); min-height: 290px; padding: 20px; display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; box-sizing: border-box; overflow: hidden;">
              <div id="decrypt-results-placeholder">
                <i data-lucide="shield-check" style="width: 48px; height: 48px; color: var(--text-muted); opacity: 0.5; margin-bottom: 12px;"></i>
                <div style="font-size: 14px; font-weight: 600; color: var(--text-muted);">En attente de décryptage...</div>
                <p style="font-size: 12px; color: var(--text-muted); max-width: 280px; margin: 4px 0 0 0;">
                  Soumettez un code chiffré pour lancer la vérification de sécurité.
                </p>
              </div>
              
              <div id="decrypt-results-content" style="display: none; width: 100%; text-align: left;">
                <!-- Status Badge Header -->
                <div id="decrypt-status-banner" style="padding: 12px; border-radius: 8px; margin-bottom: 16px; display: flex; align-items: center; gap: 8px; font-weight: 600; font-size: 14px;">
                </div>

                <!-- Verified Details Grid -->
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 16px;">
                  <div style="background: rgba(255,255,255,0.02); padding: 10px; border-radius: 8px; border: 1px solid var(--border);">
                    <div style="font-size: 10px; color: var(--text-muted); text-transform: uppercase;">Utilisateur</div>
                    <div id="res-user" style="font-size: 13px; font-weight: 700; color: var(--text-main); margin-top: 2px;">-</div>
                  </div>
                  <div style="background: rgba(255,255,255,0.02); padding: 10px; border-radius: 8px; border: 1px solid var(--border);">
                    <div style="font-size: 10px; color: var(--text-muted); text-transform: uppercase;">Type de Transaction</div>
                    <div id="res-type" style="font-size: 13px; font-weight: 700; color: var(--primary); margin-top: 2px;">-</div>
                  </div>
                  <div style="background: rgba(255,255,255,0.02); padding: 10px; border-radius: 8px; border: 1px solid var(--border);">
                    <div style="font-size: 10px; color: var(--text-muted); text-transform: uppercase;">Montant Reçu / Retiré</div>
                    <div id="res-amount" style="font-size: 13px; font-weight: 700; color: var(--success); margin-top: 2px;">-</div>
                  </div>
                  <div style="background: rgba(255,255,255,0.02); padding: 10px; border-radius: 8px; border: 1px solid var(--border);">
                    <div style="font-size: 10px; color: var(--text-muted); text-transform: uppercase;">Date de Transaction</div>
                    <div id="res-date" style="font-size: 13px; font-weight: 700; color: var(--text-main); margin-top: 2px;">-</div>
                  </div>
                </div>

                <!-- On-chain verification info -->
                <div style="background: rgba(255,255,255,0.02); padding: 12px; border-radius: 8px; border: 1px solid var(--border); margin-bottom: 12px;">
                  <div style="font-size: 10px; color: var(--text-muted); text-transform: uppercase; margin-bottom: 4px;">Hash de Transaction</div>
                  <div id="res-tx-hash" style="font-family: monospace; font-size: 11px; color: var(--text-main); word-break: break-all;">-</div>
                </div>

                <!-- DB details -->
                <div style="background: rgba(255,255,255,0.02); padding: 12px; border-radius: 8px; border: 1px solid var(--border);">
                  <div style="font-size: 10px; color: var(--text-muted); text-transform: uppercase; margin-bottom: 6px;">Statut Base de Données</div>
                  <div style="display: flex; align-items: center; justify-content: space-between;">
                    <span id="res-db-status" class="badge active">-</span>
                    <span id="res-id" style="font-size: 11px; color: var(--text-muted);">ID Enregistrement: -</span>
                  </div>
                </div>

              </div>
            </div>
          </div>
        </div>
      </div>
      <% } %>

      <!-- SMTP Settings -->
      <% if (isPage('smtp')) { %>
      <div class="section-card" id="settings">
        <div class="section-header">
          <div>
            <h3>Configuration systeme et SMTP</h3>
            <p>Centralisez les variables de communication et les parametres techniques globaux.</p>
          </div>
        </div>
        <div class="settings-form">
          <form action="/admin/settings" method="POST">
            <% settings.forEach(setting => { %>
              <div class="form-group">
                <label><%= setting.description %> (<%= setting.setting_key %>)</label>
                <input type="<%= setting.setting_key.includes('pass') ? 'password' : 'text' %>" name="<%= setting.setting_key %>" value="<%= setting.setting_value %>">
              </div>
            <% }) %>
            <button type="submit" class="btn" style="margin-top: 10px;">Mettre à jour la configuration</button>
          </form>
        </div>
      </div>

      <!-- Danger Zone -->
      <div class="section-card" style="border-color: rgba(239, 68, 68, 0.3);">
        <div class="section-header" style="background: rgba(239, 68, 68, 0.05); border-bottom-color: rgba(239, 68, 68, 0.3);">
          <h3 style="color: var(--danger);">Zone dangereuse</h3>
        </div>
        <div class="settings-form">
          <p style="color: var(--text-muted); font-size: 14px; margin-bottom: 20px;">
            Attention : Vider la base de données supprimera définitivement tous les utilisateurs, publications, messages et commentaires. Seuls les comptes administrateurs et la configuration SMTP seront conservés. Cette action est irréversible.
          </p>
          <form action="/admin/empty-database" method="POST" onsubmit="return confirm('Êtes-vous ABSOLUMENT certain de vouloir vider toute la base de données ? Il n\'y a pas de retour en arrière possible.');">
            <button type="submit" class="btn" style="background: var(--danger);">Vider la base de données</button>
          </form>
        </div>
      </div>
      <% } %>

      <!-- Messagerie d'administration -->
      <% if (isPage('messaging')) { %>
      <div class="section-card" id="messaging-panel">
        <div class="section-header">
          <div>
            <h3>Envoyer un message ou une notification</h3>
            <p>Communiquez directement avec un utilisateur ciblé ou diffusez un message important à l'ensemble des membres de la communauté.</p>
          </div>
        </div>
        <div class="settings-form" style="padding: 24px;">
          <form id="adminMessagingForm" style="display: flex; flex-direction: column; gap: 18px;">
            <div id="messagingAlert" style="display: none; padding: 12px 16px; border-radius: 8px; font-weight: 500; font-size: 14px;"></div>

            <div class="form-group">
              <label style="display: block; margin-bottom: 6px; font-weight: 600; font-size: 13px; color: var(--text-main);">Destinataire</label>
              <div style="display: flex; gap: 16px; align-items: center; margin-top: 6px;">
                <label style="display: flex; align-items: center; gap: 8px; font-size: 14px; cursor: pointer; color: var(--text-main);">
                  <input type="radio" name="target_type" value="all" checked style="accent-color: var(--primary);">
                  Tous les utilisateurs
                </label>
                <label style="display: flex; align-items: center; gap: 8px; font-size: 14px; cursor: pointer; color: var(--text-main);">
                  <input type="radio" name="target_type" value="single" style="accent-color: var(--primary);">
                  Un utilisateur spécifique
                </label>
              </div>
            </div>

            <div class="form-group" id="singleUserSelectGroup" style="display: none;">
              <label for="target_user_id" style="display: block; margin-bottom: 6px; font-weight: 600; font-size: 13px; color: var(--text-main);">Sélectionner l'utilisateur</label>
              <select id="target_user_id" name="target_user_id" style="width: 100%; height: 42px; border-radius: 8px; border: 1px solid var(--border); padding: 0 12px; background: var(--card-bg); color: var(--text-main); font-size: 14px; outline: none;">
                <option value="">-- Choisir un utilisateur --</option>
                <% users.forEach(user => { %>
                  <option value="<%= user.id %>"><%= user.first_name %> <%= user.last_name %> (@<%= user.username %>)</option>
                <% }) %>
              </select>
            </div>

            <div class="form-group">
              <label for="message_text" style="display: block; margin-bottom: 6px; font-weight: 600; font-size: 13px; color: var(--text-main);">Message à envoyer</label>
              <textarea id="message_text" name="message_text" rows="4" placeholder="Tapez votre message ici (max 255 caractères)..." maxlength="255" style="width: 100%; border-radius: 8px; border: 1px solid var(--border); padding: 12px; background: var(--card-bg); color: var(--text-main); font-size: 14px; outline: none; font-family: inherit; resize: vertical;" required></textarea>
            </div>

            <button type="submit" class="btn" id="messagingSubmitBtn" style="min-height: 42px; display: flex; align-items: center; justify-content: center; gap: 8px; width: fit-content; padding: 0 24px; border: none; border-radius: 12px; background: var(--primary); color: #fff; font-weight: 600; cursor: pointer; transition: all 0.2s;">
              <i data-lucide="send" style="width: 16px; height: 16px; color: #fff;"></i>
              <span>Envoyer le message</span>
            </button>
          </form>
        </div>
      </div>

      <script>
        document.addEventListener('DOMContentLoaded', () => {
          const radioAll = document.querySelector('input[name="target_type"][value="all"]');
          const radioSingle = document.querySelector('input[name="target_type"][value="single"]');
          const singleGroup = document.getElementById('singleUserSelectGroup');
          const form = document.getElementById('adminMessagingForm');
          const alertBox = document.getElementById('messagingAlert');
          const submitBtn = document.getElementById('messagingSubmitBtn');

          function toggleGroup() {
            if (radioSingle && radioSingle.checked) {
              singleGroup.style.display = 'block';
              document.getElementById('target_user_id').required = true;
            } else {
              singleGroup.style.display = 'none';
              document.getElementById('target_user_id').required = false;
            }
          }

          if (radioAll && radioSingle) {
            radioAll.addEventListener('change', toggleGroup);
            radioSingle.addEventListener('change', toggleGroup);
          }

          if (form) {
            form.addEventListener('submit', async (e) => {
              e.preventDefault();
              alertBox.style.display = 'none';
              submitBtn.disabled = true;
              submitBtn.querySelector('span').textContent = 'Envoi en cours...';

              const formData = {
                target_type: form.elements['target_type'].value,
                target_user_id: form.elements['target_user_id'].value,
                message_text: form.elements['message_text'].value
              };

              try {
                const res = await fetch('/admin/messaging/send', {
                  method: 'POST',
                  headers: {
                    'Content-Type': 'application/json'
                  },
                  body: JSON.stringify(formData)
                });

                const data = await res.json();
                if (data.success) {
                  alertBox.style.background = 'rgba(34, 181, 115, 0.15)';
                  alertBox.style.color = 'var(--success)';
                  alertBox.textContent = data.message;
                  alertBox.style.display = 'block';
                  form.elements['message_text'].value = '';
                } else {
                  alertBox.style.background = 'rgba(239, 90, 90, 0.15)';
                  alertBox.style.color = 'var(--danger)';
                  alertBox.textContent = data.error || 'Une erreur est survenue.';
                  alertBox.style.display = 'block';
                }
              } catch (err) {
                console.error(err);
                alertBox.style.background = 'rgba(239, 90, 90, 0.15)';
                alertBox.style.color = 'var(--danger)';
                alertBox.textContent = 'Erreur réseau ou serveur.';
                alertBox.style.display = 'block';
              } finally {
                submitBtn.disabled = false;
                submitBtn.querySelector('span').textContent = 'Envoyer le message';
              }
            });
          }
        });
      </script>
      <% } %>

    </div>
  </main>

