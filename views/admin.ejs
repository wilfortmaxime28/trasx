    const adminAccountsList = Array.isArray(typeof adminAccounts !== 'undefined' ? adminAccounts : [])
      ? (typeof adminAccounts !== 'undefined' ? adminAccounts : [])
      : [];
    const formatUsd = (value) => `$${Number(value || 0).toFixed(2)}`;
    const formatTokenBalance = (value) => Number(value || 0).toFixed(4).replace(/\.?0+$/, '');
    const revenueSummary = platformRevenueSummary || { total_usd_equivalent: 0, total_usd_native: 0, total_tokens_native: 0, entries_count: 0 };
