      });
    }

    if (fileInput) {
      fileInput.addEventListener('change', (e) => {
        if (e.target.files && e.target.files.length > 0) {
          handleQrFile(e.target.files[0]);
        }
      });
    }

    function handleQrFile(file) {
      const reader = new FileReader();
      reader.onload = function(event) {
        const img = new Image();
        img.onload = function() {
          const canvas = document.createElement('canvas');
          const ctx = canvas.getContext('2d');
          canvas.width = img.width;
          canvas.height = img.height;
          ctx.drawImage(img, 0, 0, img.width, img.height);
          const imageData = ctx.getImageData(0, 0, img.width, img.height);
          
          if (typeof jsQR === 'undefined') {
            alert("Erreur: La bibliothèque jsQR n'a pas pu être chargée. Collez manuellement le code.");
            return;
          }
          
          const code = jsQR(imageData.data, imageData.width, imageData.height);
          if (code && code.data) {
            encryptedCodeTextarea.value = code.data;
            alert('QR Code détecté et lu avec succès !');
            decryptForm.dispatchEvent(new Event('submit'));
          } else {
            alert("Impossible de lire un QR code valide dans cette image. Assurez-vous que l'image est nette.");
          }
        };
        img.src = event.target.result;
      };
      reader.readAsDataURL(file);
    }

    if (decryptForm) {
      decryptForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const code = encryptedCodeTextarea.value.trim();
        if (!code) {
          alert('Veuillez entrer un code chiffré.');
          return;
        }

        // Set UI to loading state
        decryptPlaceholder.style.display = 'none';
        decryptContent.style.display = 'none';
        
        try {
          const response = await fetch('/admin/decrypt-receipt', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/x-www-form-urlencoded',
            },
            body: new URLSearchParams({ encryptedCode: code })
          });
          
          const data = await response.json();
          
          if (!response.ok || !data.success) {
            throw new Error(data.message || 'Erreur lors du décryptage.');
          }
          
          decryptContent.style.display = 'block';
          
          if (data.authentic) {
            decryptStatusBanner.style.background = 'rgba(16, 185, 129, 0.15)';
            decryptStatusBanner.style.border = '1px solid var(--success)';
            decryptStatusBanner.style.color = 'var(--success)';
            decryptStatusBanner.innerHTML = `<i data-lucide="check-circle" style="width: 18px; height: 18px;"></i> Reçu Authentique & Validé`;
          } else {
            decryptStatusBanner.style.background = 'rgba(239, 68, 68, 0.15)';
            decryptStatusBanner.style.border = '1px solid var(--danger)';
            decryptStatusBanner.style.color = 'var(--danger)';
            decryptStatusBanner.innerHTML = `<i data-lucide="alert-triangle" style="width: 18px; height: 18px;"></i> ALERTE FRAUDE (Données incohérentes)`;
          }

          if (data.dbRecord) {
            document.getElementById('res-user').innerHTML = `@${data.dbRecord.username} (${data.dbRecord.user_name})`;
            document.getElementById('res-type').innerHTML = data.dbRecord.type === 'deposit' ? 'Dépôt USDT' : 'Retrait USDT';
            document.getElementById('res-type').style.color = data.dbRecord.type === 'deposit' ? 'var(--success)' : 'var(--primary)';
            
            let amountLabel = `${parseFloat(data.dbRecord.amount_usdt).toFixed(2)} USDT`;
            if (data.dbRecord.type === 'withdrawal') {
              amountLabel += `<br><span style="font-size: 11px; color: var(--text-muted);">Net : ${parseFloat(data.dbRecord.net_amount_usdt).toFixed(2)} USDT (frais: ${parseFloat(data.dbRecord.fee_usdt).toFixed(2)} USDT)</span>`;
            }
            document.getElementById('res-amount').innerHTML = amountLabel;
            document.getElementById('res-date').innerHTML = new Date(data.dbRecord.created_at).toLocaleString();
            document.getElementById('res-tx-hash').innerHTML = data.dbRecord.tx_hash || 'En attente';
            
            const badge = document.getElementById('res-db-status');
            badge.innerHTML = data.dbRecord.status;
            badge.className = 'badge';
            if (data.dbRecord.status === 'confirmed' || data.dbRecord.status === 'completed') {
              badge.classList.add('active');
            } else if (data.dbRecord.status === 'pending') {
              badge.classList.add('paused');
            } else {
              badge.classList.add('blocked');
            }
            
            document.getElementById('res-id').innerHTML = `ID Enregistrement: ${data.dbRecord.id}`;
          } else {
            document.getElementById('res-user').innerHTML = `Utilisateur ID: ${data.decryptedPayload.user_id}`;
            document.getElementById('res-type').innerHTML = data.decryptedPayload.type === 'deposit' ? 'Dépôt USDT' : 'Retrait USDT';
            document.getElementById('res-amount').innerHTML = `${parseFloat(data.decryptedPayload.amount).toFixed(2)} USDT`;
            document.getElementById('res-date').innerHTML = new Date(data.decryptedPayload.date).toLocaleString();
            document.getElementById('res-tx-hash').innerHTML = data.decryptedPayload.tx_hash || 'None';
            
            const badge = document.getElementById('res-db-status');
            badge.innerHTML = 'INTRAÇABLE EN BDD';
            badge.className = 'badge blocked';
            
            document.getElementById('res-id').innerHTML = `ID Décrypté: ${data.decryptedPayload.id}`;
          }
          
          if (typeof lucide !== 'undefined') lucide.createIcons();
          
        } catch (error) {
          decryptPlaceholder.style.display = 'flex';
          alert(error.message);
        }
      });
    }

    async function handleReportAction(reportId, action, targetId) {
      let url = '';
      let body = {};
      let confirmMsg = '';

      if (action === 'dismiss') {
        url = '/admin/moderation/dismiss-report';
        body = { reportId };
        confirmMsg = 'Voulez-vous vraiment ignorer ce signalement ?';
      } else if (action === 'delete-post') {
        url = '/admin/moderation/delete-reported-post';
        body = { postId: targetId };
        confirmMsg = 'Voulez-vous vraiment supprimer définitivement ce post ?';
      } else if (action === 'block-user') {
        url = '/admin/moderation/block-reported-user';
        body = { userId: targetId };
        confirmMsg = 'Voulez-vous vraiment bloquer définitivement le compte de cet auteur ?';
      }

      if (!url || !confirm(confirmMsg)) return;

      try {
        const response = await fetch(url, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json'
          },
          body: JSON.stringify(body)
        });
        const result = await response.json();
        if (response.ok && result.success) {
          alert(result.message);
          window.location.reload();
        } else {
          alert(result.message || 'Une erreur est survenue.');
        }
      } catch (err) {
        console.error(err);
        alert('Erreur réseau ou serveur.');
      }
    }

    async function handleAdminRecoverDeposit(event) {
      event.preventDefault();
      const userIdEl = document.getElementById('adminRecoverUserId');
      const txHashEl = document.getElementById('adminRecoverTxHash');
      const msgEl = document.getElementById('adminRecoverStatusMsg');
      const btn = document.getElementById('adminRecoverSubmitBtn');
      if (!userIdEl || !txHashEl || !msgEl || !btn) return;

      const userId = userIdEl.value.trim();
      const txHash = txHashEl.value.trim();

      if (!userId || isNaN(Number(userId))) {
        showRecoverMsg('error', "Veuillez saisir un ID utilisateur valide.");
        return;
      }
      if (!txHash || !/^0x[a-fA-F0-9]{64}$/i.test(txHash)) {
        showRecoverMsg('error', "Veuillez saisir un TxID valide (0x + 64 caractères hexadécimaux).");
        return;
      }

      btn.disabled = true;
      btn.textContent = 'Vérification...';
      showRecoverMsg('info', 'Contact de la blockchain en cours...');

      try {
        const response = await fetch('/admin/deposits/recover-txid', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json'
          },
          body: JSON.stringify({ userId: Number(userId), txHash })
        });
        const result = await response.json();

        if (response.ok && result.success) {
          showRecoverMsg('success', result.message || 'Dépôt récupéré et crédité avec succès !');
          userIdEl.value = '';
          txHashEl.value = '';
          btn.textContent = 'Dépôt crédité !';
          setTimeout(() => {
            window.location.reload();
          }, 1500);
        } else {
          showRecoverMsg('error', result.error || 'Une erreur est survenue.');
          btn.disabled = false;
          btn.textContent = 'Vérifier et créditer le dépôt';
        }
      } catch (err) {
        console.error(err);
        showRecoverMsg('error', 'Erreur réseau ou serveur.');
        btn.disabled = false;
        btn.textContent = 'Vérifier et créditer le dépôt';
      }
    }

    function showRecoverMsg(type, text) {
      const el = document.getElementById('adminRecoverStatusMsg');
      if (!el) return;
      el.style.display = 'block';
      el.textContent = text;
      if (type === 'success') {
        el.style.background = 'rgba(16, 185, 129, 0.15)';
        el.style.border = '1px solid var(--success)';
        el.style.color = 'var(--success)';
      } else if (type === 'error') {
        el.style.background = 'rgba(239, 68, 68, 0.15)';
        el.style.border = '1px solid var(--danger)';
        el.style.color = 'var(--danger)';
      } else {
        el.style.background = 'rgba(59, 130, 246, 0.15)';
        el.style.border = '1px solid var(--primary)';
        el.style.color = 'var(--primary)';
      }
    }

    // Script pour le changement de mot de passe administrateur
    document.addEventListener('DOMContentLoaded', () => {
      const changePasswordBtn = document.getElementById('changePasswordBtn');
      const changePasswordModal = document.getElementById('changePasswordModal');
      const changePasswordModalClose = document.getElementById('changePasswordModalClose');
      const changePasswordModalCancel = document.getElementById('changePasswordModalCancel');
      const changePasswordForm = document.getElementById('changePasswordForm');
      const changePasswordMessage = document.getElementById('changePasswordMessage');
      const changePasswordSubmitBtn = document.getElementById('changePasswordSubmitBtn');

      if (changePasswordBtn && changePasswordModal) {
        // Open modal
        changePasswordBtn.addEventListener('click', () => {
          changePasswordForm.reset();
          if (changePasswordMessage) {
            changePasswordMessage.style.display = 'none';
            changePasswordMessage.innerHTML = '';
          }
          changePasswordModal.classList.add('is-open');
          changePasswordModal.setAttribute('aria-hidden', 'false');
        });

        // Close modal helpers
        const closeCPModal = () => {
          changePasswordModal.classList.remove('is-open');
          changePasswordModal.setAttribute('aria-hidden', 'true');
        };

        if (changePasswordModalClose) {
          changePasswordModalClose.addEventListener('click', closeCPModal);
        }
        if (changePasswordModalCancel) {
          changePasswordModalCancel.addEventListener('click', closeCPModal);
        }

        // Close on clicking outside dialog
        changePasswordModal.addEventListener('click', (event) => {
          if (event.target === changePasswordModal) {
            closeCPModal();
          }
        });

        // Close on Escape key
        document.addEventListener('keydown', (event) => {
          if (event.key === 'Escape' && changePasswordModal.classList.contains('is-open')) {
            closeCPModal();
          }
        });

        // Handle form submission
        changePasswordForm.addEventListener('submit', async (e) => {
          e.preventDefault();

          const currentPassword = document.getElementById('current_password').value;
          const newPassword = document.getElementById('new_password').value;
          const confirmPassword = document.getElementById('confirm_password').value;

          if (changePasswordMessage) {
            changePasswordMessage.style.display = 'none';
            changePasswordMessage.innerHTML = '';
          }

          if (newPassword !== confirmPassword) {
            showCPMessage('Le nouveau mot de passe et sa confirmation ne correspondent pas.', 'error');
            return;
          }

          if (newPassword.length < 6) {
            showCPMessage('Le nouveau mot de passe doit faire au moins 6 caractères.', 'error');
            return;
          }

          // Set button loading state
          if (changePasswordSubmitBtn) {
            changePasswordSubmitBtn.disabled = true;
            changePasswordSubmitBtn.textContent = 'Mise à jour...';
          }

          try {
            const response = await fetch('/admin/change-password', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
                'Accept': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
              },
              body: JSON.stringify({
                current_password: currentPassword,
                new_password: newPassword,
                confirm_password: confirmPassword
              })
            });

            const data = await response.json();

            if (response.ok && data.success) {
              showCPMessage(data.message || 'Mot de passe modifié avec succès.', 'success');
              changePasswordForm.reset();
              setTimeout(() => {
                closeCPModal();
              }, 1500);
            } else {
              showCPMessage(data.message || 'Erreur lors de la modification du mot de passe.', 'error');
            }
          } catch (error) {
            console.error('Error updating password:', error);
            showCPMessage('Une erreur réseau ou serveur est survenue.', 'error');
          } finally {
            if (changePasswordSubmitBtn) {
              changePasswordSubmitBtn.disabled = false;
              changePasswordSubmitBtn.textContent = 'Confirmer';
            }
          }
        });

        function showCPMessage(text, type) {
          if (!changePasswordMessage) return;
          changePasswordMessage.style.display = 'block';
          changePasswordMessage.textContent = text;
          
          if (type === 'success') {
            changePasswordMessage.style.background = 'rgba(16, 185, 129, 0.15)';
            changePasswordMessage.style.border = '1px solid var(--success)';
            changePasswordMessage.style.color = 'var(--success)';
          } else {
            changePasswordMessage.style.background = 'rgba(239, 68, 68, 0.15)';
            changePasswordMessage.style.border = '1px solid var(--danger)';
            changePasswordMessage.style.color = 'var(--danger)';
          }
        }
      }
    });
  </script>
</body>
</html>
