            <div style="font-size: 11px; color: var(--text-muted); margin-top: 4px;">+<%= officialSeedStats.contentBatchSize %> par clic</div>
          </div>
          <div style="padding: 16px; border-radius: 16px; background: rgba(245, 158, 11, 0.08); border: 1px solid rgba(245, 158, 11, 0.14);">
            <div style="font-size: 12px; color: var(--text-muted); margin-bottom: 6px;">Status générés</div>
            <div style="font-size: 26px; font-weight: 800; color: var(--text-main);"><%= officialSeedStats.statusCount %></div>
            <div style="font-size: 11px; color: var(--text-muted); margin-top: 4px;">+<%= officialSeedStats.contentBatchSize %> par clic</div>
          </div>
        </div>

        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 18px; align-items: start;">
