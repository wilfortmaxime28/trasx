    const initializeAdminReasonForms = (root = document) => {
      const restrictedStatuses = new Set(['Paused', 'Partially Blocked', 'Blocked']);

      root.querySelectorAll('[data-account-status-form]').forEach((form) => {
        if (form.dataset.reasonBound === '1') return;
        form.dataset.reasonBound = '1';

        const statusSelect = form.querySelector('[data-account-status-select]');
        const restrictionFields = form.querySelector('[data-account-restriction-fields]');
        const reasonSelect = form.querySelector('[data-account-reason-select]');
        const customReasonInput = form.querySelector('[data-account-custom-reason]');

        const toggleCustomReasonField = () => {
          const shouldShowCustomReason = statusSelect
            && restrictedStatuses.has(statusSelect.value)
            && reasonSelect
            && reasonSelect.value === 'Autre';
          if (!customReasonInput) return;
          customReasonInput.style.display = shouldShowCustomReason ? 'block' : 'none';
          customReasonInput.required = !!shouldShowCustomReason;
        };

        const toggleRestrictionFields = () => {
          const shouldShowRestrictionFields = statusSelect && restrictedStatuses.has(statusSelect.value);
          if (restrictionFields) {
            restrictionFields.style.display = shouldShowRestrictionFields ? 'grid' : 'none';
          }
          if (reasonSelect) {
            reasonSelect.required = !!shouldShowRestrictionFields;
          }
          if (!shouldShowRestrictionFields && customReasonInput) {
            customReasonInput.required = false;
          }
          toggleCustomReasonField();
        };

        if (statusSelect) {
          statusSelect.addEventListener('change', toggleRestrictionFields);
        }
        if (reasonSelect) {
          reasonSelect.addEventListener('change', toggleCustomReasonField);
        }

        toggleRestrictionFields();
      });

      root.querySelectorAll('[data-moderation-reason-form]').forEach((form) => {
        if (form.dataset.reasonBound === '1') return;
        form.dataset.reasonBound = '1';

        const reasonSelect = form.querySelector('[data-moderation-reason-select]');
