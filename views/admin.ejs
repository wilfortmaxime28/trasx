                            <div>
                              <div style="font-weight: 700; cursor: pointer;" onclick="openAdminUserModal('admin-user-detail-template-<%= user.id %>')">
                                <%= user.first_name %> <%= user.last_name %>
                              </div>
                              <div style="font-size: 12px; color: var(--text-muted);">@<%= user.username %> · <%= user.email %></div>
                            </div>
                          </div>
                        </td>
                        <td>
                          <span class="badge <%= user.account_status === 'Blocked' ? 'blocked' : 'partially' %>">
                            <%= user.account_status === 'Blocked' ? 'Bloqué' : 'Partiellement bloqué' %>
                          </span>
                        </td>
                        <td style="font-weight: 600;">
                          <%= user.account_restriction_reason || 'Raison non renseignée' %>
                        </td>
                        <td style="color: var(--text-muted);">
                          <%= user.account_restriction_details || 'Aucun détail visible.' %>
                        </td>
                        <td>
                          <%= user.account_restriction_updated_at ? new Date(user.account_restriction_updated_at).toLocaleString('fr-FR') : '—' %>
                        </td>
                        <td>
